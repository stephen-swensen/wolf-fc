        28,   // nein_sovass  (NEINSOVASSND -> digi 28)
        20,   // leben        (LEBENSND -> digi 20)
        17,   // ahhhg        (AHHHGSND -> digi 17)
         8,   // gutentag     (GUTENTAGSND -> digi 8)
