    // Play a sound by sfx.id.*. Prefers the digitized version (richer
    // audio, matches the original Sound Blaster mode) and falls back to
    // the AdLib version loaded from AUDIOT on demand. `pan` is [-1, +1];
    // 0 = centered. `gain` is a linear multiplier — 1.0 plays at the
    // OG Sound Blaster level, <1 attenuates, >1 pushes into the mixer's
    // soft-clip region. Only the digi path honours pan/gain; the AdLib
    // fallback routes through the OPL2 chip, which has no cheap per-note
    // attenuation knob (in practice enemy/pickup sounds all have digi
    // versions, so the fall-through is silent for spatial callers).
    private let trigger_panned_gain = (sound_id: int32, ac: audio_ctx*,
                                pan: float64, gain: float64) ->
        if sound_id < 0 || sound_id >= count then return
        let digi_idx = digi_slot[sound_id]
        if digi_idx >= 0 then
            digi.play_with_gain(ac->digi, digi_idx, pan, gain)
        else
            let enum_val = adlib_chunk[sound_id]
            if enum_val >= 0 then
                let chunk = 87 + enum_val   // STARTADLIBSOUNDS = LASTSOUND = 87
                if chunk >= 0 && chunk < ac->ad->num_chunks then
                    let off = (int64) audio.chunk_offset(ac->ad, chunk)
                    let len = audio.chunk_length(ac->ad, chunk)
                    if len >= 23 then
                        adlib.play(ac->sfx, adlib.parse(ac->ad->raw, off))

    private let trigger_panned = (sound_id: int32, ac: audio_ctx*, pan: float64) ->
        trigger_panned_gain(sound_id, ac, pan, 1.0)

    let trigger = (sound_id: int32, ac: audio_ctx*) ->
        trigger_panned_gain(sound_id, ac, 0.0, 1.0)

    let trigger_loud = (sound_id: int32, ac: audio_ctx*, gain: float64) ->
        trigger_panned_gain(sound_id, ac, 0.0, gain)

    // Spatial variant: pans a source in the stereo field AND attenuates
    // by distance, so a guard firing across the level is quiet and off
    // to the side while the same guard at point-blank is loud and
    // centered. Takes the player struct so we can look up pos + camera
    // plane.
    //
    // Pan mapping: project the source→player vector onto the player's
    // camera-plane axis (perpendicular to facing). That's exactly how
    // the raycaster decides horizontal screen-x for sprites, so a
    // source sitting right of the player on screen will pan right.
    //
    // Distance mapping: linear rolloff from full volume at the player's
    // tile to silent at ~16 tiles out. Roughly matches the original's
    // attenuation tables (ATABLEMAX=15 in PlaySoundLocGlobal), which
    // also silenced sources beyond that radius. Sounds past the cutoff
    // are dropped entirely so distant enemies don't eat mix slots.
    let trigger_at = (sound_id: int32, ac: audio_ctx*, g: game*,
                       x: float64, y: float64) ->
        let dx = x - g->pos_x
        let dy = y - g->pos_y
        let dist_sq = dx * dx + dy * dy
        let dist = math.sqrt(dist_sq)
        let max_dist = 16.0
        let gain = if dist >= max_dist then 0.0
                   else (max_dist - dist) / max_dist
        if gain <= 0.0 then return
        // Very-close sounds (<1 tile) stay centered so stepping past an
        // enemy doesn't produce a hard stereo flip.
        if dist_sq < 1.0 then
            trigger_panned_gain(sound_id, ac, 0.0, gain)
        else
            // Camera-plane axis is g->plane; its sign tells us which side.
            let plen = math.sqrt(g->plane_x * g->plane_x + g->plane_y * g->plane_y)
            let pan_raw = if plen < 1e-4 then 0.0
                else (dx * g->plane_x + dy * g->plane_y) / (plen * dist)
            // Soften pan by distance so far-off sources don't ping-pong
            // across the soundstage; at 16 tiles pan settles to ~half
            // of raw.
            let pan_atten = 1.0 / (1.0 + dist / 8.0)
            let pan = pan_raw * (0.4 + 0.6 * pan_atten)
            trigger_panned_gain(sound_id, ac, pan, gain)
