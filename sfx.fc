// Wolf-FC sound effects — mapping of game events to AUDIOT chunk IDs, and
// the trigger helpers that queue an AdLib SFX or digitized PCM clip from
// the `audio_ctx` owned by `world`. Digi-pack clips are preferred when
// present (matches the original Sound Blaster mode); the AdLib chunk from
// AUDIOT is the fallback.
//
// Every sound the game triggers is indexed by `sfx.id.*` — each id is a
// row number into the `digi_slot` / `adlib_chunk` tables below.
//
// To add a new sound:
//   1. Append a constant to `module sfx.id` and bump `sfx.count`,
//   2. extend `digi_slot` and `adlib_chunk` with the right lookup row,
//   3. call `sfx.trigger(sfx.id.new_one, ac)` from the new site.

module sfx =
    import math from std::

    // Sound IDs — indexes into the sfx_digi_slot / sfx_adlib_chunk
    // tables in main.fc. Not Wolf3D AUDIOT enum values, and not digi-
    // pack slot numbers. The tables translate.
    module id =
        let open_door      = 0
        let close_door     = 1
        let atk_pistol     = 2
        let atk_knife      = 3
        let atk_mg         = 4
        let atk_gat        = 5
        let get_key        = 6
        let get_ammo       = 7
        let bonus1         = 8    // cross
        let pain           = 9
        let push_wall      = 10
        let get_mg         = 11
        let get_gat        = 12
        let hit_wall       = 13
        let no_action      = 14
        let no_way         = 15
        let bonus2         = 16   // chalice
        let bonus3         = 17   // bible
        let bonus4         = 18   // crown
        let bonus1up       = 19   // extra life
        let health1        = 20   // dog food / food
        let health2        = 21   // first aid
        let halt           = 22   // guard/officer alert ("Halt!")
        let schutzad       = 23   // SS alert ("Schutzstaffel!")
        let dog_bark       = 24   // dog alert
        let nazi_fire      = 25   // guard/officer fire
        let ss_fire        = 26   // SS rapid fire
        let dog_attack     = 27   // dog bite
        let dog_death      = 28
        let death_1        = 29   // guard death scream (aka DEATHSCREAM1SND)
        let death_2        = 30   // officer death scream
        let death_3        = 31   // SS death scream
        // HITENEMYSND exists in the original's audio enum but is never
        // played anywhere — kept as a table slot for completeness.
        let hit_enemy      = 32   // bullet impact on flesh — unused
        // Expanded guard death scream pool (original A_DeathScream picks
        // one of 8 at random for guardobj). First three are death_1..3.
        let death_4        = 33   // DEATHSCREAM4SND
        let death_5        = 34
        let death_6        = 35
        let death_7        = 36
        let death_8        = 37
        let death_9        = 38
        // Per-kind / per-boss vocals. Sighting = "FirstSighting" vocal
        // played once when enemy wakes. Death = played from A_DeathScream.
        let spion          = 39   // SPIONSND — officer sighting
        let nein_sovass    = 40   // NEINSOVASSND — officer death
        let leben          = 41   // LEBENSND — SS death ("Mein Leben!")
        let ahhhg          = 42   // AHHHGSND — mutant death
        let gutentag       = 43   // GUTENTAGSND — Hans sighting
        let mutti          = 44   // MUTTISND — Hans death ("Mutti!")
        let kein           = 45   // KEINSND — Gretel sighting
        let mein           = 46   // MEINSND — Gretel death
        let eine           = 47   // EINESND — Giftmacher sighting
        let donner         = 48   // DONNERSND — Giftmacher death
        let erlauben       = 49   // ERLAUBENSND — Fat Face sighting
        let rose           = 50   // ROSESND — Fat Face death
        let schabbsha      = 51   // SCHABBSHASND — Schabbs sighting
        let meingott       = 52   // MEINGOTTSND — Schabbs death
        let tot_hund       = 53   // TOT_HUNDSND — Fake Hitler sighting
        let hitlerha       = 54   // HITLERHASND — Fake Hitler death
        let die            = 55   // DIESND — Mecha/Real Hitler sighting
        let scheist        = 56   // SCHEISTSND — Mecha Hitler death
        let eva            = 57   // EVASND — Real Hitler death
        // Intermission / elevator sounds
        let level_done     = 58   // LEVELDONESND — elevator switch "ding"
        let end_bonus1     = 59   // ENDBONUS1SND — per-tick counter during countup
        let end_bonus2     = 60   // ENDBONUS2SND — counter stopped (non-100%)
        let percent100     = 61   // PERCENT100SND — 100% ratio bonus
        let no_bonus       = 62   // NOBONUSSND — 0% ratio
        // Boss-specific attack sounds. The original dispatches T_Shoot's
        // firing sound per obclass; wolf-fc previously routed every
        // non-SS boss to nazi_fire, which sounded wrong for bosses.
        let boss_fire      = 63   // BOSSFIRESND — Hans, Mecha/Real Hitler gun
        let schabbs_throw  = 64   // SCHABBSTHROWSND — Schabbs syringe (AdLib only)
        let flamethrower   = 65   // FLAMETHROWERSND — Fake Hitler (AdLib only)
        let missile_fire   = 66   // MISSILEFIRESND — Gift / Fat rocket
        // Placeholders: mapping is filled so late-landing callers don't
        // revisit this table. No current trigger site — mech_step waits
        // on a separate Mecha Hitler stage and yeah waits on T_BJYell.
        let mech_step      = 67   // MECHSTEPSND — Mecha Hitler walk stomp
        let yeah           = 68   // YEAHSND — BJ victory-jump exclamation
        // Menu UI sounds. AdLib-only — none have digi versions.
        let move_gun1      = 69   // MOVEGUN1SND — menu cursor move
        let shoot          = 70   // SHOOTSND — menu item confirm
        let esc_pressed    = 71   // ESCPRESSEDSND — menu cancel / back
        let missile_hit    = 72   // MISSILEHITSND — rocket wall explosion
        let slurpie        = 73   // SLURPIESND — gibs pickup slurp

    // Total number of sfx.id.* entries. The sfx_digi_slot / sfx_adlib_chunk
    // tables in main.fc are sized to this.
    private let count = 74

    // --- AUDIOT enum IDs the original triggered but wolf-fc still doesn't.
    //     Append a new `id.*` above when wiring one up. Tracked in TODO.md.
    //
    //   move_gun2        = 4   MOVEGUN2SND      — keybind-rebind confirm beep
    //   player_death     = 9   PLAYERDEATHSND   — BJ's dying scream on killing blow
    //   shoot_door       = 28  SHOOTDOORSND     — keybind-menu confirm (NOT door hits)
    //
    // Other AUDIOT chunks (SELECTWPNSND, HEARTBEATSND, NAZIHITPLAYERSND,
    // WALK1/2SND, GAMEOVERSND, NOITEMSND, BOSSACTIVESND, GOOBSSND, etc.)
    // exist as data but were never called from the original — see the
    // 2026-04-25 audit in TODO.md. Don't add them as fidelity items.

    // Output sample rate for the SDL audio device (Hz). All driver
    // chips run at this rate. The int32-mix + soft-clip finalizer lives
    // in `sound.fc::mixer` — the main loop just calls `mixer.fill_frame`
    // and queues the resulting int16 buffer to SDL.
    let sample_rate = 44100

    // Digi-pack index for each sfx.id.* (-1 = no digitized version).
    // The mapping is the WL6 branch of the original's wolfdigimap[]
    // (wl_main.cpp:927). SOD's branch differs — in particular, SOD
    // remaps digi 38 to GETGATLINGSND as a "Got Gat replacement", but
    // in WL6 digi 38 is ERLAUBENSND (Fat Face sighting voice line).
    // Verified entry-by-entry 2026-04-20: every row here matches
    // InitDigiMap's table for WL6; missing enum entries resolve to -1
    // too (SD_PlaySound then falls back to AdLib).
    private let digi_slot = int32[74] {
         3,   // open_door    (OPENDOORSND  -> digi 3)
         2,   // close_door   (CLOSEDOORSND -> digi 2)
         5,   // atk_pistol   (ATKPISTOLSND -> digi 5)
        -1,   // atk_knife    (no digi in Wolf3D)
         4,   // atk_mg       (ATKMACHINEGUNSND -> digi 4)
         6,   // atk_gat      (ATKGATLINGSND -> digi 6)
        -1,   // get_key      (no digi)
        -1,   // get_ammo     (no digi)
        -1,   // bonus1       (no digi)
        14,   // pain         (TAKEDAMAGESND -> digi 14)
        15,   // push_wall    (PUSHWALLSND  -> digi 15)
        -1,   // get_mg       (no digi)
        -1,   // get_gat      (WL6 has no digi for GETGATLINGSND — plays via
              //                AdLib only. SOD's wolfdigimap remaps digi 38 to
              //                GETGATLINGSND, but in WL6 digi 38 is ERLAUBENSND.)
        -1,   // hit_wall     (no digi)
        -1,   // no_action    (no digi)
        -1,   // no_way       (no digi)
        -1,   // bonus2       (no digi)
        -1,   // bonus3       (no digi)
        -1,   // bonus4       (no digi)
        -1,   // bonus1up     (no digi)
        -1,   // health1      (no digi)
        -1,   // health2      (no digi)
         0,   // halt         (HALTSND -> digi 0)
         7,   // schutzad     (SCHUTZADSND -> digi 7)
