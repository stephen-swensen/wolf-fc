// Wolf-FC sound effects — mapping of game events to AUDIOT chunk IDs, and
// the trigger helpers that queue an AdLib SFX or digitized PCM clip from
// the `audio_ctx` owned by `world`. Digi-pack clips are preferred when
// present (matches the original Sound Blaster mode); the AdLib chunk from
// AUDIOT is the fallback.
//
// Every sound the game triggers is indexed by `sfx.id.*` — each id is a
// row number into the `digi_slot` / `adlib_chunk` tables below.
//
// To add a new sound:
//   1. Append a constant to `module sfx.id` and bump `sfx.count`,
//   2. extend `digi_slot` and `adlib_chunk` with the right lookup row,
//   3. call `sfx.trigger(sfx.id.new_one, ac)` from the new site.

module sfx =
    import math from std::

    // Sound IDs — indexes into the sfx_digi_slot / sfx_adlib_chunk
    // tables in main.fc. Not Wolf3D AUDIOT enum values, and not digi-
    // pack slot numbers. The tables translate.
    module id =
        let open_door      = 0
        let close_door     = 1
        let atk_pistol     = 2
        let atk_knife      = 3
        let atk_mg         = 4
        let atk_gat        = 5
        let get_key        = 6
        let get_ammo       = 7
        let bonus1         = 8    // cross
        let pain           = 9
        let push_wall      = 10
        let get_mg         = 11
        let get_gat        = 12
        let hit_wall       = 13
        let no_action      = 14
        let no_way         = 15
        let bonus2         = 16   // chalice
        let bonus3         = 17   // bible
        let bonus4         = 18   // crown
        let bonus1up       = 19   // extra life
        let health1        = 20   // dog food / food
        let health2        = 21   // first aid
        let halt           = 22   // guard/officer alert ("Halt!")
        let schutzad       = 23   // SS alert ("Schutzstaffel!")
        let dog_bark       = 24   // dog alert
        let nazi_fire      = 25   // guard/officer fire
        let ss_fire        = 26   // SS rapid fire
        let dog_attack     = 27   // dog bite
        let dog_death      = 28
        let death_1        = 29   // guard death scream
        let death_2        = 30   // officer death scream
        let death_3        = 31   // SS death scream
        // The original's audio enum has a "hit enemy" entry, but it's
        // never played anywhere — kept as a table slot for completeness.
        let hit_enemy      = 32   // bullet impact on flesh — unused
        // Expanded guard death scream pool — the original picks one of
        // 8 at random for guard-class enemies. First three are
        // death_1..3.
        let death_4        = 33
        let death_5        = 34
        let death_6        = 35
        let death_7        = 36
        let death_8        = 37
        let death_9        = 38
        // Per-kind / per-boss vocals. Sighting = one-shot vocal
        // played once when enemy wakes. Death = played on death.
        let spion          = 39   // officer sighting
        let nein_sovass    = 40   // officer death
        let leben          = 41   // SS death ("Mein Leben!")
        let ahhhg          = 42   // mutant death
        let gutentag       = 43   // Hans sighting
        let mutti          = 44   // Hans death ("Mutti!")
        let kein           = 45   // Gretel sighting
        let mein           = 46   // Gretel death
        let eine           = 47   // Giftmacher sighting
        let donner         = 48   // Giftmacher death
        let erlauben       = 49   // Fat Face sighting
        let rose           = 50   // Fat Face death
        let schabbsha      = 51   // Schabbs sighting
        let meingott       = 52   // Schabbs death
        let tot_hund       = 53   // Fake Hitler sighting
        let hitlerha       = 54   // Fake Hitler death
        let die            = 55   // Mecha/Real Hitler sighting
        let scheist        = 56   // Mecha Hitler death
        let eva            = 57   // Real Hitler death
        // Intermission / elevator sounds
        let level_done     = 58   // elevator switch "ding"
        let end_bonus1     = 59   // per-tick counter during countup
        let end_bonus2     = 60   // counter stopped (non-100%)
        let percent100     = 61   // 100% ratio bonus
        let no_bonus       = 62   // 0% ratio
        // Boss-specific attack sounds. The original dispatches per
        // actor class; wolf-fc previously routed every non-SS boss
        // to nazi_fire, which sounded wrong for bosses.
        let boss_fire      = 63   // Hans, Mecha/Real Hitler gun
        let schabbs_throw  = 64   // Schabbs syringe (AdLib only)
        let flamethrower   = 65   // Fake Hitler (AdLib only)
        let missile_fire   = 66   // Gift / Fat rocket
        // Placeholders: mapping is filled so late-landing callers don't
        // revisit this table. No current trigger site — mech_step
        // waits on a separate Mecha Hitler stage and yeah waits on the
        // BJ-yell hook.
        let mech_step      = 67   // Mecha Hitler walk stomp
        let yeah           = 68   // BJ victory-jump exclamation
        // Menu UI sounds. AdLib-only — none have digi versions.
        let move_gun1      = 69   // menu cursor move
        let shoot          = 70   // menu item confirm
        let esc_pressed    = 71   // menu cancel / back
        let missile_hit    = 72   // rocket wall explosion
        let slurpie        = 73   // gibs pickup slurp
        let move_gun2      = 74   // menu commit / setting changed
        let player_death   = 75   // BJ's dying scream on lethal hit

    // Total number of sfx.id.* entries. The sfx_digi_slot / sfx_adlib_chunk
    // tables in main.fc are sized to this.
    private let count = 76

    // --- AUDIOT enum IDs the original triggered but wolf-fc still doesn't.
    //     Append a new `id.*` above when wiring one up. Tracked in TODO.md.
    //
    //   shoot_door       = 28  (keybind-menu confirm — NOT door hits)
    //
    // Other AUDIOT chunks (select-weapon, heartbeat, nazi-hit-player,
    // walk1/2, game-over, no-item, boss-active, goobs, etc.) exist as
    // data but were never called from the original — see the 2026-04-25
    // audit in TODO.md. Don't add them as fidelity items.

    // (The output sample rate is no longer a constant — it's detected from
    // the default output device at startup and lives on
    // `audio_ctx.sample_rate`; all driver chips are constructed at that
    // rate. The i32-mix + soft-clip finalizer lives in `sound.fc::mixer`.)

