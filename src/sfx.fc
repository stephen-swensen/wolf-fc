    // Per-sound priority — matches the original's per-sound priority
    // field. The AdLib driver skips a trigger when its priority is
    // strictly less than the currently-playing sound's; equal-or-higher
    // preempts. Two-tier scheme suffices for our needs:
    //   0 = ambient feedback (wall bumps, "do nothing"); these never
    //       drown out a deliberate event.
    //   1 = everything else (pickups, doors, weapons, alerts, deaths).
    // Same-priority preempt means rapid pickups (cross→cross,
    // cross→chalice) restart audibly. The "do nothing" hold-rhythm is
    // handled at the call site (see player.fc's use-key handler), not
    // here.
    private let priority = i32[76] {
        1,  // open_door
        1,  // close_door
        1,  // atk_pistol
        1,  // atk_knife
        1,  // atk_mg
        1,  // atk_gat
        1,  // get_key
        1,  // get_ammo
        1,  // bonus1
        1,  // pain
        1,  // push_wall
        1,  // get_mg
        1,  // get_gat
        0,  // hit_wall      — ambient: don't override pickups/actions
        0,  // no_action     — ambient: held-space "do-do-do"
        1,  // no_way
        1,  // bonus2
        1,  // bonus3
        1,  // bonus4
        1,  // bonus1up
        1,  // health1
        1,  // health2
        1,  // halt
        1,  // schutzad
        1,  // dog_bark
        1,  // nazi_fire
        1,  // ss_fire
        1,  // dog_attack
        1,  // dog_death
        1,  // death_1
        1,  // death_2
        1,  // death_3
        1,  // hit_enemy
        1,  // death_4
        1,  // death_5
        1,  // death_6
        1,  // death_7
        1,  // death_8
        1,  // death_9
        1,  // spion
        1,  // nein_sovass
        1,  // leben
        1,  // ahhhg
        1,  // gutentag
        1,  // mutti
        1,  // kein
        1,  // mein
        1,  // eine
        1,  // donner
        1,  // erlauben
        1,  // rose
        1,  // schabbsha
        1,  // meingott
        1,  // tot_hund
        1,  // hitlerha
        1,  // die
        1,  // scheist
        1,  // eva
        1,  // level_done
        1,  // end_bonus1
        1,  // end_bonus2
        1,  // percent100
        1,  // no_bonus
        1,  // boss_fire
        1,  // schabbs_throw
        1,  // flamethrower
        1,  // missile_fire
        1,  // mech_step
        1,  // yeah
        1,  // move_gun1
        1,  // shoot
        1,  // esc_pressed
        1,  // missile_hit
        1,  // slurpie
        1,  // move_gun2
        1   // player_death
    }

    // Returns true if the AdLib SFX chip is currently playing a chunk.
    // Used by the "do nothing" hold-rhythm gate in the use-key
    // handler: holding space against a wall fires the cue on the
    // press edge, then re-fires each time the previous chunk
    // finishes — naturally paced "do-do-do" without restarting the
    // OPL2 envelope mid-attack. The chip itself lives on the audio
    // thread now, so read the flag the callback publishes (acquire)
    // rather than poking `sfx->active` across the boundary.
    let adlib_busy = (ac: audio_ctx*) ->
        atomic_load_acquire(&ac.adlib_busy_flag)

    // Play a sound by sfx.id.*. The Sound submenu has two independent
    // toggles relevant here: DIGITIZED SOUND (gates the digi PCM path)
    // and SOUND EFFECTS (gates the AdLib SFX fallback). When DIGITIZED
    // SOUND is on and a digi sample exists, it plays — that's the
    // richer "Sound Blaster" path. Otherwise, when SOUND EFFECTS is
    // on and an AdLib chunk exists, it plays. With both off, silent.
    //
    // `pan` is [-1, +1]; 0 = centered. `gain` is a linear multiplier
    // — 1.0 plays at the default-mix level, <1 attenuates, >1 pushes
    // into the mixer's soft-clip region. Only the digi path honours
    // pan/gain; the AdLib fallback routes through the OPL2 chip, which
    // has no cheap per-note attenuation knob (in practice enemy/pickup
    // sounds all have digi versions, so the fall-through is silent
    // for spatial callers when digi is on).
    // Producer side (any caller, main thread): post the play request onto the
    // audio command ring. The actual digi/adlib dispatch and chip/slot
    // mutation happen on the audio thread in `apply_trigger`, drained from
    // `ac->cmd_ring`. A full ring just drops the sound (never a stall). The
    // id is validated here so we never enqueue an out-of-range index.
    private let trigger_panned_gain = (sound_id: i32, ac: audio_ctx*,
                                pan: f64, gain: f64) ->
        if sound_id < 0 || sound_id >= count then return
        spsc.enqueue(ac.cmd_ring, audio_q.cmd {
            kind = audio_q.play_sfx, sfx_id = sound_id,
            pan = pan, gain = gain, player = none(imf.player*) })
        void()

    // Consumer side (audio thread only): perform the trigger the ring carried.
    // Digi pack is preferred when DIGITIZED SOUND is on and a sample exists;
    // otherwise the AdLib chunk plays when SOUND EFFECTS is on. Both toggles
    // are written by the main thread, so read them with acquire ordering.
    // `sound_id` is already range-checked by the producer.
    let apply_trigger = (sound_id: i32, ac: audio_ctx*,
                         pan: f64, gain: f64) ->
        let digi_idx = digi_slot[sound_id]
        if digi_idx >= 0 && atomic_load_acquire(&ac.digi_on) then
            digi.play_with_gain(ac.digi, digi_idx, pan, gain)
            return
        // No digi (off, or no sample) — fall through to AdLib if the
        // SFX toggle is on and an AdLib chunk exists.
        if !atomic_load_acquire(&ac.sfx_on) then return
        let enum_val = adlib_chunk[sound_id]
        if enum_val >= 0 then
            let chunk = 87 + enum_val   // 87 = AdLib block base in AUDIOT
            if chunk >= 0 && chunk < ac.ad.num_chunks then
                let off = (i64) audio.chunk_offset(ac.ad, chunk)
                let len = audio.chunk_length(ac.ad, chunk)
                if len >= 23 then
                    adlib.play(ac.sfx, adlib.parse(ac.ad.raw, off),
                               priority[sound_id])

    private let trigger_panned = (sound_id: i32, ac: audio_ctx*, pan: f64) ->
        trigger_panned_gain(sound_id, ac, pan, 1.0)

    let trigger = (sound_id: i32, ac: audio_ctx*) ->
        trigger_panned_gain(sound_id, ac, 0.0, 1.0)

    // Center-pan trigger with an explicit gain multiplier. `gain > 1`
    // pushes a punchy cue (e.g. level-done) into the mixer's soft-
    // clip region; `gain < 1` attenuates a cue that's perceptually
    // too loud against the rest of the mix (doors). 1.0 = same as
    // `trigger`.
    let trigger_gain = (sound_id: i32, ac: audio_ctx*, gain: f64) ->
        trigger_panned_gain(sound_id, ac, 0.0, gain)

    // Spatial variant: pans a source in the stereo field AND attenuates
    // by distance, so a guard firing across the level is quiet and off
    // to the side while the same guard at point-blank is loud and
    // centered. Takes the player struct so we can look up pos + camera
    // plane.
    //
    // Pan mapping: project the source→player vector onto the player's
    // camera-plane axis (perpendicular to facing). That's exactly how
    // the raycaster decides horizontal screen-x for sprites, so a
    // source sitting right of the player on screen will pan right.
    //
    // Distance mapping: linear rolloff from full volume at the player's
    // tile to silent at ~16 tiles out. Roughly matches the original's
    // 15-step attenuation curve, which also silenced sources beyond
    // that radius. Sounds past the cutoff are dropped entirely so
    // distant enemies don't eat mix slots.
    let trigger_at = (sound_id: i32, ac: audio_ctx*, g: game*,
                       x: f64, y: f64) ->
        let dx = x - g.pos_x
        let dy = y - g.pos_y
        let dist_sq = dx * dx + dy * dy
        let dist = math.sqrt(dist_sq)
        let max_dist = 16.0
        let gain = if dist >= max_dist then 0.0
                   else (max_dist - dist) / max_dist
        if gain <= 0.0 then return
        // Very-close sounds (<1 tile) stay centered so stepping past an
        // enemy doesn't produce a hard stereo flip.
        if dist_sq < 1.0 then
            trigger_panned_gain(sound_id, ac, 0.0, gain)
        else
            // Camera-plane axis is g->plane; its sign tells us which side.
            let plen = math.sqrt(g.plane_x * g.plane_x + g.plane_y * g.plane_y)
            let pan_raw = if plen < 1e-4 then 0.0
                else (dx * g.plane_x + dy * g.plane_y) / (plen * dist)
            // Soften pan by distance so far-off sources don't ping-pong
            // across the soundstage; at 16 tiles pan settles to ~half
            // of raw.
            let pan_atten = 1.0 / (1.0 + dist / 8.0)
            let pan = pan_raw * (0.4 + 0.6 * pan_atten)
            trigger_panned_gain(sound_id, ac, pan, gain)
