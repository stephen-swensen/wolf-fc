let vg_t_endart2   = 144     // (unused) episode-2 ending text page
let vg_t_endart3   = 145     // (unused) episode-3 ending text page
let vg_t_endart4   = 146     // (unused) episode-4 ending text page
let vg_t_endart5   = 147     // (unused) episode-5 ending text page
let vg_t_endart6   = 148     // (unused) episode-6 ending text page

// Draw a decoded VGA-planar pic at (dst_x, dst_y) in the framebuffer.
// Pixels outside the fb are clipped. `pal` is the 256-entry ARGB palette.
// Palette index 255 is magenta but treated as opaque here — VGAGRAPH
// images don't use transparency (only sprites do). First call for a given
// chunk decodes + palette-applies into rc->pic_cache; subsequent calls are
// a plain ARGB memcpy.
let draw_vg_pic = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                   chunk: int32, dst_x: int32, dst_y: int32) ->
    if chunk < 0 || chunk >= (int32) rc->pic_cache.len then return
    if rc->pic_cache[chunk].len == 0 then
        let pic = vgagraph.load_pic(vg, chunk)
        defer free(pic)
        if pic.len == 0 then return
        let w = vgagraph.pic_width(vg, chunk)
        let h = vgagraph.pic_height(vg, chunk)
        if w <= 0 || h <= 0 then return
        let buf = alloc(uint32[w * h] {})!
        for i in 0..(w * h)
            buf[(int64) i] = pal[(int32) pic[(int64) i]]
        rc->pic_cache[chunk] = buf
    let buf = rc->pic_cache[chunk]
    let w = vgagraph.pic_width(vg, chunk)
    let h = vgagraph.pic_height(vg, chunk)
    for y in 0..h
        let dy = dst_y + y
        if dy < 0 || dy >= game_h then continue
        for x in 0..w
            let dx = dst_x + x
            if dx < 0 || dx >= game_w then continue
            rc->fb[(int64) dy * 320 + (int64) dx] = buf[(int64) y * (int64) w + (int64) x]

// "GET PSYCHED!" level-load overlay. Matches wolf4sdl PreloadGraphics:
// fill the 3D view area with VIEWCOLOR (palette 0x7f), draw GETPSYCHEDPIC
// centered horizontally at y = (view_h - pic_h) / 2, then paint a two-
// tone progress bar (colors 0x37 / 0x32 over a BLACK trough) across the
// bottom of the pic frame. Our progress animates 0→100% as the timer
// counts down, which is a tiny embellishment on top of wolf4sdl (which
// pins the bar at 100% the whole second).
let render_get_psyched_overlay = (rc: render_ctx*, vg: vgagraph.vgagraph_file*,
                                   pal: uint32[],
                                   timer_remaining: float64,
                                   timer_total: float64) ->
    // Blank the 3D viewport with the grey border color. Leave the status
    // bar (y >= view_h) untouched.
    let bg = pal[get_psyched_bg_index]
    for y in 0..view_h
        let base = y * game_w
        for x in 0..game_w
            rc->fb[base + x] = bg
    // Center the pic within the viewport. Use the VGAGRAPH-reported size
    // in case the pic is ever re-packed; wolf3d's is 224x48.
    let pw = vgagraph.pic_width(vg, vg_get_psyched)
    let ph = vgagraph.pic_height(vg, vg_get_psyched)
    let pic_w = if pw > 0 then pw else get_psyched_pic_w
    let pic_h = if ph > 0 then ph else get_psyched_pic_h
    let pic_x = (game_w - pic_w) / 2
    let pic_y = (view_h - pic_h) / 2
    draw_vg_pic(rc, vg, pal, vg_get_psyched, pic_x, pic_y)
    // Progress bar: wolf4sdl offsets it to (WindowX+5, WindowY+WindowH-3)
    // with width WindowW-10. We use the pic bounds as the window.
    let bar_x = pic_x + 5
    let bar_y = pic_y + pic_h - 3
    let bar_full_w = pic_w - 10
    let bg_col = pal[0x00]
    let bar_col = pal[0x37]
    let bar_hilight = pal[0x32]
    // Trough (always full-width black strip 2px tall).
    for by in 0..2
        let row = (bar_y + by) * game_w
        for bx in 0..bar_full_w
            rc->fb[row + bar_x + bx] = bg_col
    // Filled portion: 0 → 100% as timer_remaining goes from total → 0.
    let elapsed = timer_total - timer_remaining
    let frac = if timer_total <= 0.0 then 1.0 else elapsed / timer_total
    let fill_w_f = frac * (float64) bar_full_w
    let fill_w = if fill_w_f < 0.0 then 0
        else if fill_w_f > (float64) bar_full_w then bar_full_w
        else (int32) fill_w_f
    for by in 0..2
        let row = (bar_y + by) * game_w
        let col = if by == 0 then bar_hilight else bar_col
        // wolf4sdl draws the main bar full-width then the highlight one
        // pixel shorter. For simplicity we paint both at the same width.
        for bx in 0..fill_w
            rc->fb[row + bar_x + bx] = col

// One-time decode + nearest-neighbor scale of TITLEPIC into a 320×200 ARGB
// buffer. Returns a heap slice the caller must hold for the process
// lifetime.
let build_title_bg_cache = (vg: vgagraph.vgagraph_file*, pal: uint32[]) ->
    let buf = alloc(uint32[game_w * game_h] {})!
    let pic = vgagraph.load_pic(vg, vg_title)
    defer free(pic)
    if pic.len == 0 then return buf
    let w = vgagraph.pic_width(vg, vg_title)
    let h = vgagraph.pic_height(vg, vg_title)
    if w <= 0 || h <= 0 then return buf
    for py in 0..game_h
        let sy = (int64) py * (int64) h / (int64) game_h
        for px in 0..game_w
            let sx = (int64) px * (int64) w / (int64) game_w
            let pix = pic[sy * (int64) w + sx]
            buf[(int64) py * (int64) game_w + (int64) px] = pal[(int32) pix]
    buf

// Blit the cached title backdrop into the framebuffer.
let blit_title_bg = (rc: render_ctx*) ->
    if rc->title_bg.len == 0 then return
    for i in 0..(game_w * game_h)
        rc->fb[i] = rc->title_bg[i]

// ============================================================
// Wolf3D font rendering
// ============================================================
//
// The bitmap font in VGAGRAPH has this layout (after Huffman expand):
//   int16 height
//   int16 location[256]   — offset from struct start to each char's pixels
//   int8  width[256]      — pixel width per char (0 for unused glyphs)
//   ...pixel bytes (non-zero = ink, 0 = background)
//
// Characters are stored column-major within their glyph: a glyph of
// (width, height) is `width * height` bytes; pixel[col, row] lives at
// byte `col * height + row`... actually wolf4sdl walks it as
// `source[i*height + j]` so row varies faster than column when iterating
// column-first. We just read column-major: pix[col*height + row].

struct font_info =
    height: int32
    location: int32[256]
    width: int32[256]
    pixels: uint8[]       // original decoded font chunk, held for glyph reads

let load_font = (vg: vgagraph.vgagraph_file*, chunk: int32) ->
    // Wolf4sdl fonts are raw (not planar). The decompressed chunk is the
    // fontstruct followed by pixel data.
    let raw = vgagraph.decompress_chunk(vg, chunk)
    if raw.len < 4 then return alloc(font_info {
        height = 8,
        location = int32[256] {},
        width = int32[256] {},
        pixels = raw
    })!
    let h = (int32) bytes.u16(raw, 0i64)
    let mut loc = int32[256] {}
    let mut wdt = int32[256] {}
    for i in 0..256
        // location[] is 256 uint16 entries starting at offset 2.
        loc[i] = (int32) bytes.u16(raw, 2i64 + (int64) i * 2)
        // width[] is 256 uint8 entries starting after the location array
        // (offset 2 + 512 = 514).
        wdt[i] = (int32) raw[514i64 + (int64) i]
    alloc(font_info {
        height = h,
        location = loc,
        width = wdt,
        pixels = raw
    })!

let free_font = (f: font_info*) ->
    free(f->pixels)
    free(f)

// Draw one character from the VGAGRAPH font. Returns the advance width.
// Glyph pixels are row-major: byte at (col, row) = pixels[row * width + col].
let draw_font_char = (rc: render_ctx*, f: font_info*, x: int32, y: int32,
                       ch: int32, color: uint32) ->
    if ch < 0 || ch >= 256 then return 0
    let cw = f->width[ch]
    if cw <= 0 then return 0
    let ch_h = f->height
    let src_off = (int64) f->location[ch]
    for row in 0..ch_h
        for col in 0..cw
            let px = f->pixels[src_off + (int64) row * (int64) cw + (int64) col]
            if px != 0u8 then
                let dx = x + col
                let dy = y + row
                if dx >= 0 && dx < game_w && dy >= 0 && dy < game_h then
                    rc->fb[(int64) dy * 320 + (int64) dx] = color
    cw

let draw_font_text = (rc: render_ctx*, f: font_info*,
                      x: int32, y: int32, s: const str, color: uint32) ->
    let mut cx = x
    for i in 0..(int32) s.len
        let ch = (int32) s[(int64) i]
        let advance = draw_font_char(rc, f, cx, y, ch, color)
        cx = cx + advance

// Measure a string's rendered pixel width (for centering).
let font_text_width = (f: font_info*, s: const str) ->
    let mut w = 0
    for i in 0..(int32) s.len
        let ch = (int32) s[(int64) i]
        if ch >= 0 && ch < 256 then w = w + f->width[ch]
    w

let draw_font_centered = (rc: render_ctx*, f: font_info*,
                          y: int32, s: const str, color: uint32) ->
    let w = font_text_width(f, s)
    draw_font_text(rc, f, (game_w - w) / 2, y, s, color)

// Load an IMF music player from an AUDIOT chunk number.
let music_load = (ad: audio.audio_data*, chunk: int32) ->
    let off = (int64) audio.chunk_offset(ad, chunk)
    let len = (int64) audio.chunk_length(ad, chunk)
    imf.init_from_chunk(ad->raw, off, (int64) len, (float64) sample_rate)

// Pick the AUDIOT chunk number that should be playing for the current phase.
// Title and main menu use MENUSONG (WONDERIN). Intermission uses ENDLEVEL.
// Per-episode and final victory screens get URAHERO and VICMARCH. All other
// phases (gp_playing, gp_dying, gp_game_over) use the per-level song table.
let music_chunk_for_phase = (phase: game_phase, level_num: int32) ->
    let mus = match phase with
    | gp_title | gp_main_menu -> music_wonderin
    | gp_intermission         -> music_endlevel
    | gp_bj_victory           -> music_urahero   // same cue as the episode-end screen
    // Death-cam: keep the level track playing so the fizzle-out / taunt
    // card / fade-in all happen under the boss-level music (matches the
    // original — A_StartDeathCam doesn't switch tracks).
    | gp_death_cam            -> if level_num >= 0 && level_num < 60 then songs[level_num] else 0
    | gp_episode_end          -> music_urahero
    | gp_victory              -> music_vicmarch
    | _ -> if level_num >= 0 && level_num < 60 then songs[level_num] else 0
    261 + mus

// ============================================================
// HUD — simple status bar at screen bottom
// ============================================================

// 3x5 pixel bitmap font (packed into int32: 5 rows of 3 bits).
// Supports digits 0-9 and uppercase A-Z.
let char_glyph = (ch: int32) ->
    // Digits
    if ch == 48 then 7 | (5 << 3) | (5 << 6) | (5 << 9) | (7 << 12)       // 0
    else if ch == 49 then 2 | (6 << 3) | (2 << 6) | (2 << 9) | (7 << 12)  // 1
    else if ch == 50 then 7 | (1 << 3) | (7 << 6) | (4 << 9) | (7 << 12)  // 2
    else if ch == 51 then 7 | (1 << 3) | (7 << 6) | (1 << 9) | (7 << 12)  // 3
    else if ch == 52 then 5 | (5 << 3) | (7 << 6) | (1 << 9) | (1 << 12)  // 4
    else if ch == 53 then 7 | (4 << 3) | (7 << 6) | (1 << 9) | (7 << 12)  // 5
    else if ch == 54 then 7 | (4 << 3) | (7 << 6) | (5 << 9) | (7 << 12)  // 6
    else if ch == 55 then 7 | (1 << 3) | (1 << 6) | (1 << 9) | (1 << 12)  // 7
    else if ch == 56 then 7 | (5 << 3) | (7 << 6) | (5 << 9) | (7 << 12)  // 8
    else if ch == 57 then 7 | (5 << 3) | (7 << 6) | (1 << 9) | (7 << 12)  // 9
    // Letters
    else if ch == 65 then 2 | (5 << 3) | (7 << 6) | (5 << 9) | (5 << 12)  // A
    else if ch == 67 then 3 | (4 << 3) | (4 << 6) | (4 << 9) | (3 << 12)  // C
    else if ch == 68 then 6 | (5 << 3) | (5 << 6) | (5 << 9) | (6 << 12)  // D
    else if ch == 69 then 7 | (4 << 3) | (7 << 6) | (4 << 9) | (7 << 12)  // E
    else if ch == 70 then 7 | (4 << 3) | (6 << 6) | (4 << 9) | (4 << 12)  // F
    else if ch == 71 then 7 | (4 << 3) | (5 << 6) | (5 << 9) | (7 << 12)  // G
    else if ch == 72 then 5 | (5 << 3) | (7 << 6) | (5 << 9) | (5 << 12)  // H
    else if ch == 73 then 7 | (2 << 3) | (2 << 6) | (2 << 9) | (7 << 12)  // I
    else if ch == 75 then 5 | (6 << 3) | (4 << 6) | (6 << 9) | (5 << 12)  // K
    else if ch == 76 then 4 | (4 << 3) | (4 << 6) | (4 << 9) | (7 << 12)  // L
    else if ch == 77 then 5 | (7 << 3) | (7 << 6) | (5 << 9) | (5 << 12)  // M
    else if ch == 78 then 5 | (7 << 3) | (7 << 6) | (5 << 9) | (5 << 12)  // N
    else if ch == 79 then 7 | (5 << 3) | (5 << 6) | (5 << 9) | (7 << 12)  // O
    else if ch == 80 then 6 | (5 << 3) | (6 << 6) | (4 << 9) | (4 << 12)  // P
    else if ch == 82 then 6 | (5 << 3) | (6 << 6) | (5 << 9) | (5 << 12)  // R
    else if ch == 83 then 3 | (4 << 3) | (2 << 6) | (1 << 9) | (6 << 12)  // S
    else if ch == 84 then 7 | (2 << 3) | (2 << 6) | (2 << 9) | (2 << 12)  // T
    else if ch == 85 then 5 | (5 << 3) | (5 << 6) | (5 << 9) | (7 << 12)  // U
    else if ch == 86 then 5 | (5 << 3) | (5 << 6) | (2 << 9) | (2 << 12)  // V
    else if ch == 87 then 5 | (5 << 3) | (5 << 6) | (7 << 9) | (5 << 12)  // W
    else if ch == 89 then 5 | (5 << 3) | (2 << 6) | (2 << 9) | (2 << 12)  // Y
    else 0  // space or unknown

let digit_glyph = (d: int32) -> char_glyph(d + 48)

let draw_digit = (rc: render_ctx*, x: int32, y: int32, d: int32, color: uint32, scale: int32) ->
    let g = digit_glyph(d)
    for row in 0..5
        let bits = (g >> (row * 3)) & 7
        for col in 0..3
            if (bits >> (2 - col)) & 1 != 0 then
                for sy in 0..scale
                    for sx in 0..scale
                        let px = x + col * scale + sx
                        let py = y + row * scale + sy
                        if px >= 0 && px < game_w && py >= 0 && py < game_h then
                            rc->fb[(int64) py * 320 + (int64) px] = color

let draw_number = (rc: render_ctx*, x: int32, y: int32, num: int32, color: uint32, scale: int32) ->
    let mut n = num
    if n < 0 then n = 0
    let mut digits = int32[8] { 0, 0, 0, 0, 0, 0, 0, 0 }
    let mut count = 0
    if n == 0 then
        digits[0] = 0
        count = 1
    else
        loop
            if n == 0 then break
            if count >= 8 then break
            digits[count] = n % 10
            n = n / 10
            count = count + 1
    // Draw right-to-left (digits are stored reversed)
    for i in 0..count
        let dx = x - (i * (3 * scale + scale))
        draw_digit(rc, dx, y, digits[i], color, scale)

// Draw a string using the 3x5 bitmap font.
let draw_text = (rc: render_ctx*, x: int32, y: int32, s: const str, color: uint32, scale: int32) ->
    for ci in 0..(int32) s.len
        let ch = (int32) s[(int64) ci]
        let gl = char_glyph(ch)
        if gl != 0 then
            let cx = x + ci * (3 * scale + scale)
            for row in 0..5
                let bits = (gl >> (row * 3)) & 7
                for col in 0..3
                    if (bits >> (2 - col)) & 1 != 0 then
                        for sy in 0..scale
                            for sx in 0..scale
                                let px = cx + col * scale + sx
                                let py = y + row * scale + sy
                                if px >= 0 && px < game_w && py >= 0 && py < game_h then
                                    rc->fb[(int64) py * 320 + (int64) px] = color

// Draw a filled rectangle in the framebuffer.
let fill_rect = (rc: render_ctx*, x0: int32, y0: int32, x1: int32, y1: int32, color: uint32) ->
    for y in y0..y1
        for x in x0..x1
            if x >= 0 && x < game_w && y >= 0 && y < game_h then
                rc->fb[(int64) y * 320 + (int64) x] = color

// Draw a vertical separator line with 3D effect.
let draw_vsep = (rc: render_ctx*, x: int32, y0: int32, y1: int32) ->
    for y in y0..y1
        if x >= 0 && x < game_w && y >= 0 && y < game_h then
            rc->fb[(int64) y * 320 + (int64) x] = 0xFF383838u32
            if x + 1 < game_w then
                rc->fb[(int64) y * 320 + (int64) (x + 1)] = 0xFF909090u32

// Pick the BJ face chunk from health + animation frame. Wolf4sdl picks the
// expression row from `(100-health)/16` (clamped 0..7) and the A/B/C variant
// from `gamestate.faceframe` (0..2). Health=0 shows the final "mostly dead"
// row. `frame` is clamped to 0..2 by the caller.
let face_chunk_for = (health: int32, frame: int32) ->
    let mut h = health
    if h > 100 then h = 100
    if h < 0 then h = 0
    let idx = if h == 0 then 6 else (100 - h) / 16
    let clamped = if idx > 6 then 6 else idx
    let f = if frame < 0 then 0 else if frame > 2 then 2 else frame
    vg_face_base + clamped * 3 + f

// Face-animation byte roll. Uses its own pcg channel (see struct game) so HUD
// rendering doesn't perturb the enemy RNG stream that scripted tests rely on.
let face_rnd_byte = (g: game*) ->
    (int32) (random.pcg_random.next_uint32(&g->rng_face) & 0xFFu32)

// Wolf4sdl UpdateFace: accumulate `tics` into facecount; when it exceeds a
// random 0..255 threshold, roll a new faceframe. The roll is `US_RndT()>>6`
// (giving 0..3) with 3 mapped down to 1, so the distribution is 0=25% /
// 1=50% / 2=25% — the centre variant is most common, which gives the face a
// natural "look forward" bias with occasional glances. Our dt is fixed at
// 1/35s in tests; multiplying by 70 yields ~2 units per tick, matching the
// wolf4sdl 70Hz tics rate.
let update_face = (g: game*, dt: float64) ->
    g->face_count = g->face_count + dt * 70.0
    if g->face_count > (float64) face_rnd_byte(g) then
        let roll = face_rnd_byte(g) / 64       // 0..3
        let frame = if roll == 3 then 1 else roll
        g->face_frame = frame
        g->face_count = 0.0

// Draw a right-aligned decimal number using the VGAGRAPH number pics.
// `digits` is the cell count; shorter numbers get N_BLANKPIC padding on
// the left (matches wolf4sdl LatchNumber). `px`/`py` is the top-left of
// the LEFTMOST cell. Each cell is 8x16.
let draw_vg_number = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                      px: int32, py: int32, digits: int32, num: int32) ->
    let mut n = if num < 0 then 0 else num
    let mut out_digits = int32[16] {}
    let mut count = 0
    if n == 0 then
        out_digits[0] = 0
        count = 1
    else
        loop
            if n == 0 then break
            if count >= 16 then break
            out_digits[count] = n % 10
            n = n / 10
            count = count + 1
    // Draw right-to-left: rightmost digit at px + (digits-1)*8
    for slot in 0..digits
        let x = px + (digits - 1 - slot) * 8
        let chunk = if slot < count then vg_n_0 + out_digits[slot]
            else vg_n_blank
        draw_vg_pic(rc, vg, pal, chunk, x, py)

let render_hud = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[], g: game*) ->
    let bar_top = view_h                         // 160
    // Full Wolf3D status-bar graphic: all the cell outlines + labels are
    // pre-rendered into a single 320x40 image. We paint it, then stamp
    // digits / face / keys / weapon-icon over the empty cells.
    draw_vg_pic(rc, vg, pal, vg_statusbar, 0, bar_top)
    // Cell x-coords (in pixels) and widths (in 8-px "cells"), from
    // wolf4sdl LatchNumber calls:
    //   floor : x=16, 2 cells
    //   score : x=48, 6 cells
    //   lives : x=112, 1 cell
    //   health: x=168, 3 cells
    //   ammo  : x=216, 2 cells
    let num_y = bar_top + 16
    draw_vg_number(rc, vg, pal, 16, num_y, 2, g->level_num + 1)
    draw_vg_number(rc, vg, pal, 48, num_y, 6, g->score)
    draw_vg_number(rc, vg, pal, 112, num_y, 1, g->lives)
    draw_vg_number(rc, vg, pal, 168, num_y, 3, g->health)
    draw_vg_number(rc, vg, pal, 216, num_y, 2, g->ammo)
    // BJ face — chosen by health + the rolling A/B/C variant from
    // update_face. Dead / dying locks to the final row, A-variant only.
    // got_gatling_timer overrides everything while active, matching the
    // original's DrawFace check against SD_SoundPlaying(GETGATLINGSND).
    let face = if g->got_gatling_timer > 0.0 then vg_got_gatling
        else match g->phase with
        | gp_dying     -> vg_face_base + 6 * 3
        | _            -> face_chunk_for(g->health, g->face_frame)
    draw_vg_pic(rc, vg, pal, face, 136, bar_top + 4)
    // Weapon icon on the right.
    let weapon_chunk = match g->weapon with
    | 1 -> vg_pistol
    | 2 -> vg_mg
    | 3 -> vg_chain
    | _ -> vg_knife
    draw_vg_pic(rc, vg, pal, weapon_chunk, 256, bar_top + 8)
    // Key indicators — two slots on the right edge. Positions match the
    // original StatusDrawPic coords (30,4) and (30,20) → x=240.
    if g->has_gold_key then
        draw_vg_pic(rc, vg, pal, vg_gold_key, 240, bar_top + 4)
    if g->has_silver_key then
        draw_vg_pic(rc, vg, pal, vg_silver_key, 240, bar_top + 20)

// Upscale fb (320x200) to dbuf (640x400) with nearest-neighbor 2x.
// ============================================================
// Weapon overlay — VSWAP weapon sprite at bottom center
// ============================================================

// Weapon fire rates (seconds per shot cycle). Index by g->weapon. Derived
// from wolf4sdl's `attackinfo[4][14]` (wl_agent.cpp:56) with 6-tic frames
// at the 70Hz tic rate. Knife/pistol: 4 full frames = 24 tics ≈ 0.343s per
// swing/shot. MG: frames 2↔3 loop while held = 12 tics ≈ 0.171s/shot.
// Chaingun: fires on both frame 2 and 3 of the 2-frame loop = 6 tics ≈
// 0.086s/shot.
let fire_rate = float64[4] { 0.343, 0.343, 0.171, 0.086 }

// Per-weapon firing sound. Values are snd_atk_knife / snd_atk_pistol /
// snd_atk_mg / snd_atk_gat (the literals, since snd_* let-bindings can't
// appear in an array literal at file scope).
let weapon_fire_snd = int32[4] { 3, 2, 4, 5 }

// Base sprite index in VSWAP for each weapon's "ready" pose. The 4 attack
// frames follow sequentially (ready, atk1, atk2, atk3, atk4). Derived from
// wolf4sdl's wl_def.h player-attack-frames enum: SPR_KNIFEREADY=416, etc.
let weapon_sprite_base = int32[4] { 416, 421, 426, 431 }

let update_weapon = (w: world*, dt: float64) ->
    let g = w->g
    let ac = w->ac
    if g->fire_timer > 0.0 then
        g->fire_timer = g->fire_timer - dt
        // Advance animation frames across the fire_rate window (4 phases).
        if g->fire_timer <= 0.0 then
            g->weapon_frame = 0
            g->fire_timer = 0.0
            // Wolf3D auto-switches to the knife at the end of an attack if
            // ammo ran out (wl_agent.cpp T_Attack, the !ammo branch).
            if g->weapon > 0 && g->ammo == 0 then g->weapon = 0
        else
            let total = fire_rate[g->weapon]
            let progress = 1.0 - g->fire_timer / total
            g->weapon_frame = if progress < 0.25 then 1
                else if progress < 0.5 then 2
                else if progress < 0.75 then 3
                else 4
    if g->key_fire && g->fire_timer <= 0.0 then
        if g->weapon == 0 then
            // Knife — no ammo needed
            g->fire_timer = fire_rate[0]
            g->weapon_frame = 1
            trigger_sound(weapon_fire_snd[0], ac)
            fire_player_hitscan(w)
        else if g->ammo > 0 then
            g->ammo = g->ammo - 1
            g->fire_timer = fire_rate[g->weapon]
            g->weapon_frame = 1
            trigger_sound(weapon_fire_snd[g->weapon], ac)
            fire_player_hitscan(w)

// One simulation tick — runs all per-frame game-state updates in order.
// Used by both the interactive game loop and the headless test mode so
// they stay in sync. Add new per-frame systems here, not at each caller.
let tick = (w: world*, dt: float64) ->
    let g = w->g
    // Damage flash and respawn fade decay every frame regardless of phase.
    if g->damage_flash_timer > 0.0 then
        g->damage_flash_timer = g->damage_flash_timer - dt
        if g->damage_flash_timer < 0.0 then g->damage_flash_timer = 0.0
    if g->respawn_fade_timer > 0.0 then
        g->respawn_fade_timer = g->respawn_fade_timer - dt
        if g->respawn_fade_timer < 0.0 then g->respawn_fade_timer = 0.0
    // Same for the message-banner timer.
    if g->msg_timer > 0.0 then
        g->msg_timer = g->msg_timer - dt
        if g->msg_timer < 0.0 then g->msg_timer = 0.0
    // "Got Gatling!" face swap decays regardless of phase — the face cell
    // keeps refreshing even during frozen phases, and the original's
    // SD_SoundPlaying check is timer-based here.
    if g->got_gatling_timer > 0.0 then
        g->got_gatling_timer = g->got_gatling_timer - dt
        if g->got_gatling_timer < 0.0 then g->got_gatling_timer = 0.0
    // Outside gp_playing only phase_timer advances + the phase-transition
    // handler runs (so death collapse → restart, etc. can fire). Enemies,
    // doors, pickups, weapon, player: all frozen.
    match g->phase with
    | gp_playing ->
        // "GET PSYCHED!" load overlay: freeze everything while visible so
        // the player can't walk into a wall on the first frame after a
        // level transition. Processed before `next_level` so a player who
        // hits the elevator during the overlay (impossible, but defensive)
        // still sees the level-done flow resume cleanly once it finishes.
        if g->get_psyched_timer > 0.0 then
            g->get_psyched_timer = g->get_psyched_timer - dt
            if g->get_psyched_timer < 0.0 then g->get_psyched_timer = 0.0
        // Elevator-switch pre-intermission wait: freeze all gameplay for
        // `next_level_delay` seconds so LEVELDONESND plays out in the world
        // before the tally screen takes over. update_phase_transitions won't
        // enter the intermission phase until the delay has elapsed. We keep
        // gameplay frozen for the whole `next_level` window (even on the tick
        // where delay reaches 0) so the phase transition fires cleanly at end
        // of tick without one stray gameplay frame sneaking in.
        else if g->next_level then
            if g->next_level_delay > 0.0 then
                g->next_level_delay = g->next_level_delay - dt
                if g->next_level_delay < 0.0 then g->next_level_delay = 0.0
            // Even with the rest of gameplay frozen, dying actors keep
            // animating so anything mid-die when the elevator switch
            // fired finishes its death cascade before the tally screen.
            update_dying_enemies(w->lv, dt)
        else
            // Wolf4sdl PlayLoop resets madenoise at the top of each frame; we
            // follow suit so noise from one tick only wakes enemies on the same
            // tick. update_weapon raises it again when the player fires a gun,
            // and damage_enemy raises it on a knife hit.
            g->made_noise = false
            g->level_time = g->level_time + dt
            update_player(w->lv, g, dt, w->ac)
            update_doors(w->lv, g, dt, w->ac)
            update_pushwall(w->lv, dt)
            update_weapon(w, dt)
            update_enemies(w, dt)
            update_projectiles(w->lv, g, w->ac, dt)
            check_pickups(w->lv, g, w->ac)
            update_face(g, dt)
    | _ ->
        g->phase_timer = g->phase_timer + dt
        if g->phase == game_phase.gp_intermission then
            tick_intermission(g, w->ac, dt)
        else if g->phase == game_phase.gp_bj_victory then
            tick_bj_victory(w->lv, g, w->ac, dt)
            // Boss corpse + any other dying actors keep animating during
            // the BJ run so the player sees the death animation finish
            // (not just the first die frame freeze-framed under BJ).
            update_dying_enemies(w->lv, dt)
        else if g->phase == game_phase.gp_death_cam then
            // Pump the dying boss's animation frames before the phase
            // logic inspects e->state — dc_sub_pre_fade and
            // dc_sub_replay_hold both advance on the es_die → es_dead
            // transition, so the tick order matters.
            update_dying_enemies(w->lv, dt)
            tick_death_cam(w->lv, g, w->ac, dt)
    // Phase transitions (death collapse → restart / game-over). Main loop
    // layers music switching on top of this; test mode doesn't need music
    // so it can ignore the return value.
    let _changed = update_phase_transitions(w, w->ac->vs)

// Draw a t_compshape sprite as a HUD overlay, stretched to (dst_w, dst_h)
// at screen position (dst_x, dst_y). Transparent (unused) source pixels are
// skipped implicitly by the run-list format. Framebuffer writes are clipped
// to the 3D viewport (0..view_h) so the weapon never paints onto the HUD bar.
let draw_hud_sprite = (rc: render_ctx*, vs: vswap.vswap_file*, pal: uint32[],
                       page: int32, dst_x: int32, dst_y: int32,
                       dst_w: int32, dst_h: int32) ->
    let hdr = vswap.sprite_header_at(vs, page)
    if !hdr.valid then return   // sparse page
    let base = hdr.base
    for sc in hdr.left_pix..(hdr.right_pix + 1)
        let sx0 = dst_x + sc * dst_w / 64
        let sx1 = dst_x + (sc + 1) * dst_w / 64
        if sx1 <= 0 || sx0 >= game_w then continue
        let data_off = (int64) hdr.col_offsets[sc]
        let mut off = base + data_off
        loop
            let endy_raw = (int32) bytes.u16(vs->raw, off)
            if endy_raw == 0 then break
            let newstart = (int64) (int16) bytes.u16(vs->raw, off + 2)
            let starty_raw = (int32) bytes.u16(vs->raw, off + 4)
            off = off + 6
            let row_start = starty_raw / 2
            let row_end = endy_raw / 2
            for row in row_start..row_end
                let pix = vs->raw[base + newstart + (int64) row]
                let color = pal[(int32) pix]
                let sy0 = dst_y + row * dst_h / 64
                let sy1 = dst_y + (row + 1) * dst_h / 64
                let y0 = if sy0 < 0 then 0 else sy0
                let y1 = if sy1 > view_h then view_h else sy1
                for sx in sx0..sx1
                    if sx < 0 || sx >= game_w then continue
                    for sy in y0..y1
                        rc->fb[(int64) sy * 320 + (int64) sx] = color

// Draw the currently-held weapon sprite centered at the bottom of the 3D
// viewport. Sprite page = sprite_start + weapon_sprite_base[weapon] + frame,
// where frame 0 is "ready" and 1..4 are the attack frames.
let render_weapon = (rc: render_ctx*, vs: vswap.vswap_file*, pal: uint32[], g: game*) ->
    let frame = g->weapon_frame
    let sprite_idx = weapon_sprite_base[g->weapon] + frame
    let page = vs->sprite_start + sprite_idx
    // Weapon bob during movement (subtle vertical offset).
    let bob = if g->key_up || g->key_down then
        (int32) (math.sin(g->pos_x * 8.0 + g->pos_y * 8.0) * 2.0)
    else 0
    // Scale the 64x64 source to fill the viewport height, centered.
    // Source transparency covers the upper rows so only the bottom portion
    // of the weapon is actually drawn.
    let dw = view_h
    let dh = view_h
    let dx = (game_w - dw) / 2
    let dy = view_h - dh + bob
    draw_hud_sprite(rc, vs, pal, page, dx, dy, dw, dh)

// Upscale fb (320x200) to dbuf (640x400) with nearest-neighbor 2x.
let upscale_2x = (rc: render_ctx*) ->
    for y in 0..game_h
        for x in 0..game_w
            let c = rc->fb[(int64) y * (int64) game_w + (int64) x]
            let dx = (int64) x * 2
            let dy = (int64) y * 2
            let sw = (int64) screen_w
            rc->dbuf[dy * sw + dx] = c
            rc->dbuf[dy * sw + dx + 1] = c
            rc->dbuf[(dy + 1) * sw + dx] = c
            rc->dbuf[(dy + 1) * sw + dx + 1] = c

// ============================================================
// Screenshots — saved as PNG with game-state metadata in a tEXt chunk.
// Interactive 's' key cycles through 100 slots under ~/.wolf-fc/screenshots/.
// Test mode writes to a caller-supplied path.
// ============================================================

let screenshot_max_slots = 100

// Overlay a color tint over the 3D viewport by blending each pixel toward
// `tint` at `alpha` (0..1). alpha=0 is a no-op; alpha=1 paints the tint
// solid. Used for damage red-flash and the dying collapse fade.
let viewport_tint = (rc: render_ctx*, tint: uint32, alpha: float64) ->
    if alpha <= 0.0 then return
    let a = if alpha >= 1.0 then 1.0 else alpha
    let inv = 1.0 - a
    let tr = (float64) ((tint >> 16) & 0xFFu32) * a
    let tg = (float64) ((tint >> 8) & 0xFFu32) * a
    let tb = (float64) (tint & 0xFFu32) * a
    for y in 0..view_h
        for x in 0..game_w
            let c = rc->fb[(int64) y * 320 + (int64) x]
            let r = (float64) ((c >> 16) & 0xFFu32) * inv + tr
            let g = (float64) ((c >> 8) & 0xFFu32) * inv + tg
            let b = (float64) (c & 0xFFu32) * inv + tb
            rc->fb[(int64) y * 320 + (int64) x] =
                0xFF000000u32 | ((uint32) r << 16) | ((uint32) g << 8) | (uint32) b

// Stippled red dissolve driven by a per-pixel spatial hash. For each pixel,
// a deterministic 16-bit hash h(x,y) is compared against a threshold derived
// from `progress` (0..1): pixels whose hash falls below the threshold are
// painted solid `tint`. Rising progress monotonically adds pixels; falling
// progress monotonically removes them. The hash uses Knuth-style
// multiplicative mixing — different constants produce visually similar
// results, so the choice here is just "something well-mixed and cheap."
let dissolve_stipple = (rc: render_ctx*, tint: uint32, progress: float64) ->
    if progress <= 0.0 then return
    let p = if progress >= 1.0 then 1.0 else progress
    let threshold = (uint32) (p * 65536.0)
    let color = 0xFF000000u32 | (tint & 0x00FFFFFFu32)
    for y in 0..view_h
        for x in 0..game_w
            let mut h = (uint32) x * 0x9E3779B1u32 + (uint32) y * 0xC2B2AE35u32
            h = (h ^ (h >> 13u32)) * 0x85EBCA6Bu32
            h = (h ^ (h >> 16u32)) & 0xFFFFu32
            if h < threshold then
                rc->fb[(int64) y * 320 + (int64) x] = color

// Draw a centered string in the 3D viewport using the 3x5 bitmap font,
// scaled up to `scale` px per bit. Used by the intermission / game-over
// overlays; normal in-game UI goes through render_hud.
let draw_centered_text = (rc: render_ctx*, y: int32, s: const str, color: uint32, scale: int32) ->
    let slen = (int32) s.len
    let tw = slen * (3 * scale + scale) - scale
    let x = (game_w - tw) / 2
    draw_text(rc, x, y, s, color, scale)

// Draw a single character from the LEVELEND_LUMP pic set. Returns the pixel
// advance after the glyph. Matches wolf4sdl's Write() dispatch: letters,
// digits, and '%' advance 16 px (the pics are drawn inside 16-wide cells);
// ':', '!', "'" advance 8 px; ' ' just advances 16.
let write_lpic_char = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                       x: int32, y: int32, ch: int32) ->
    // Uppercase lowercase letters in place.
    let mut c = ch
    if c >= 97 && c <= 122 then c = c - 32
    if c == 32 then
        16    // space — no draw, wide advance
    else if c == 58 then
        draw_vg_pic(rc, vg, pal, vg_l_colon, x, y)
        8
    else if c == 33 then
        draw_vg_pic(rc, vg, pal, vg_l_expoint, x, y)
        8
    else if c == 39 then
        draw_vg_pic(rc, vg, pal, vg_l_apostrophe, x, y)
        8
    else if c == 37 then
        draw_vg_pic(rc, vg, pal, vg_l_percent, x, y)
        16
    else if c >= 48 && c <= 57 then
        draw_vg_pic(rc, vg, pal, vg_l_num0 + (c - 48), x, y)
        16
    else if c >= 65 && c <= 90 then
        draw_vg_pic(rc, vg, pal, vg_l_a + (c - 65), x, y)
        16
    else
        16    // unsupported glyph; blank cell

// Draw a string using the LEVELEND_LUMP letter/digit pics, starting at
// pixel (x, y). `\n` resets x and advances y by 16 px (one row).
let write_lpic_text = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                       x: int32, y: int32, s: const str) ->
    let mut nx = x
    let mut ny = y
    for i in 0..(int32) s.len
        let ch = (int32) s[(int64) i]
        if ch == 10 then
            nx = x
            ny = ny + 16
        else
            nx = nx + write_lpic_char(rc, vg, pal, nx, ny, ch)

// Write a number using the big L_NUM pics. `align_right` = true right-aligns
// the last digit at pixel column `x`; false starts the first digit at x.
let write_lpic_number = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                         x: int32, y: int32, num: int32, align_right: bool) ->
    let mut n = if num < 0 then 0 else num
    let mut digits = int32[12] {}
    let mut count = 0
    if n == 0 then
        digits[0] = 0
        count = 1
    else
        loop
            if n == 0 then break
            if count >= 12 then break
            digits[count] = n % 10
            n = n / 10
            count = count + 1
    let start_x = if align_right then x - count * 16 else x
    for i in 0..count
        let d = digits[count - 1 - i]
        draw_vg_pic(rc, vg, pal, vg_l_num0 + d, start_x + i * 16, y)

// Fill the framebuffer with a single palette-indexed color. Used for the
// intermission background (VIEWCOLOR = 0x7f, a mid grey matching wolf3d).
let fb_fill_palette = (rc: render_ctx*, pal: uint32[], idx: int32) ->
    let color = pal[idx]
    for i in 0..(game_w * game_h)
        rc->fb[i] = color

// Classic Wolf3D intermission: faithful recreation of LevelCompleted().
// Background is a mid-grey fill (palette 0x7F VIEWCOLOR), BJ portrait on the
// left (breathing), "floor N completed" caption, bonus / time / par lines,
// and live kill / secret / treasure ratios animated via tick_intermission.
let render_intermission = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                           g: game*) ->
    // Viewport-only VIEWCOLOR fill — the HUD strip (y >= view_h) is painted
    // separately by render_hud at the end so the player sees their carried
    // stats (floor/score/lives/health/ammo/face/weapon) through the tally.
    // Mirrors wolf4sdl's "split screen mode with the status bar" intermission.
    let bg = pal[0x7F]
    for y in 0..view_h
        for x in 0..game_w
            rc->fb[(int64) y * (int64) game_w + (int64) x] = bg

    // BJ portrait — alternate L_GUYPIC / L_GUY2PIC every ~0.5s for a gentle
    // breathing effect. Positioned at cell (0, 2) = pixel (0, 16) per wolf4sdl.
    let breathe = ((int32) (g->inter_breathe_timer * 2.0)) % 2
    let guy_pic = if breathe == 0 then vg_l_guy else vg_l_guy2
    draw_vg_pic(rc, vg, pal, guy_pic, 0, 16)

    // Secret-floor layout: no floor number, no time / par / ratio tally.
    // Static "SECRET FLOOR / COMPLETED!" caption + flat "15000 BONUS!"
    // line, matching wolf4sdl LevelCompleted's !normal-floor branch.
    if is_secret_level(g->level_num) then
        write_lpic_text(rc, vg, pal, 14 * 8, 4 * 8, "SECRET FLOOR\n COMPLETED!")
        write_lpic_text(rc, vg, pal, 10 * 8, 16 * 8, "15000 BONUS!")
        return

    // Caption: "floor\ncompleted" drawn at cell (14, 2) per wolf4sdl.
    write_lpic_text(rc, vg, pal, 14 * 8, 2 * 8, "FLOOR\nCOMPLETED")
    // Level number left-aligned at cell (26, 2).
    let mapon = g->level_num % levels_per_episode + 1
    write_lpic_number(rc, vg, pal, 26 * 8, 2 * 8, mapon, false)

    // BONUS line at cell (14, 7). Label + right-aligned number at column 36.
    write_lpic_text(rc, vg, pal, 14 * 8, 7 * 8, "BONUS")
    write_lpic_number(rc, vg, pal, 36 * 8, 7 * 8, g->inter_bonus_shown, true)

    // TIME and PAR rows at cells (16, 10) and (16, 12). Numbers drawn as
    // 2-digit mm + colon + 2-digit ss starting at cell column 26.
    write_lpic_text(rc, vg, pal, 16 * 8, 10 * 8, "TIME")
    write_lpic_text(rc, vg, pal, 16 * 8, 12 * 8, " PAR")
    let mut sec_total = (int32) g->level_time
    if sec_total > 99 * 60 then sec_total = 99 * 60
    let mm = sec_total / 60
    let ss = sec_total % 60
    let mut tx = 26 * 8
    draw_vg_pic(rc, vg, pal, vg_l_num0 + mm / 10, tx, 10 * 8)
    tx = tx + 16
    draw_vg_pic(rc, vg, pal, vg_l_num0 + mm % 10, tx, 10 * 8)
    tx = tx + 16
    draw_vg_pic(rc, vg, pal, vg_l_colon, tx, 10 * 8)
    tx = tx + 8
    draw_vg_pic(rc, vg, pal, vg_l_num0 + ss / 10, tx, 10 * 8)
    tx = tx + 16
    draw_vg_pic(rc, vg, pal, vg_l_num0 + ss % 10, tx, 10 * 8)
    // Par row (unknown-par levels render "??:??" — wolf3d's boss & secret
    // levels, which for us is level_num % 10 == 8 or 9).
    let par = if g->level_num < 60 then par_times[g->level_num] else 0
    tx = 26 * 8
    if par <= 0 then
        write_lpic_text(rc, vg, pal, tx, 12 * 8, "??:??")
    else
        let pm = par / 60
        let ps = par % 60
        draw_vg_pic(rc, vg, pal, vg_l_num0 + pm / 10, tx, 12 * 8)
        tx = tx + 16
        draw_vg_pic(rc, vg, pal, vg_l_num0 + pm % 10, tx, 12 * 8)
        tx = tx + 16
        draw_vg_pic(rc, vg, pal, vg_l_colon, tx, 12 * 8)
        tx = tx + 8
        draw_vg_pic(rc, vg, pal, vg_l_num0 + ps / 10, tx, 12 * 8)
        tx = tx + 16
        draw_vg_pic(rc, vg, pal, vg_l_num0 + ps % 10, tx, 12 * 8)

    // RATIOS — labels left-aligned, numbers right-aligned at column 37.
    write_lpic_text(rc, vg, pal, 9 * 8, 14 * 8, "KILL RATIO    %")
    write_lpic_text(rc, vg, pal, 5 * 8, 16 * 8, "SECRET RATIO    %")
    write_lpic_text(rc, vg, pal, 1 * 8, 18 * 8, "TREASURE RATIO    %")
    // Stage gating: each ratio shows its current count-up value in its
    // active stage; earlier stages show their final value; later stages
    // show nothing yet.
    let kr_shown = if g->inter_stage > 1 then g->inter_target_kr
                   else if g->inter_stage == 1 then g->inter_counter
                   else -1
    let sr_shown = if g->inter_stage > 2 then g->inter_target_sr
                   else if g->inter_stage == 2 then g->inter_counter
                   else -1
    let tr_shown = if g->inter_stage > 3 then g->inter_target_tr
                   else if g->inter_stage == 3 then g->inter_counter
                   else -1
    let ratio_right = 37 * 8
    if kr_shown >= 0 then
        write_lpic_number(rc, vg, pal, ratio_right, 14 * 8, kr_shown, true)
    if sr_shown >= 0 then
        write_lpic_number(rc, vg, pal, ratio_right, 16 * 8, sr_shown, true)
    if tr_shown >= 0 then
        write_lpic_number(rc, vg, pal, ratio_right, 18 * 8, tr_shown, true)

    // HUD stays visible — score has already been incremented by the bonus
    // award in enter_intermission, so the ticker the player sees matches
    // the running score line at the bottom.
    render_hud(rc, vg, pal, g)

// Game-over screen: black background, big "GAME OVER", score, prompt.
let render_game_over = (rc: render_ctx*, g: game*) ->
    for i in 0..(game_w * game_h)
        rc->fb[i] = 0xFF000000u32
    let red = 0xFFD00000u32
    let white = 0xFFFFFFFFu32
    draw_centered_text(rc, 40, "GAME", red, 3)
    draw_centered_text(rc, 70, "OVER", red, 3)
    draw_text(rc, 80, 120, "FINAL SCORE", white, 1)
    draw_number(rc, 220, 120, g->score, white, 1)
    draw_centered_text(rc, 140, "PRESS ANY KEY", white, 1)

// Backdrop color behind the taunt card — palette index 0x7F (6-bit VGA
// (0, 16, 16) → 8-bit ARGB (0, 64, 64)). In the original this is
// `bordercol = VIEWCOLOR`, the dark teal that the status-bar frame also
// uses; dissolving to pure black looks too abrupt compared to the OG.
let dc_backdrop_color = 0xFF004040u32

// Render one frame of the gp_death_cam cutscene. Normal viewport during
// the pre-fade hold and the replay; a dissolve-to-backdrop during fade_out
// and fade_in (progress 0..1 from g->dc_fade); a solid backdrop with the
// taunt text during the taunt sub-phase.
let render_death_cam = (w: world*, vs: vswap.vswap_file*, pal: uint32[],
                        font: font_info*) ->
    let g = w->g
    let rc = w->rc
    let sub = g->dc_sub
    if sub == dc_sub_taunt then
        // Fully covered viewport (dc_fade is 1.0 here) with the taunt.
        // Text is left-aligned at x=68, y=45 and rendered in white — the
        // original calls US_Print with PrintX=68/PrintY=45/fontcolor=15.
        // HUD stays visible underneath.
        dissolve_stipple(rc, dc_backdrop_color, 1.0)
        let white = 0xFFFFFFFFu32
        draw_font_text(rc, font, 68, 45, "Let's see that again!", white)
    else
        render_walls(w->lv, rc, g, vs, pal)
        build_billboards(w->lv, rc, g, vs->sprite_start)
        render_billboards(rc, g, vs, pal)
        render_weapon(rc, vs, pal, g)
        // dc_fade is 0 during pre-fade and replay, so dissolve_stipple is
        // a no-op there (it early-returns on progress <= 0).
        dissolve_stipple(rc, dc_backdrop_color, g->dc_fade)

// Per-episode victory screen (gp_episode_end): shown after the intermission
// on level 8 (boss / finale) of each episode. Simple text screen — no
// ENDART, no BJ art for now. Space advances to the next episode.
let render_episode_end = (rc: render_ctx*, font: font_info*, g: game*) ->
    for i in 0..(game_w * game_h)
        rc->fb[i] = 0xFF000020u32    // deep blue backdrop
    let ep = g->level_num / levels_per_episode
    let yellow = 0xFFFFD700u32
    let white  = 0xFFFFFFFFu32
    let gray   = 0xFFB0B0B0u32
    draw_centered_text(rc, 20, "YOU WIN", yellow, 3)
    draw_font_centered(rc, font, 56, "EPISODE", white)
    let ep_label = match ep with
    | 0 -> "1"
    | 1 -> "2"
    | 2 -> "3"
    | 3 -> "4"
    | 4 -> "5"
    | _ -> "6"
    draw_font_centered(rc, font, 66, ep_label, yellow)
    draw_font_centered(rc, font, 84, episode_title(ep), yellow)
    // Score summary.
    draw_text(rc, 70, 120, "FINAL SCORE", white, 1)
    draw_number(rc, 220, 120, g->score, yellow, 1)
    // Prompt.
    draw_font_centered(rc, font, game_h - 32,
        if ep + 1 >= num_episodes then "PRESS ANY KEY TO CONTINUE" else "PRESS ANY KEY FOR NEXT EPISODE",
        gray)

// Final victory (gp_victory): shown after clearing all six episodes. Space
// returns to the main menu.
let render_final_victory = (rc: render_ctx*, font: font_info*, g: game*) ->
    for i in 0..(game_w * game_h)
        rc->fb[i] = 0xFF200000u32    // deep red
    let gold   = 0xFFFFD700u32
    let white  = 0xFFFFFFFFu32
    let gray   = 0xFFB0B0B0u32
    draw_centered_text(rc, 20, "YOU WON", gold, 3)
    draw_centered_text(rc, 54, "THE GAME", gold, 3)
    draw_font_centered(rc, font, 104, "BJ HAS ESCAPED THE CASTLE", white)
    draw_text(rc, 70, 124, "FINAL SCORE", white, 1)
    draw_number(rc, 220, 124, g->score, gold, 1)
    draw_font_centered(rc, font, game_h - 32, "PRESS ANY KEY", gray)

// ============================================================
// Title / Main menu / Pause
// ============================================================

// Variant of viewport_tint that covers the whole framebuffer (HUD + view).
let viewport_tint_full = (rc: render_ctx*, tint: uint32, alpha: float64) ->
    if alpha <= 0.0 then return
    let a = if alpha >= 1.0 then 1.0 else alpha
    let inv = 1.0 - a
    let tr = (float64) ((tint >> 16) & 0xFFu32) * a
    let tg = (float64) ((tint >> 8) & 0xFFu32) * a
    let tb = (float64) (tint & 0xFFu32) * a
    for y in 0..game_h
        for x in 0..game_w
            let c = rc->fb[(int64) y * 320 + (int64) x]
            let r = (float64) ((c >> 16) & 0xFFu32) * inv + tr
            let g = (float64) ((c >> 8) & 0xFFu32) * inv + tg
            let b = (float64) (c & 0xFFu32) * inv + tb
            rc->fb[(int64) y * 320 + (int64) x] =
                0xFF000000u32 | ((uint32) r << 16) | ((uint32) g << 8) | (uint32) b

// Title screen — full-screen TITLEPIC with a "PRESS ANY KEY" blink at bottom.
let render_title = (rc: render_ctx*, vg: vgagraph.vgagraph_file*, pal: uint32[],
                     font: font_info*, time: float64) ->
    blit_title_bg(rc)
    // Blink on/off every 0.6 seconds.
    let blink_on = ((int32) (time * 1.6667)) % 2 == 0
    if blink_on then
        draw_font_centered(rc, font, game_h - 22, "PRESS ANY KEY", 0xFFFFFF00u32)

// Menu labels are returned by functions instead of living in an array
// literal — FC treats `"foo"` as `const str` which doesn't fit into
// `str[N]` directly.
//
// Main menu:
//   0 RESUME GAME (only when has_active_game; locked otherwise)
//   1 NEW GAME
//   2 LOAD GAME
//   3 SAVE GAME   (only when has_active_game; locked otherwise)
//   4 SOUND       (toggles music_on)
//   5 QUIT
let main_menu_len = 6
let main_menu_label = (i: int32) ->
    match i with
    | 0 -> "RESUME"
    | 1 -> "NEW GAME"
    | 2 -> "LOAD GAME"
    | 3 -> "SAVE GAME"
    | 4 -> "SOUND"
    | 5 -> "QUIT"
    | _ -> ""

// Locked = visible but not selectable. Up/down navigation skips locked
// rows; pressing Enter on a locked row (which only happens via direct
// `setmenu_sel` paths from external test commands) is a no-op.
let main_menu_is_locked = (i: int32, has_active_game: bool) ->
    (i == 0 || i == 3) && !has_active_game

let diff_menu_label = (i: int32) ->
    match i with
    | 0 -> "CAN I PLAY, DADDY?"
    | 1 -> "DON'T HURT ME."
    | 2 -> "BRING 'EM ON!"
    | 3 -> "I AM DEATH INCARNATE!"
    | _ -> ""

// Episode picker labels — short for menu fit.
let episode_menu_label = (i: int32) ->
    match i with
    | 0 -> "EPISODE 1  ESCAPE FROM WOLFENSTEIN"
    | 1 -> "EPISODE 2  OPERATION EISENFAUST"
    | 2 -> "EPISODE 3  DIE, FUHRER, DIE!"
    | 3 -> "EPISODE 4  A DARK SECRET"
    | 4 -> "EPISODE 5  TRAIL OF THE MADMAN"
    | 5 -> "EPISODE 6  CONFRONTATION"
    | _ -> ""

// Map picker sub-submenu: 10 maps per episode plus a BOSS FIGHT shortcut
// that starts on map 9 and teleports the player next to the boss. Maps
// 9 and 10 get annotations to highlight the boss / secret routing.
let map_menu_len = 11
let map_menu_label = (i: int32) ->
    match i with
    | 0 -> "FLOOR 1"
    | 1 -> "FLOOR 2"
    | 2 -> "FLOOR 3"
    | 3 -> "FLOOR 4"
    | 4 -> "FLOOR 5"
    | 5 -> "FLOOR 6"
    | 6 -> "FLOOR 7"
    | 7 -> "FLOOR 8"
    | 8 -> "FLOOR 9  (BOSS)"
    | 9 -> "FLOOR 10  (SECRET)"
    | 10 -> "BOSS FIGHT"
    | _ -> ""

// Draw a list-style menu: centered title, one highlighted row per item,
// chevrons around the selected row. `label_fn` returns the text for item i.
// Used by the main / episode / difficulty submenus; save-load slots paint
// separately because their rows encode per-slot metadata.
let draw_list_menu = (rc: render_ctx*, font: font_info*, title: const str,
                      items_y: int32, n: int32, sel: int32,
                      label_fn: (int32) -> const str, locked_fn: (int32) -> bool) ->
    let yellow = 0xFFFFD700u32
    let white  = 0xFFFFFFFFu32
    let dull   = 0xFF707070u32
    draw_font_centered(rc, font, 24, title, yellow)
    for i in 0..n
        let y = items_y + i * (font->height + 4)
        let is_sel = sel == i
        let is_locked = locked_fn(i)
        let color = if is_locked then dull
                    else if is_sel then yellow else white
        let label = label_fn(i)
        draw_font_centered(rc, font, y, label, color)
        if is_sel then
            let w = font_text_width(font, label)
            let cx = (game_w - w) / 2
            draw_font_text(rc, font, cx - 14, y, ">", yellow)
            draw_font_text(rc, font, cx + w + 6, y, "<", yellow)


// Render the save or load slot menu. Each row shows "N <label>" or
// "N EMPTY". The save-picker highlights all slots (writable); the load-
// picker greys empty slots so they're visually unselectable.
let render_slot_menu = (rc: render_ctx*, sm: save_menu_ctx*, font: font_info*,
                        title: const str, sel: int32, load_mode: bool) ->
    let yellow = 0xFFFFD700u32
    let white  = 0xFFFFFFFFu32
    let dull   = 0xFF707070u32
    let gray   = 0xFFB0B0B0u32
    draw_font_centered(rc, font, 20, title, yellow)
    let items_y = 44
    for i in 0..num_save_slots
        let s = &sm->slots[i]
        let y = items_y + i * (font->height + 3)
        let is_sel = sel == i
        let is_locked = load_mode && s->empty
        let color = if is_locked then dull
                    else if is_sel then yellow else white
        let row_x = 40
        draw_font_text(rc, font, row_x, y, "%d{i + 1}", color)
        if s->empty then
            draw_font_text(rc, font, row_x + 18, y, "EMPTY", color)
        else
            // "LVL N  <label>  SCORE"
            let ep = s->level_num / levels_per_episode + 1
            let lvl = s->level_num % levels_per_episode + 1
            draw_font_text(rc, font, row_x + 18, y,
                "E%d{ep}M%d{lvl}", color)
            // Label (user-chosen). Fall back to a generic string if unset.
            if s->label.len > 0 then
                // Draw up to ~22 chars of label.
                let mut limit = (int32) s->label.len
                if limit > 22 then limit = 22
                // Copy to a tiny scratch buffer so we can treat it as const str.
                for j in 0..limit
                    sm->label_scratch[j] = s->label[j]
                sm->label_scratch[limit] = 0u8
                let slab = (const str) sm->label_scratch[0..(int64) limit]
                draw_font_text(rc, font, row_x + 60, y, slab, color)
            draw_font_text(rc, font, row_x + 180, y, "%d{s->score}", color)
        if is_sel then
            draw_font_text(rc, font, 20, y, ">", yellow)
            draw_font_text(rc, font, game_w - 28, y, "<", yellow)
    draw_font_centered(rc, font, game_h - 24,
        "UP/DOWN  ENTER  ESC", gray)

let render_main_menu = (rc: render_ctx*, sm: save_menu_ctx*,
                        vg: vgagraph.vgagraph_file*, pal: uint32[],
                        font: font_info*, g: game*) ->
    // Tint the title as a backdrop (slightly dimmed so the menu pops).
    blit_title_bg(rc)
    // Darken overlay so menu text stays readable over the title art.
    viewport_tint_full(rc, 0x00000000u32, 0.55)
    if g->menu_level == menu_main then
        draw_list_menu(rc, font, "MAIN MENU", 50, main_menu_len, g->menu_sel,
            (i: int32) ->
                // SOUND row gets an inline ON/OFF; RESUME and SAVE rows are
                // locked without an active game.
                if i == 4 then
                    if g->music_on then "SOUND:  ON" else "SOUND: OFF"
                else main_menu_label(i),
            (i: int32) -> main_menu_is_locked(i, g->has_active_game))
    else if g->menu_level == menu_episode then
        draw_list_menu(rc, font, "CHOOSE EPISODE", 44, num_episodes, g->menu_sel,
            (i: int32) -> episode_menu_label(i),
            (_: int32) -> false)
    else if g->menu_level == menu_map then
        draw_list_menu(rc, font, "CHOOSE FLOOR", 32, map_menu_len, g->menu_sel,
            (i: int32) -> map_menu_label(i),
            (_: int32) -> false)
    else if g->menu_level == menu_difficulty then
        draw_list_menu(rc, font, "CHOOSE DIFFICULTY", 56, 4, g->menu_sel,
            (i: int32) -> diff_menu_label(i),
            (_: int32) -> false)
    else if g->menu_level == menu_savelist then
        render_slot_menu(rc, sm, font, "SAVE GAME", g->menu_sel, false)
    else if g->menu_level == menu_loadlist then
        render_slot_menu(rc, sm, font, "LOAD GAME", g->menu_sel, true)

// Render the full game frame to fb (used before saving a screenshot).
let render_frame = (w: world*, vs: vswap.vswap_file*, pal: uint32[]) ->
    match w->g->phase with
    | gp_title ->
        render_title(w->rc, w->vg, pal, w->font, w->g->phase_timer)
        return
    | gp_main_menu ->
        render_main_menu(w->rc, w->sm, w->vg, pal, w->font, w->g)
        return
    | gp_intermission ->
        render_intermission(w->rc, w->vg, pal, w->g)
        return
    | gp_game_over ->
        render_game_over(w->rc, w->g)
        return
    | gp_episode_end ->
        render_episode_end(w->rc, w->font, w->g)
        return
    | gp_victory ->
        render_final_victory(w->rc, w->font, w->g)
        return
    | gp_death_cam ->
        render_death_cam(w, vs, pal, w->font)
        render_hud(w->rc, w->vg, pal, w->g)
        return
    | _ -> void()
    render_walls(w->lv, w->rc, w->g, vs, pal)
    build_billboards(w->lv, w->rc, w->g, vs->sprite_start)
    render_billboards(w->rc, w->g, vs, pal)
    render_weapon(w->rc, vs, pal, w->g)
    // Damage / death red overlays — applied over the 3D view, under the HUD.
    // Phase-filtered renderers above return early, so this block only runs
    // during gp_playing or gp_dying. Damage flash is a brief uniform alpha
    // blend; the longer death + respawn transitions use a spatial-hash
    // stipple so the scene fills / clears as speckled grains of red.
    let red_tint = 0x00C00000u32
    let flash_a = if w->g->damage_flash_timer > 0.0 then
        w->g->damage_flash_timer / damage_flash_time * 0.45
    else 0.0
    if flash_a > 0.0 then viewport_tint(w->rc, red_tint, flash_a)
    let stipple_progress = match w->g->phase with
    | gp_dying ->
        // Ramp 0 → 1 over death_fade_time, then hold at 1 until
        // death_anim_time elapses and the phase transition fires.
        let t = w->g->phase_timer / death_fade_time
        if t > 1.0 then 1.0 else t
    | _ ->
        // Quick uncover back to the new scene on respawn.
        if w->g->respawn_fade_timer > 0.0 then
            w->g->respawn_fade_timer / respawn_fade_time
        else 0.0
    dissolve_stipple(w->rc, red_tint, stipple_progress)
    render_hud(w->rc, w->vg, pal, w->g)
    render_message(w->rc, w->font, w->g)
    // "GET PSYCHED!" level-entry overlay. The original fills the 3D
    // viewport with VIEWCOLOR (palette 0x7f), draws the pic centered, and
    // paints a progress bar across the bottom of the pic frame. We
    // replicate the same layout and animate the bar 0→100% over the hold
    // duration so the static "always-full" look of wolf4sdl's simplified
    // port still reads as genuine progress. Drawn AFTER render_hud so the
    // status bar stays visible underneath, matching the original.
    if w->g->get_psyched_timer > 0.0 then
        render_get_psyched_overlay(w->rc, w->vg, pal,
            w->g->get_psyched_timer, get_psyched_time)
    // Pre-intermission fade-to-black: while `next_level` is latched and
    // gameplay is frozen, darken the entire frame linearly as next_level_delay
    // ticks down. Gives the player immediate visual feedback that the
    // elevator/boss activation registered, rather than a silent 1s hitch
    // followed by a sudden jump to the tally screen.
    if w->g->next_level && elevator_wait_time > 0.0 then
        let frac = 1.0 - w->g->next_level_delay / elevator_wait_time
        let alpha = if frac < 0.0 then 0.0 else if frac > 1.0 then 1.0 else frac
        viewport_tint_full(w->rc, 0x000000u32, alpha)

// Save the current fb as a PNG at `path` with game-state metadata embedded
// as a tEXt chunk (one field per line, grep-able).
let save_png = (w: world*, path: const str) ->
    let g = w->g
    let gk = if g->has_gold_key then 1 else 0
    let sk = if g->has_silver_key then 1 else 0
    let meta = alloc("level=%d{g->level_num + 1}\npos=(%7.3f{g->pos_x}, %7.3f{g->pos_y})\ndir=(%7.4f{g->dir_x}, %7.4f{g->dir_y})\nhealth=%d{g->health}\nammo=%d{g->ammo}\nscore=%d{g->score}\nlives=%d{g->lives}\nweapon=%d{g->weapon}\nkeys=gold:%d{gk},silver:%d{sk}")!
    defer free(meta)
    png.write(path, w->rc->fb, game_w, game_h, meta)

// Clear any screenshot files left over from a previous session so each run
// starts numbering from 000. Users who want to keep screenshots should copy
// them elsewhere before starting a new session.
let clear_screenshots = () ->
    match wolf_data_dir() with
    | none -> void()
    | some(dir) ->
        defer free(dir)
        let ss_dir = "%s{dir}/screenshots"
        io.mkdir(dir)
        io.mkdir(ss_dir)
        match io.list_dir(ss_dir) with
        | none -> void()
        | some(entries) ->
            let mut deleted = 0
            for name in entries
                if text.starts_with(name, "ss_") && text.ends_with(name, ".png") then
                    io.remove("%s{ss_dir}/%s{name}")
                    deleted = deleted + 1
                free(name)
            free(entries)
            if deleted > 0 then
                io.write("[screenshot] cleared %d{deleted} old file(s) from %s{ss_dir}\n", stdout)
                void()

// Take an interactive screenshot: renders, picks the next rotating slot in
// $WOLF_FC_HOME/screenshots (or ~/.wolf-fc/screenshots), writes a PNG, and
// prints the path to stdout.
let take_screenshot = (w: world*, vs: vswap.vswap_file*, pal: uint32[]) ->
    match wolf_data_dir() with
    | none ->
        io.write("[screenshot] HOME not set; skipping\n", stdout)
        void()
    | some(dir) ->
        defer free(dir)
        io.mkdir(dir)
        io.mkdir("%s{dir}/screenshots")
        let slot = w->rc->screenshot_slot
        w->rc->screenshot_slot = (w->rc->screenshot_slot + 1) % screenshot_max_slots
        let path = "%s{dir}/screenshots/ss_%03d{slot}.png"
        render_frame(w, vs, pal)
        save_png(w, path)
        io.write("[screenshot] saved %s{path}\n", stdout)
        void()

// ============================================================
// Save / load — one 10-slot save directory under ~/.wolf-fc/saves/.
//
// Format is a simple line-oriented text file: first token of each line
// names the section ("WLFC", "label", "game", "pos", "doors", "door",
// "pushwall", "sprites_alive", "enemies", "enemy"). Text is deliberate:
// it's debuggable, round-trips cleanly through printf/%f parsing, and
// avoids the platform-specific float64-to-bytes dance that a binary
// format would need.
// ============================================================

let save_version = 1

// Split a save-file line on spaces, compacting consecutive separators so
// the padded-width floats we write (e.g. "%14.6f") parse cleanly. Returns
// a heap `str[]` that the caller must free (along with each entry — this
// matches text.split's ownership). Used by every `else if text.starts_with
// (line, "tag ") then` branch in `load_game_from_slot`.
let split_ws = (s: const str) ->
    // Two-pass: count tokens, then allocate exact size.
    let mut count = 0
    let mut i = 0i64
    loop
        if i >= s.len then break
        if s[i] == 0x20u8 then
            i = i + 1
            continue
        count = count + 1
        loop
            if i >= s.len then break
            if s[i] == 0x20u8 then break
            i = i + 1
    let out = alloc(str[count] {})!
    let mut ti = 0
    let mut j = 0i64
    loop
        if j >= s.len then break
        if s[j] == 0x20u8 then
            j = j + 1
            continue
        let start = j
        loop
            if j >= s.len then break
            if s[j] == 0x20u8 then break
            j = j + 1
        let n = j - start
        // Copy into a heap slice so entries outlive any caller reuse.
        let buf = alloc(uint8[n] {})!
        for k in 0..n
            buf[k] = s[start + k]
        out[ti] = buf
        ti = ti + 1
    out

// Free the result of split_ws (both the outer array and each entry).
let free_split = (toks: str[]) ->
    for k in 0..(int32) toks.len
        free(toks[(int64) k])
    free(toks)

// Root directory for wolf-fc user data (saves, screenshots). Respects the
// WOLF_FC_HOME env override so test runs can point at a throwaway directory
// instead of scribbling on the real user's saves. Falls back to
// $HOME/.wolf-fc for normal use.
let wolf_data_dir = () ->
    match sys.env("WOLF_FC_HOME") with
    | some(override) -> some(alloc("%s{override}")!)
    | none ->
        match sys.home_dir() with
        | none -> default(str?)
        | some(home) -> some(alloc("%s{home}/.wolf-fc")!)

// Ensure $WOLF_FC_HOME/saves (or ~/.wolf-fc/saves) exists. Returns true if
// the directory is (now) available.
let ensure_save_dir = () ->
    match wolf_data_dir() with
    | none -> false
    | some(dir) ->
        defer free(dir)
        io.mkdir(dir)
        io.mkdir("%s{dir}/saves")
        true

let save_slot_path = (slot: int32) ->
    match wolf_data_dir() with
    | none -> default(str?)
    | some(dir) ->
        defer free(dir)
        let p = alloc("%s{dir}/saves/slot_%02d{slot}.sav")!
        some(p)

// Return the current wall-clock seconds (for save-label timestamps).
// Not currently used — reserved for future "DATE" field in the label.

// Write the running world state to a save-slot file. Overwrites any existing
// slot. Metadata label is auto-generated from the current level + time.
let save_game_to_slot = (w: world*, slot: int32) ->
    ensure_save_dir()
    match save_slot_path(slot) with
    | none ->
        io.write("save: HOME not set, skipping\n", stderr)
        void()
    | some(path) ->
        let g = w->g
        let lv = w->lv
        match io.open(path, "w") with
        | none ->
            io.write("save: failed to open %s{path}\n", stderr)
            void()
        | some(f) ->
            defer io.close(f)
            io.write("WLFC %d{save_version}\n", f)
            // Auto-generated label — encodes episode/level for the menu.
            let ep = g->level_num / levels_per_episode + 1
            let lvl = g->level_num % levels_per_episode + 1
            io.write("label E%d{ep}M%d{lvl}\n", f)
            io.write(
                "game %d{g->level_num} %d{g->difficulty} %d{g->lives} %d{g->score} %d{g->health} %d{g->ammo} %d{g->weapon} %d{g->best_weapon} %d{if g->has_gold_key then 1 else 0} %d{if g->has_silver_key then 1 else 0} %d{if g->went_secret then 1 else 0}\n", f)
            io.write(
                "counters %d{g->kills} %d{g->total_kills} %d{g->secrets} %d{g->total_secrets} %d{g->treasures} %d{g->total_treasures}\n", f)
            io.write("time %14.6f{g->level_time}\n", f)
            io.write("pos %14.6f{g->pos_x} %14.6f{g->pos_y}\n", f)
            io.write("dir %14.6f{g->dir_x} %14.6f{g->dir_y}\n", f)
            io.write("plane %14.6f{g->plane_x} %14.6f{g->plane_y}\n", f)
            io.write("area %d{g->area_number}\n", f)
            // Doors: count + one row per door.
            io.write("doors %d{lv->num_doors}\n", f)
            for i in 0..lv->num_doors
                let d = &lv->doors[i]
                let st = match d->state with
                | closed  -> 0
                | opening -> 1
                | open    -> 2
                | closing -> 3
                io.write(
                    "door %d{i} %d{d->tile_x} %d{d->tile_y} %d{st} %14.6f{d->open_timer} %14.6f{lv->door_pos[i]}\n", f)
            // Pushwall.
            let pw = &lv->pushwall
            let pw_active = if pw->active then 1 else 0
            io.write(
                "pushwall %d{pw_active} %d{pw->tile_x} %d{pw->tile_y} %d{pw->dir_x} %d{pw->dir_y} %14.6f{pw->progress} %d{(int32) pw->orig_tile}\n", f)
            // Sprite alive flags: compact hex bitmask, one char per 4 sprites.
            io.write("sprites %d{lv->num_sprites} ", f)
            let ns = lv->num_sprites
            let bytes_needed = (ns + 3) / 4
            for b in 0..bytes_needed
                let mut nibble = 0
                for bit in 0..4
                    let idx = b * 4 + bit
                    if idx < ns && lv->sprites[idx].alive then
                        nibble = nibble | (1 << bit)
                let ch = if nibble < 10 then 48 + nibble else 87 + nibble
                w->sm->hex_scratch[0] = (uint8) ch
                io.write(w->sm->hex_scratch[0..1], f)
            io.write("\n", f)
            // Enemies.
            io.write("enemies %d{lv->num_enemies}\n", f)
            for i in 0..lv->num_enemies
                let e = &lv->enemies[i]
                let ki = enemy_kind_to_int(e->kind)
                let si = enemy_state_to_int(e->state)
                let amb = if e->ambush then 1 else 0
                let nfd = if e->notified then 1 else 0
                let sh = if e->shoot_fired then 1 else 0
                io.write(
                    "enemy %d{i} %14.6f{e->x} %14.6f{e->y} %d{e->tile_x} %d{e->tile_y} %d{ki} %d{si} %d{e->dir} %d{e->hp} %d{e->anim_frame} %14.6f{e->anim_timer} %d{sh} %14.6f{e->move_remaining} %d{amb} %d{nfd} %14.6f{e->reaction_timer}\n", f)
            // PRNG state. Bits round-trip through signed int64 (same width as
            // uint64 under 2's complement); load reinterprets via (uint64).
            // Older saves lack this line and fall back to a fresh seed-0 stream
            // (reset at the top of load_game_from_slot).
            io.write(
                "rng %d{(int64) g->rng_enemy.state} %d{(int64) g->rng_enemy.inc} %d{(int64) g->rng_face.state} %d{(int64) g->rng_face.inc}\n", f)
            io.write("end\n", f)
            void()

// Numeric kind/state codes for serialization. Preserving ordering so older
// saves stay loadable if we add new variants at the end.
let enemy_kind_to_int = (k: enemy_kind) ->
    match k with
    | ek_guard        -> 0
    | ek_officer      -> 1
    | ek_ss           -> 2
    | ek_dog          -> 3
    | ek_mutant       -> 4
    | ek_hans         -> 5
    | ek_schabbs      -> 6
    | ek_gretel       -> 7
    | ek_giftmacher   -> 8
    | ek_fat          -> 9
    | ek_hitler_fake  -> 10
    | ek_hitler       -> 11
    | ek_blinky       -> 12
    | ek_pinky        -> 13
    | ek_clyde        -> 14
    | ek_inky         -> 15

let int_to_enemy_kind = (n: int32) ->
    match n with
    | 0  -> enemy_kind.ek_guard
    | 1  -> enemy_kind.ek_officer
    | 2  -> enemy_kind.ek_ss
    | 3  -> enemy_kind.ek_dog
    | 4  -> enemy_kind.ek_mutant
    | 5  -> enemy_kind.ek_hans
    | 6  -> enemy_kind.ek_schabbs
    | 7  -> enemy_kind.ek_gretel
    | 8  -> enemy_kind.ek_giftmacher
    | 9  -> enemy_kind.ek_fat
    | 10 -> enemy_kind.ek_hitler_fake
    | 11 -> enemy_kind.ek_hitler
    | 12 -> enemy_kind.ek_blinky
    | 13 -> enemy_kind.ek_pinky
    | 14 -> enemy_kind.ek_clyde
    | _  -> enemy_kind.ek_inky

let enemy_state_to_int = (s: enemy_state) ->
    match s with
    | es_stand -> 0
    | es_path  -> 1
    | es_chase -> 2
    | es_shoot -> 3
    | es_pain  -> 4
    | es_die   -> 5
    | es_dead  -> 6

let int_to_enemy_state = (n: int32) ->
    match n with
    | 0 -> enemy_state.es_stand
    | 1 -> enemy_state.es_path
    | 2 -> enemy_state.es_chase
    | 3 -> enemy_state.es_shoot
    | 4 -> enemy_state.es_pain
    | 5 -> enemy_state.es_die
    | _ -> enemy_state.es_dead

let int_to_door_state = (n: int32) ->
    match n with
    | 0 -> door_state.closed
    | 1 -> door_state.opening
    | 2 -> door_state.open
    | _ -> door_state.closing

// Load a saved slot file into the world. Returns true on success. On failure
// the world state is undefined (caller should treat a failed load as the
// equivalent of a save corrupt and return to the main menu).
//
// Approach: read the whole file into memory, split into lines, walk line by
// line applying each section. First we load the map for the saved level_num,
// then overlay door / pushwall / sprite / enemy state. The freshly-built
// level already has enemies spawned from plane-1, which we overwrite.
let load_game_from_slot = (w: world*, vs: vswap.vswap_file*, slot: int32) ->
    match save_slot_path(slot) with
    | none -> false
    | some(path) ->
        match io.read_all(path) with
        | none -> false
        | some(contents) ->
            defer free(contents)
            let lines = text.split(contents, "\n")
            defer free(lines)
            if lines.len < 2 then false
            else if !text.starts_with(lines[0], "WLFC ") then false
            else
                let g = w->g
                // Reset both PCG streams to a seed-0 baseline before walking
                // lines. A save written by this build will include an `rng`
                // line that overwrites the state; older saves lack that line
                // and keep this deterministic default. Either way, load is
                // now reproducible rather than inheriting whatever stream
                // position the live game had reached.
                g->rng_enemy = random.pcg_random.make_with_channel(0u64, rng_channel_enemy)
                g->rng_face  = random.pcg_random.make_with_channel(0u64, rng_channel_face)
                let mut level_loaded = false
                let mut i = 0
                loop
                    if i >= (int32) lines.len then break
                    let line = lines[(int64) i]
                    i = i + 1
                    if line.len == 0 then continue
                    if text.starts_with(line, "label ") then
                        void()   // menu-only; ignored at load time
                    else if text.starts_with(line, "game ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 12 then
                            g->level_num    = unwrap_int(toks[1])
                            g->difficulty   = unwrap_int(toks[2])
                            g->lives        = unwrap_int(toks[3])
                            g->score        = unwrap_int(toks[4])
                            g->health       = unwrap_int(toks[5])
                            g->ammo         = unwrap_int(toks[6])
                            g->weapon       = unwrap_int(toks[7])
                            g->best_weapon  = unwrap_int(toks[8])
                            g->has_gold_key   = unwrap_int(toks[9]) != 0
                            g->has_silver_key = unwrap_int(toks[10]) != 0
                            g->went_secret  = unwrap_int(toks[11]) != 0
                            // Reload the level for the saved level_num. This
                            // rebuilds lv->{tilemap,doors,pushwall,sprites,enemies}
                            // which we'll immediately overwrite with the saved
                            // state below.
                            reload_level_data(w, vs)
                            level_loaded = true
                    else if text.starts_with(line, "counters ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 7 then
                            g->kills           = unwrap_int(toks[1])
                            g->total_kills     = unwrap_int(toks[2])
                            g->secrets         = unwrap_int(toks[3])
                            g->total_secrets   = unwrap_int(toks[4])
                            g->treasures       = unwrap_int(toks[5])
                            g->total_treasures = unwrap_int(toks[6])
                    else if text.starts_with(line, "time ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 2 then g->level_time = unwrap_float(toks[1])
                    else if text.starts_with(line, "pos ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 3 then
                            g->pos_x = unwrap_float(toks[1])
                            g->pos_y = unwrap_float(toks[2])
                    else if text.starts_with(line, "dir ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 3 then
                            g->dir_x = unwrap_float(toks[1])
                            g->dir_y = unwrap_float(toks[2])
                    else if text.starts_with(line, "plane ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 3 then
                            g->plane_x = unwrap_float(toks[1])
                            g->plane_y = unwrap_float(toks[2])
                    else if text.starts_with(line, "area ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 2 then g->area_number = unwrap_int(toks[1])
                    else if text.starts_with(line, "rng ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 5 then
                            g->rng_enemy.state = (uint64) unwrap_int64(toks[1])
                            g->rng_enemy.inc   = (uint64) unwrap_int64(toks[2])
                            g->rng_face.state  = (uint64) unwrap_int64(toks[3])
                            g->rng_face.inc    = (uint64) unwrap_int64(toks[4])
                    else if text.starts_with(line, "door ") then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 7 && level_loaded then
                            let di = unwrap_int(toks[1])
                            if di >= 0 && di < w->lv->num_doors then
                                let d = &w->lv->doors[di]
                                d->state = int_to_door_state(unwrap_int(toks[4]))
                                d->open_timer = unwrap_float(toks[5])
                                w->lv->door_pos[di] = unwrap_float(toks[6])
                    else if text.starts_with(line, "pushwall ") && level_loaded then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 8 then
                            let pw = &w->lv->pushwall
                            pw->active   = unwrap_int(toks[1]) != 0
                            pw->tile_x   = unwrap_int(toks[2])
                            pw->tile_y   = unwrap_int(toks[3])
                            pw->dir_x    = unwrap_int(toks[4])
                            pw->dir_y    = unwrap_int(toks[5])
                            pw->progress = unwrap_float(toks[6])
                            pw->orig_tile = (uint8) unwrap_int(toks[7])
                    else if text.starts_with(line, "sprites ") && level_loaded then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 3 then
                            let ns = unwrap_int(toks[1])
                            let bits = toks[2]
                            let bytes_needed = (ns + 3) / 4
                            for b in 0..bytes_needed
                                if (int64) b >= bits.len then break
                                let ch = (int32) bits[(int64) b]
                                let nibble = if ch >= 48 && ch <= 57 then ch - 48
                                             else if ch >= 97 && ch <= 102 then ch - 87
                                             else 0
                                for bit in 0..4
                                    let idx = b * 4 + bit
                                    if idx >= ns then break
                                    if idx < w->lv->num_sprites then
                                        w->lv->sprites[idx].alive = (nibble >> bit) & 1 != 0
                    else if text.starts_with(line, "enemies ") && level_loaded then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 2 then
                            w->lv->num_enemies = unwrap_int(toks[1])
                    else if text.starts_with(line, "enemy ") && level_loaded then
                        let toks = split_ws(line)
                        defer free_split(toks)
                        if toks.len >= 15 then
                            let ei = unwrap_int(toks[1])
                            if ei >= 0 && ei < w->lv->num_enemies then
                                let e = &w->lv->enemies[ei]
                                e->x              = unwrap_float(toks[2])
                                e->y              = unwrap_float(toks[3])
                                e->tile_x         = unwrap_int(toks[4])
                                e->tile_y         = unwrap_int(toks[5])
                                e->kind           = int_to_enemy_kind(unwrap_int(toks[6]))
                                e->state          = int_to_enemy_state(unwrap_int(toks[7]))
                                e->dir            = unwrap_int(toks[8])
                                e->hp             = unwrap_int(toks[9])
                                e->anim_frame     = unwrap_int(toks[10])
                                e->anim_timer     = unwrap_float(toks[11])
                                e->shoot_fired    = unwrap_int(toks[12]) != 0
                                e->move_remaining = unwrap_float(toks[13])
                                e->ambush         = unwrap_int(toks[14]) != 0
                                if toks.len >= 16 then
                                    e->notified = unwrap_int(toks[15]) != 0
                                if toks.len >= 17 then
                                    e->reaction_timer = unwrap_float(toks[16])
                                else
                                    e->reaction_timer = 0.0
                // Recompute area_by_player from the restored door states so
                // enemy AI sees the correct connectivity. connect_areas walks
                // the door list and re-floods from the player's anchor area.
                for a in 0..num_areas
                    w->lv->area_by_player[a] = false
                for aa in 0..(num_areas * num_areas)
                    w->lv->area_connect[aa] = 0u8
                // Sum open-door counts into area_connect (both directions).
                for di in 0..w->lv->num_doors
                    let d = &w->lv->doors[di]
                    match d->state with
                    | open ->
                        if d->area1 >= 0 && d->area2 >= 0 then
                            let i1 = d->area1 * num_areas + d->area2
                            let i2 = d->area2 * num_areas + d->area1
                            w->lv->area_connect[i1] = w->lv->area_connect[i1] + 1u8
                            w->lv->area_connect[i2] = w->lv->area_connect[i2] + 1u8
                    | _ -> void()
                connect_areas(w->lv, g->area_number)
                // Resume gameplay.
                g->phase = game_phase.gp_playing
                g->phase_timer = 0.0
                g->made_noise = false
                g->key_up = false
                g->key_down = false
                g->key_left = false
                g->key_right = false
                g->key_fire = false
                g->key_space = false
                // Leave key_space_handled at false: the user confirmed the
                // load by pressing space/enter in the menu, and if we mark it
                // handled here their *next* press on a door/elevator (after
                // the intervening KEYUP) would be silently eaten. Matches the
                // enter_intermission / enter_episode_end fix for the same
                // symptom.
                g->key_space_handled = false
                g->key_ack = false
                g->key_ack_handled = false
                g->damage_flash_timer = 0.0
                g->msg_timer = 0.0
                true

// Small parse helpers — saves bail gracefully if a field is unparseable by
// defaulting to 0 / 0.0. Paired with the "expect at least N tokens" guards
// in each section above, this keeps a malformed line from cascading.
let unwrap_int = (s: const str) ->
    match text.parse_int32(s) with
    | some(n) -> n
    | none    -> 0

let unwrap_int64 = (s: const str) ->
    match text.parse_int64(s) with
    | some(n) -> n
    | none    -> 0i64

let unwrap_float = (s: const str) ->
    match text.parse_float64(s) with
    | some(x) -> x
    | none    -> 0.0

// Rebuild the save-slots cache from disk. Called when entering the save/load
// menu. Reads only the header + label of each file (not the full body) by
// streaming line-by-line until we've seen the `game` line.
let refresh_save_slots = (sm: save_menu_ctx*) ->
    for i in 0..num_save_slots
        // Free any label from a previous refresh.
        let old_label = sm->slots[i].label
        if old_label.len > 0 then free(old_label)
        sm->slots[i] = save_slot_info {
            empty = true,
            label = default(uint8[]),
            level_num = 0, difficulty = 0, score = 0
        }
    for i in 0..num_save_slots
        match save_slot_path(i) with
        | none -> void()
        | some(path) ->
            if !io.exists(path) then void()
            else
                match io.read_all(path) with
                | none -> void()
                | some(contents) ->
                    defer free(contents)
                    let lines = text.split(contents, "\n")
                    defer free(lines)
                    let mut level_num = 0
                    let mut difficulty = 0
                    let mut score = 0
                    let mut label_src = default(const str?)
                    let mut valid = false
                    for li in 0..(int32) lines.len
                        let line = lines[(int64) li]
                        if text.starts_with(line, "label ") then
                            label_src = some(line[6..line.len])
                        else if text.starts_with(line, "game ") then
                            let toks = split_ws(line)
                            defer free_split(toks)
                            if toks.len >= 5 then
                                level_num = unwrap_int(toks[1])
                                difficulty = unwrap_int(toks[2])
                                score = unwrap_int(toks[4])
                                valid = true
                    if valid then
                        let lbl = match label_src with
                        | some(s) ->
                            let n = s.len
                            let buf = alloc(uint8[n] {})!
                            for k in 0..n
                                buf[k] = s[k]
                            buf
                        | none -> default(uint8[])
                        sm->slots[i] = save_slot_info {
                            empty = false, label = lbl,
                            level_num = level_num,
                            difficulty = difficulty, score = score
                        }

// In-game debug dump (D key): print everything we'd want to know to diagnose
// a "stuck" report — player pos / dir / phase / lives, and for every tile in
// the player's bbox, what's there (wall / door / sprite / enemy). Output goes
// to stderr so it doesn't interfere with stdout-based scripts.
let debug_dump_state = (w: world*) ->
    let g = w->g
    let lv = w->lv
    let phase_s = match g->phase with
    | gp_title        -> "title"
    | gp_main_menu    -> "menu"
    | gp_playing      -> "playing"
    | gp_dying        -> "dying"
    | gp_intermission -> "intermission"
    | gp_game_over    -> "gameover"
    | gp_bj_victory   -> "bj_victory"
    | gp_death_cam    -> "death_cam"
    | gp_episode_end  -> "episode_end"
    | gp_victory      -> "victory"
    io.write("\n=== DEBUG DUMP ===\n", stderr)
    io.write("phase=%s{phase_s} hp=%d{g->health} lives=%d{g->lives} level=%d{g->level_num}\n", stderr)
    io.write("pos=(%7.4f{g->pos_x}, %7.4f{g->pos_y}) dir=(%7.4f{g->dir_x}, %7.4f{g->dir_y})\n", stderr)
    io.write("area=%d{g->area_number} keys: gold=%d{if g->has_gold_key then 1 else 0} silver=%d{if g->has_silver_key then 1 else 0}\n", stderr)
    let xl = (int32) (g->pos_x - player_radius)
    let xr = (int32) (g->pos_x + player_radius)
    let yl = (int32) (g->pos_y - player_radius)
    let yh = (int32) (g->pos_y + player_radius)
    io.write("bbox tiles: x[%d{xl}..%d{xr}] y[%d{yl}..%d{yh}]\n", stderr)
    for tx in xl..(xr + 1)
        for ty in yl..(yh + 1)
            let ti = (int32) lv->tilemap[(int64) tx * 64 + (int64) ty]
            let door_kind = if ti >= 128 then
                match lv->doors[ti - 128].state with
                | closed  -> "DOOR:closed"
                | opening -> "DOOR:opening"
                | open    -> "DOOR:open"
                | closing -> "DOOR:closing"
            else ""
            let kind = if ti >= 1 && ti <= 63 then "WALL"
                else if ti >= 128 then door_kind
                else "open"
            io.write("  tile (%d{tx},%d{ty}) tilemap=%d{ti} -> %s{kind}\n", stderr)
    io.write("blocking sprites within 2 tiles:\n", stderr)
    for i in 0..lv->num_sprites
        let s = &lv->sprites[i]
        if !s->alive || !s->blocks then continue
        let dx = s->x - g->pos_x
        let dy = s->y - g->pos_y
        let d = math.sqrt(dx * dx + dy * dy)
        if d < 2.0 then
            io.write("  sprite[%d{i}] pos=(%6.3f{s->x},%6.3f{s->y}) page=%d{s->shape_page} d=%5.3f{d}\n", stderr)
    io.write("live enemies within 2 tiles:\n", stderr)
    for i in 0..lv->num_enemies
        let e = &lv->enemies[i]
        match e->state with
        | es_dead | es_die -> void()
        | _ ->
            let dx = e->x - g->pos_x
            let dy = e->y - g->pos_y
            let d = math.sqrt(dx * dx + dy * dy)
            if d < 2.0 then
                io.write("  enemy[%d{i}] pos=(%6.3f{e->x},%6.3f{e->y}) tile(%d{e->tile_x},%d{e->tile_y}) hp=%d{e->hp} d=%5.3f{d}\n", stderr)
    io.write("=== END ===\n\n", stderr)
    void()

// ============================================================
// Headless test mode — scripted commands for automated testing
// ============================================================

let run_test_cmd = (w: world*, arg: const str, pal: uint32[], dt: float64) ->
    let g = w->g
    let bad = (expected: const str) ->
        io.write("bad arg '%s{arg}': expected %s{expected}\n", stderr)
        void()
    if text.starts_with(arg, "fwd:") then
        match text.parse_int32(arg[4..arg.len]) with
        | some(n) ->
            g->key_up = true
            for j in 0..n
                tick(w, dt)
            g->key_up = false
        | none -> bad("integer tick count")
    else if text.starts_with(arg, "back:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            g->key_down = true
            for j in 0..n
                tick(w, dt)
            g->key_down = false
        | none -> bad("integer tick count")
    else if text.starts_with(arg, "turnr:") then
        match text.parse_int32(arg[6..arg.len]) with
        | some(deg) -> rotate_camera(g, 0.0 - (float64) deg * 3.14159265 / 180.0)
        | none -> bad("integer degrees")
    else if text.starts_with(arg, "turnl:") then
        match text.parse_int32(arg[6..arg.len]) with
        | some(deg) -> rotate_camera(g, (float64) deg * 3.14159265 / 180.0)
        | none -> bad("integer degrees")
    else if arg == "run" then
        g->key_shift = !g->key_shift
    else if text.starts_with(arg, "goto:") then
        let coords = text.split(arg[5..arg.len], ",")
        if coords.len >= 2 then
            match text.parse_int32(coords[0]) with
            | some(tx) ->
                match text.parse_int32(coords[1]) with
                | some(ty) ->
                    g->pos_x = (float64) tx + 0.5
                    g->pos_y = (float64) ty + 0.5
                | none -> bad("integer Y coordinate")
            | none -> bad("integer X coordinate")
        else bad("X,Y coordinate pair")
        free(coords)
        check_pickups(w->lv, g, w->ac)
        // Teleporting bypasses door traversal, so the player's area + the
        // door-connectivity flood would otherwise stay anchored to the spawn
        // area. Recompute both, equivalent to "treat the jump as if the
        // player legally walked here through every open door."
        update_player_area(w->lv, g)
        connect_areas(w->lv, g->area_number)
    else if text.starts_with(arg, "sethp:") then
        match text.parse_int32(arg[6..arg.len]) with
        | some(n) -> g->health = n
        | none -> bad("integer HP value")
    else if text.starts_with(arg, "setweapon:") then
        match text.parse_int32(arg[10..arg.len]) with
        | some(n) -> g->weapon = n
        | none -> bad("integer weapon index (0-3)")
    else if text.starts_with(arg, "setammo:") then
        match text.parse_int32(arg[8..arg.len]) with
        | some(n) -> g->ammo = n
        | none -> bad("integer ammo count")
    else if arg == "fire" then
        g->key_fire = true
        tick(w, dt)
        g->key_fire = false
    else if arg == "facetile" then
        let fx = (int32) (g->pos_x + g->dir_x)
        let fy = (int32) (g->pos_y + g->dir_y)
        let ft = if fx >= 0 && fx < map_size && fy >= 0 && fy < map_size then
            (int32) w->lv->tilemap[(int64) fx * 64 + (int64) fy]
        else -1
        let nl = if g->next_level then 1 else 0
        io.write("facing=(%d{fx},%d{fy}) tile=%d{ft} next_level=%d{nl}\n", stdout)
        void()
    else if arg == "givekeys" then
        g->has_gold_key = true
        g->has_silver_key = true
    else if arg == "mli" then
        // Direct-fire the M+L+I cheat effect. In interactive play this is
        // triggered by holding those three keys; test mode has no keyboard,
        // so scripted scenarios invoke the effect through this command.
        apply_mli_cheat(g)
    else if arg == "bat" then
        apply_bat_cheat(g)
    else if arg == "iddqd" then
        // Trigger the IDDQD god-mode toggle directly without having to
        // pipe the full I-D-D-Q-D sequence through the key event path.
        apply_iddqd_cheat(g)
    else if arg == "psyched" then
        // Force the GET PSYCHED overlay timer so a following ss: captures
        // the full-screen load graphic. Bypasses the normal test_mode gate
        // in trigger_get_psyched.
        g->get_psyched_timer = get_psyched_time
    else if arg == "gotgatling" then
        // Force the GOTGATLINGPIC face-cell swap so ss: can capture it.
        // Bypasses test_mode. The pic replaces the BJ face in render_hud
        // while the timer is active.
        g->got_gatling_timer = got_gatling_time
    else if arg == "space" then
        g->key_space = true
        g->key_space_handled = false
        tick(w, dt)
        g->key_space = false
        g->key_space_handled = false
    else if text.starts_with(arg, "wait:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            for j in 0..n
                tick(w, dt)
        | none -> bad("integer tick count")
    else if text.starts_with(arg, "ss:") then
        render_frame(w, w->ac->vs, pal)
        save_png(w, arg[3..arg.len])
        io.write("Saved %s{arg[3..arg.len]}\n", stdout)
        void()
    else if arg == "state" then
        io.write("pos=(%8.4f{g->pos_x}, %8.4f{g->pos_y}) dir=(%8.4f{g->dir_x}, %8.4f{g->dir_y})\n", stdout)
        io.write("health=%d{g->health} ammo=%d{g->ammo} score=%d{g->score} lives=%d{g->lives} level=%d{g->level_num} weapon=%d{g->weapon} best=%d{g->best_weapon}\n", stdout)
        let gk = if g->has_gold_key then 1 else 0
        let sk = if g->has_silver_key then 1 else 0
        let gm = if g->god_mode then 1 else 0
        io.write("keys: gold=%d{gk} silver=%d{sk} god=%d{gm}\n", stdout)
        void()
    else if arg == "counters" then
        // Kill / secret / treasure counters + level time / par / phase.
        let phase_s = match g->phase with
        | gp_title        -> "title"
        | gp_main_menu    -> "menu"
        | gp_playing      -> "playing"
        | gp_dying        -> "dying"
        | gp_intermission -> "intermission"
        | gp_game_over    -> "gameover"
        | gp_bj_victory   -> "bj_victory"
        | gp_death_cam    -> "death_cam"
        | gp_episode_end  -> "episode_end"
        | gp_victory      -> "victory"
        let par = if g->level_num < 60 then par_times[g->level_num] else 0
        io.write("phase=%s{phase_s} difficulty=%d{g->difficulty}\n", stdout)
        io.write("kills=%d{g->kills}/%d{g->total_kills} secrets=%d{g->secrets}/%d{g->total_secrets} treasures=%d{g->treasures}/%d{g->total_treasures}\n", stdout)
        io.write("time=%6.2f{g->level_time} par=%d{par}\n", stdout)
        void()
    else if text.starts_with(arg, "vgrender:") then
        // Render one VGAGRAPH pic to the framebuffer and take a screenshot.
        // Syntax: vgrender:CHUNK,OUTFILE.png — top-left aligned, unscaled.
        let rest = arg[9..arg.len]
        let parts = text.split(rest, ",")
        if parts.len >= 2 then
            match text.parse_int32(parts[0]) with
            | some(n) ->
                // Clear the fb black first so metadata is obvious.
                for i in 0..(game_w * game_h)
                    w->rc->fb[i] = 0xFF000000u32
                draw_vg_pic(w->rc, w->vg, pal, n, 0, 0)
                png.write(parts[1], w->rc->fb, game_w, game_h, "vg")
                io.write("Saved %s{parts[1]}\n", stdout)
                void()
            | none -> bad("integer chunk number")
        else bad("CHUNK,PATH.png")
        free(parts)
    else if text.starts_with(arg, "vgrenderfont:") then
        // Render the entire font ASCII range onto the fb and save. Useful
        // for verifying the font loader extracts correct glyphs.
        for i in 0..(game_w * game_h)
            w->rc->fb[i] = 0xFF000000u32
        let mut py = 8
        let mut px = 8
        for ch in 32..127
            let adv = draw_font_char(w->rc, w->font, px, py, ch, 0xFFFFFFFFu32)
            px = px + adv + 1
            if px > game_w - 16 then
                px = 8
                py = py + w->font->height + 2
        png.write(arg[13..arg.len], w->rc->fb, game_w, game_h, "font")
        io.write("Saved %s{arg[13..arg.len]}\n", stdout)
        void()
    else if text.starts_with(arg, "vginfo:") then
        // Dump the dimensions of one VGAGRAPH chunk (pic). Useful to verify
        // the decoder produces sane widths/heights after the Huffman expand.
        match text.parse_int32(arg[7..arg.len]) with
        | some(n) ->
            let pw = vgagraph.pic_width(w->vg, n)
            let ph = vgagraph.pic_height(w->vg, n)
            let off = if n < w->vg->num_chunks then w->vg->offsets[n] else -1i64
            io.write("vgchunk %d{n}: offset=%d{off} width=%d{pw} height=%d{ph}\n", stdout)
            void()
        | none -> bad("integer chunk number")
    else if arg == "vgtable" then
        // Dump the entire picture-dimensions table (STRUCTPIC / chunk 0).
        for i in 0..w->vg->num_pics
            let pw = w->vg->pic_dims[i].width
            let ph = w->vg->pic_dims[i].height
            if pw > 0 || ph > 0 then
                let ch = i + vgagraph.start_pics
                io.write("pic %d{ch}: %d{pw}x%d{ph}\n", stdout)
        void()
    else if arg == "level_stats" then
        // Dump total enemy/pushwall/treasure counts as counted by build_level.
        io.write("level_stats: enemies=%d{w->lv->total_enemies} pushwalls=%d{w->lv->total_pushwalls} treasures=%d{w->lv->total_treasures}\n", stdout)
        void()
    else if arg == "advance" then
        // Simulates the "press space" that dismisses an intermission /
        // game-over / episode-end / victory screen. Test-mode equivalent of
        // the interactive space-bar path, but collapses animation-skip +
        // advance into one step so scripted tests don't need two hops.
        if g->phase == game_phase.gp_intermission then
            if g->inter_stage < 4 then finish_intermission_anim(g)
            if g->level_num % levels_per_episode == 8 then
                enter_episode_end(g)
            else
                advance_next_level(w, w->ac->vs)
        else if g->phase == game_phase.gp_bj_victory then
            // BJ cutscene collapses straight to the episode-end screen.
            // Interactive mode auto-advances on its own after the final
            // hold, but tests skip to the end so scripted sequences don't
            // need to pad with wait:200.
            enter_episode_end(g)
        else if g->phase == game_phase.gp_death_cam then
            // Death-cam collapses to the intermission tally screen, same
            // as a natural dc_sub_done → enter_intermission transition.
            // Tests still need to `advance` once more to reach
            // gp_episode_end on boss maps.
            enter_intermission(g)
        else if g->phase == game_phase.gp_episode_end then
            advance_next_episode(w, w->ac->vs)
        else if g->phase == game_phase.gp_victory then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_main
            g->menu_sel = 1     // NEW GAME — game ended, RESUME is locked
            g->has_active_game = false
        else if g->phase == game_phase.gp_game_over then
            restart_full_game(w, w->ac->vs)
    else if text.starts_with(arg, "setdifficulty:") then
        // Set difficulty + fully rebuild the current level so spawn filtering
        // reflects it. Useful for testing tier gating (base/+36/+72 tiles).
        match text.parse_int32(arg[14..arg.len]) with
        | some(n) ->
            g->difficulty = if n < 0 then 0 else if n > 3 then 3 else n
            // Re-run spawn_enemies on the existing level. Since difficulty
            // only affects which plane-1 enemy tiles spawn, we can clear
            // lv->num_enemies and re-scan without rebuilding the tilemap.
            w->lv->num_enemies = 0
            spawn_enemies(w->lv, w->lv_data, g->difficulty, g->no_dogs)
            // Recount total_enemies so the counters tally correctly.
            let mut alive = 0
            for i in 0..w->lv->num_enemies
                match w->lv->enemies[i].state with
                | es_dead -> void()
                | _ -> alive = alive + 1
            w->lv->total_enemies = alive
            g->total_kills = alive
            g->kills = 0
        | none -> bad("integer difficulty 0-3")
    else if text.starts_with(arg, "setlevel:") then
        match text.parse_int32(arg[9..arg.len]) with
        | some(n) ->
            if n < 0 || n >= 60 then bad("level 0..59")
            else
                g->level_num = n
                reload_level_data(w, w->ac->vs)
                find_player_start(w->lv_data, g)
                reset_level_counters(g, w->lv)
                update_player_area(w->lv, g)
                connect_areas(w->lv, g->area_number)
                g->phase = game_phase.gp_playing
                g->phase_timer = 0.0
        | none -> bad("integer level")
    else if text.starts_with(arg, "setepisode:") then
        // Jump to the start of episode N (level = N*10), preserving
        // score/lives. Wrapper around setlevel.
        match text.parse_int32(arg[11..arg.len]) with
        | some(n) ->
            if n < 0 || n >= num_episodes then bad("episode 0..5")
            else
                g->level_num = n * levels_per_episode
                reload_level_data(w, w->ac->vs)
                find_player_start(w->lv_data, g)
                reset_level_counters(g, w->lv)
                update_player_area(w->lv, g)
                connect_areas(w->lv, g->area_number)
                g->phase = game_phase.gp_playing
                g->phase_timer = 0.0
        | none -> bad("integer episode 0..5")
    else if text.starts_with(arg, "save:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            if n < 0 || n >= num_save_slots then bad("slot 0..%d{num_save_slots - 1}")
            else
                save_game_to_slot(w, n)
                io.write("saved slot %d{n}\n", stdout)
                void()
        | none -> bad("integer slot")
    else if text.starts_with(arg, "load:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            if n < 0 || n >= num_save_slots then bad("slot 0..%d{num_save_slots - 1}")
            else
                let ok = load_game_from_slot(w, w->ac->vs, n)
                io.write("load slot %d{n}: %s{if ok then "ok" else "failed"}\n", stdout)
                void()
        | none -> bad("integer slot")
    else if arg == "listsaves" then
        // Dump the on-disk save slots (label + level + score).
        refresh_save_slots(w->sm)
        for i in 0..num_save_slots
            let s = &w->sm->slots[i]
            if s->empty then
                io.write("slot %d{i}: EMPTY\n", stdout)
                void()
            else
                let ep = s->level_num / levels_per_episode + 1
                let lvl = s->level_num % levels_per_episode + 1
                let lbl_chars = if s->label.len > 0 then s->label else default(uint8[])
                io.write("slot %d{i}: E%d{ep}M%d{lvl} diff=%d{s->difficulty} score=%d{s->score} label=", stdout)
                if lbl_chars.len > 0 then io.write(lbl_chars, stdout)
                io.write("\n", stdout)
                void()
        void()
    else if arg == "endepisode" then
        // Force the episode-end path: sets next_level on level 8 of the
        // current episode so the intermission → episode-end flow runs.
        g->next_level = true
    else if arg == "kill" then
        // Instant-kill the player (skips the pain sound, goes straight to
        // dying). Mostly used by the regression suite to exercise the
        // death → restart → game-over flow without waiting for the enemy
        // AI to roll a lethal hit.
        g->health = 0
        g->phase = game_phase.gp_dying
        g->phase_timer = 0.0
        trigger_sound(snd_death_1, w->ac)
    else if text.starts_with(arg, "killenemy:") then
        // Instant-kill enemy by index (matches enemylist's [N] order).
        // Routes through damage_enemy with an HP-clearing damage value so
        // score / kills / drops fire the same way a real bullet would.
        match text.parse_int32(arg[10..arg.len]) with
        | some(n) ->
            if n < 0 || n >= w->lv->num_enemies then bad("enemy index out of range")
            else
                let e = &w->lv->enemies[n]
                damage_enemy(w->lv, g, w->ac, e, n, e->hp + 1, w->ac->vs->sprite_start)
        | none -> bad("integer enemy index")
    else if text.starts_with(arg, "setphase:") then
        // Force a phase transition for test-mode screenshot coverage.
        let p = arg[9..arg.len]
        if p == "title" then g->phase = game_phase.gp_title
        else if p == "menu" then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_main
        else if p == "diffmenu" then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_difficulty
        else if p == "epmenu" then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_episode
        else if p == "mapmenu" then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_map
        else if p == "savemenu" then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_savelist
            refresh_save_slots(w->sm)
        else if p == "loadmenu" then
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_loadlist
            refresh_save_slots(w->sm)
        else if p == "playing" then g->phase = game_phase.gp_playing
        else bad("title/menu/epmenu/mapmenu/diffmenu/savemenu/loadmenu/playing")
    else if arg == "phase" then
        let phase_s = match g->phase with
        | gp_title        -> "title"
        | gp_main_menu    -> "menu"
        | gp_playing      -> "playing"
        | gp_dying        -> "dying"
        | gp_intermission -> "intermission"
        | gp_game_over    -> "gameover"
        | gp_bj_victory   -> "bj_victory"
        | gp_death_cam    -> "death_cam"
        | gp_episode_end  -> "episode_end"
        | gp_victory      -> "victory"
        io.write("phase=%s{phase_s} timer=%6.3f{g->phase_timer} lives=%d{g->lives}\n", stdout)
        void()
    else if arg == "music" then
        // Print the AUDIOT chunk that would be playing for the current phase.
        // Lets the regression suite verify menu / intermission / victory tracks
        // without needing an open audio device.
        let chunk = music_chunk_for_phase(g->phase, g->level_num)
        io.write("music chunk=%d{chunk} (audiot offset=%d{chunk - 261})\n", stdout)
        void()
    else if arg == "digi_slots" then
        // Dump the digi-mixer slot table. Verifies wolf4sdl-style dedup:
        // retriggers of a sound already playing should reuse the same
        // slot rather than fan out across all four mixer voices.
        let mut active = 0
        for i in 0..4
            let s = &w->ac->digi->slots[i]
            if s->playing then active = active + 1
            io.write("slot %d{i}: playing=%d{if s->playing then 1 else 0} sound=%d{s->sound_num}\n", stdout)
        io.write("active=%d{active}\n", stdout)
        void()
    else if arg == "probe" then
        // Diagnostic: why can't the player move from their current position?
        // Prints the bbox tiles, any wall/door blocking each, and every live
        // enemy within 2 tiles of the player with their distance and tile.
        let px = g->pos_x
        let py = g->pos_y
        let xl = (int32) (px - player_radius)
        let xr = (int32) (px + player_radius)
        let yl = (int32) (py - player_radius)
        let yh = (int32) (py + player_radius)
        io.write("probe pos=(%7.3f{px}, %7.3f{py}) bbox_tiles: x[%d{xl}..%d{xr}] y[%d{yl}..%d{yh}]\n", stdout)
        for tx in xl..(xr + 1)
            for ty in yl..(yh + 1)
                let ti = (int32) w->lv->tilemap[(int64) tx * 64 + (int64) ty]
                let dstate = if ti < 128 then "open"
                    else match w->lv->doors[ti - 128].state with
                    | closed  -> "DOOR:closed"
                    | opening -> "DOOR:opening"
                    | open    -> "DOOR:open"
                    | closing -> "DOOR:closing"
                let solid = if ti >= 1 && ti <= 63 then "WALL" else dstate
                io.write("  tile (%d{tx},%d{ty}) = %d{ti} (%s{solid})\n", stdout)
        for i in 0..w->lv->num_enemies
            let e = w->lv->enemies[i]
            match e.state with
            | es_dead | es_die -> void()
            | _ ->
                let dx = e.x - px
                let dy = e.y - py
                let d = math.sqrt(dx * dx + dy * dy)
                if d < 2.5 then
                    let ks = match e.kind with
                    | ek_guard   -> "guard"
                    | ek_officer -> "officer"
                    | ek_ss      -> "ss"
                    | ek_dog     -> "dog"
                    | ek_mutant  -> "mutant"
                    | ek_hans    -> "hans"
                    | ek_schabbs -> "schabbs"
                    | ek_gretel  -> "gretel"
                    | ek_giftmacher  -> "gift"
                    | ek_fat     -> "fat"
                    | ek_hitler_fake -> "hitler_fake"
                    | ek_hitler  -> "hitler"
                    | ek_blinky  -> "blinky"
                    | ek_pinky   -> "pinky"
                    | ek_clyde   -> "clyde"
                    | ek_inky    -> "inky"
                    io.write("  enemy[%d{i}] %s{ks} tile(%d{e.tile_x},%d{e.tile_y}) pos(%6.3f{e.x},%6.3f{e.y}) d=%5.3f{d}\n", stdout)
        for i in 0..w->lv->num_sprites
            let s = w->lv->sprites[i]
            if !s.alive then continue
            let dx = s.x - px
            let dy = s.y - py
            let d = math.sqrt(dx * dx + dy * dy)
            if d < 2.5 then
                let bs = if s.blocks then "BLOCKS" else "walk"
                io.write("  sprite[%d{i}] tile(%d{(int32) s.x},%d{(int32) s.y}) page=%d{s.shape_page} %s{bs} d=%5.3f{d}\n", stdout)
        void()
    else if arg == "arrows" then
        // Dump every ICON_ARROWS path-marker tile baked into the level. Lets a
        // test author find a tile to walk a patrolling enemy through to verify
        // that select_path_dir applies the override.
        for y in 0..map_size
            for x in 0..map_size
                let v = (int32) w->lv->path_arrows[(int64) x * 64 + (int64) y]
                if v != dir_nodir then
                    io.write("arrow (%d{x},%d{y}) dir=%d{v}\n", stdout)
        void()
    else if arg == "enemylist" then
        // Per-enemy dump: grid position, kind, state, dir. Handy to locate
        // a specific enemy for a scripted screenshot or attack test.
        for i in 0..w->lv->num_enemies
            let e = w->lv->enemies[i]
            let ks = match e.kind with
            | ek_guard   -> "guard"
            | ek_officer -> "officer"
            | ek_ss      -> "ss"
            | ek_dog     -> "dog"
            | ek_mutant  -> "mutant"
            | ek_hans    -> "hans"
            | ek_schabbs -> "schabbs"
            | ek_gretel  -> "gretel"
            | ek_giftmacher  -> "gift"
            | ek_fat     -> "fat"
            | ek_hitler_fake -> "hitler_fake"
            | ek_hitler  -> "hitler"
            | ek_blinky  -> "blinky"
            | ek_pinky   -> "pinky"
            | ek_clyde   -> "clyde"
            | ek_inky    -> "inky"
            let ss = match e.state with
            | es_stand -> "stand"
            | es_path  -> "path"
            | es_chase -> "chase"
            | es_shoot -> "shoot"
            | es_pain  -> "pain"
            | es_die   -> "die"
            | es_dead  -> "dead"
            let area = (int32) w->lv->tile_areas[(int64) e.tile_x * 64 + (int64) e.tile_y]
            io.write("[%d{i}] (%d{e.tile_x},%d{e.tile_y}) kind=%s{ks} state=%s{ss} dir=%d{e.dir} hp=%d{e.hp} area=%d{area}\n", stdout)
        void()
    else if arg == "exittiles" then
        // List every EXITTILE marker (plane-1 tile 99) on the current map.
        // Boss-level maps place exactly one of these behind the gold-key
        // door; stepping onto it triggers the BJ-victory cutscene.
        let mut count = 0
        for y in 0..map_size
            for x in 0..map_size
                if w->lv->exit_tiles[(int64) x * 64 + (int64) y] then
                    io.write("exit: %d{x},%d{y}\n", stdout)
                    count = count + 1
        io.write("exittiles: count=%d{count}\n", stdout)
        void()
    else if arg == "enemies" then
        // Summary: counts by kind and by state, for regression checks.
        // Buckets: 0=guard, 1=officer, 2=ss, 3=dog, 4=mutant, 5=boss, 6=ghost.
        let mut by_kind = int32[7] { 0, 0, 0, 0, 0, 0, 0 }
        let mut by_state = int32[7] { 0, 0, 0, 0, 0, 0, 0 }
        for i in 0..w->lv->num_enemies
            let e = w->lv->enemies[i]
            let ki = match e.kind with
            | ek_guard -> 0
            | ek_officer -> 1
            | ek_ss -> 2
            | ek_dog -> 3
            | ek_mutant -> 4
            | ek_hans | ek_schabbs | ek_gretel | ek_giftmacher | ek_fat
            | ek_hitler_fake | ek_hitler -> 5
            | ek_blinky | ek_pinky | ek_clyde | ek_inky -> 6
            by_kind[ki] = by_kind[ki] + 1
            let si = match e.state with
            | es_stand -> 0
            | es_path -> 1
            | es_chase -> 2
            | es_shoot -> 3
            | es_pain -> 4
            | es_die -> 5
            | es_dead -> 6
            by_state[si] = by_state[si] + 1
        io.write("enemies: total=%d{w->lv->num_enemies}\n", stdout)
        io.write("  kind: guard=%d{by_kind[0]} officer=%d{by_kind[1]} ss=%d{by_kind[2]} dog=%d{by_kind[3]} mutant=%d{by_kind[4]} boss=%d{by_kind[5]} ghost=%d{by_kind[6]}\n", stdout)
        io.write("  state: stand=%d{by_state[0]} path=%d{by_state[1]} chase=%d{by_state[2]} shoot=%d{by_state[3]} pain=%d{by_state[4]} die=%d{by_state[5]} dead=%d{by_state[6]}\n", stdout)
        void()
    else if arg == "projectiles" then
        // Dump all active (alive) enemy projectiles: kind, position, travel
        // angle in radians, animation frame. Used by the boss regression
        // tests to verify Schabbs / Giftmacher / fake-Hitler actually
        // spawn visible projectiles instead of hitscanning.
        let mut alive = 0
        for i in 0..max_projectiles
            let p = &w->lv->projectiles[i]
            if !p->alive then continue
            alive = alive + 1
            let ks = match p->kind with
            | pk_needle -> "needle"
            | pk_rocket -> "rocket"
            | pk_fire   -> "fire"
            | pk_boom   -> "boom"
            io.write("  proj[%d{i}] %s{ks} pos(%6.3f{p->x},%6.3f{p->y}) ang=%5.3f{p->angle} frame=%d{p->anim_frame}\n", stdout)
        io.write("projectiles: alive=%d{alive}\n", stdout)
        void()
    else
        io.write("Unknown test command: %s{arg}\n", stdout)
        void()

// ============================================================
// Entry point
// ============================================================

let main = (args: str[]) ->
    // CLI flags. Scan all args (so flags can appear before or after --test)
    // and set the relevant module-level switches before any level is built.
    //   --no-dogs             — skip spawning ek_dog actors
    //   --test                — enter scripted-command mode (no SDL)
    //   --level N             — skip the title screen and start at level N
    //                           (0..59). Handy for boss testing:
    //                           E1 Hans=8, E2 Schabbs=18, E3 Hitler=28,
    //                           E4 Giftmacher=38, E5 Gretel=48, E6 Fat=58.
    //   --difficulty N        — override difficulty (0 baby, 3 hard).
    //                           Combines with --level; also affects menu
    //                           default for NEW GAME if set alone.
    //   --near-boss           — after applying --level (or the default
    //                           level 0), teleport the player to an open
    //                           tile adjacent to the first boss enemy on
    //                           the map, facing the boss. No-op on maps
    //                           without a boss.
    //   --near-goldkey        — same idea, but teleport next to the first
    //                           gold-key pickup. Useful for HUD testing.
    //                           No-op on maps without one (E1L1).
    //   --near-silverkey      — teleport next to the first silver-key
    //                           pickup. First silver-key map is E2L3.
    let mut test_mode = false
    let mut start_level = -1
    let mut start_difficulty = -1
    let mut start_near_boss = false
    let mut start_near_goldkey = false
    let mut start_near_silverkey = false
    let mut arg_no_dogs = false
    for i in 1..(int32) args.len
        let a = args[(int64) i]
        if a == "--no-dogs" then arg_no_dogs = true
        if a == "--test" then test_mode = true
        if a == "--near-boss" then start_near_boss = true
        if a == "--near-goldkey" then start_near_goldkey = true
        if a == "--near-silverkey" then start_near_silverkey = true
        if text.starts_with(a, "--level=") then
            match text.parse_int32(a[8..a.len]) with
            | some(n) -> if n >= 0 && n < 60 then start_level = n
            | none    -> void()
        if text.starts_with(a, "--difficulty=") then
            match text.parse_int32(a[13..a.len]) with
            | some(n) -> if n >= 0 && n < 4 then start_difficulty = n
            | none    -> void()

    // PRNG seed: deterministic 0 in --test mode so scripted scenarios
    // reproduce bit-identically; wall-clock milliseconds otherwise. A single
    // seed fans out to two pcg_random channels (enemy AI, face animation)
    // when the game struct is initialised below.
    let rng_seed = if test_mode then 0u64 else (uint64) sys.time()

    // Load game data (no SDL needed)
    io.write("Loading palette...\n", stdout)
    let pal = palette.init()

    io.write("Loading VSWAP.WL6...\n", stdout)
    let vs = vswap.load("data/VSWAP.WL6")
    io.write("  chunks=%d{vs->num_chunks}, sprites@%d{vs->sprite_start}, sounds@%d{vs->sound_start}\n", stdout)

    io.write("Loading audio...\n", stdout)
    let ad = audio.load("data/AUDIOHED.WL6", "data/AUDIOT.WL6")
    io.write("  audio chunks=%d{ad->num_chunks}\n", stdout)

    io.write("Loading VGAGRAPH...\n", stdout)
    let vg = vgagraph.load("data/VGADICT.WL6", "data/VGAHEAD.WL6", "data/VGAGRAPH.WL6")
    io.write("  vga chunks=%d{vg->num_chunks}, pics=%d{vg->num_pics}\n", stdout)

    io.write("Loading level 0...\n", stdout)
    let mut lv_data = maps.load("data/MAPHEAD.WL6", "data/GAMEMAPS.WL6", 0)
    io.write("  map %d{lv_data->width}x%d{lv_data->height}\n", stdout)

    // Assemble the `world` — the handle that groups game state, level data,
    // renderer, and audio. Orchestrators take `world*`; narrower functions
    // still take just the sub-contexts they need.
    let g = alloc(game {
        pos_x = 1.5, pos_y = 1.5,
        dir_x = 1.0, dir_y = 0.0,
        plane_x = 0.0, plane_y = fov_factor,
        key_up = false, key_down = false,
        key_left = false, key_right = false,
        key_shift = false, key_alt = false,
        key_ctrl = false, key_space = false, key_space_handled = false,
        key_ack = false, key_ack_handled = false, key_fire = false,
        key_m_held = false, key_l_held = false, key_i_held = false,
        key_b_held = false, key_a_held = false, key_t_held = false,
        cheat_mli_latched = false, cheat_bat_latched = false,
        iddqd_progress = 0, god_mode = false,
        wall_hit_cooldown = 0.0,
        health = 100, ammo = 8, score = 0, lives = 3,
        level_num = 0,
        has_gold_key = false, has_silver_key = false,
        next_level = false, next_level_delay = 0.0,
        weapon = 1, best_weapon = 1, went_secret = false,
        fire_timer = 0.0, weapon_frame = 0,
        face_frame = 0, face_count = 0.0,
        area_number = -1, made_noise = false, player_running = false, want_near_boss = false,
        bj_x = 0.0, bj_y = 0.0,
        bj_tile_x = 0, bj_tile_y = 0,
        bj_dir = dir_nodir, bj_distance = 0.0, bj_run_tiles_left = 0,
        bj_anim_frame = 0, bj_anim_timer = 0.0,
        bj_phase = 0, bj_yelled = false,
        dc_sub = 0, dc_timer = 0.0, dc_boss_idx = -1,
        dc_kill_x = 0.0, dc_kill_y = 0.0, dc_fade = 0.0,
        phase = game_phase.gp_title, phase_timer = 0.0,
        damage_flash_timer = 0.0, respawn_fade_timer = 0.0,
        get_psyched_timer = 0.0, got_gatling_timer = 0.0,
        kills = 0, total_kills = 0,
        secrets = 0, total_secrets = 0,
        treasures = 0, total_treasures = 0,
        level_time = 0.0,
        inter_stage = 0, inter_counter = 0, inter_progress = 0.0,
        inter_bonus_shown = 0,
        inter_target_timeleft = 0, inter_target_kr = 0,
        inter_target_sr = 0, inter_target_tr = 0,
        inter_breathe_timer = 0.0,
        inter_pause_timer = 0.0,
        inter_end_sound_delay = 0.0,
        difficulty = gd_hard,
        no_dogs = arg_no_dogs,
        test_mode = test_mode,
        menu_sel = 0, menu_level = menu_main,
        music_on = true, want_quit = false,
        has_active_game = false,
        msg_buf = alloc(uint8[256] {})!,
        msg_len = 0, msg_timer = 0.0,
        rng_enemy = random.pcg_random.make_with_channel(rng_seed, rng_channel_enemy),
        rng_face = random.pcg_random.make_with_channel(rng_seed, rng_channel_face)
    })!
    find_player_start(lv_data, g)
    io.write("  player at (%4.1f{g->pos_x}, %4.1f{g->pos_y})\n", stdout)

    // Sound system (valid in all modes; in --test and --screenshot nothing
    // actually reaches the speakers because SDL audio isn't opened, but
    // trigger_sound / digi.fill work over this same ctx either way).
    let w = alloc(world {
        g = g,
        lv = build_level(lv_data, vs->sprite_start, g->difficulty, g->no_dogs),
        lv_data = lv_data,
        rc = build_render_ctx(vg, pal),
        ac = alloc(audio_ctx {
            vs = vs,
            ad = ad,
            sfx = adlib.init((float64) sample_rate),
            digi = digi.init(vs)
        })!,
        sm = build_save_menu_ctx(),
        vg = vg,
        font = load_font(vg, vg_font_small)
    })!
    // Initial per-level counters mirror what was tallied during build_level.
    g->total_kills = w->lv->total_enemies
    g->total_secrets = w->lv->total_pushwalls
    g->total_treasures = w->lv->total_treasures
    // Now that both player position and level areas exist, anchor the
    // player's area + the area_by_player set. wolf4sdl SpawnPlayer / InitAreas
    // do this on level load: only the player's starting area is initially
    // marked reachable, since all doors begin closed and area_connect is 0.
    update_player_area(w->lv, g)
    connect_areas(w->lv, g->area_number)

    // --difficulty N / --level N: skip the title sequence and jump the
    // player straight into the specified map. Also respected in --test
    // mode so scripts can start on any level without a `setlevel:` prefix.
    if start_difficulty >= 0 then
        g->difficulty = start_difficulty
        // Rebuild enemies with the new difficulty tier. reload_level_data
        // reads g->difficulty, so it's enough to just re-run it.
        reload_level_data(w, vs)
        find_player_start(w->lv_data, g)
        reset_level_counters(g, w->lv)
        update_player_area(w->lv, g)
        connect_areas(w->lv, g->area_number)
    if start_level >= 0 then
        g->level_num = start_level
        reload_level_data(w, vs)
        find_player_start(w->lv_data, g)
        reset_level_counters(g, w->lv)
        update_player_area(w->lv, g)
        connect_areas(w->lv, g->area_number)
        g->phase = game_phase.gp_playing
        g->has_active_game = true
        trigger_get_psyched(g)
    if start_near_boss then
        teleport_near_boss(w->lv, w->g)
        update_player_area(w->lv, g)
        connect_areas(w->lv, g->area_number)
    if start_near_goldkey then
        teleport_near_goldkey(w->lv, w->g)
        update_player_area(w->lv, g)
        connect_areas(w->lv, g->area_number)
    if start_near_silverkey then
        teleport_near_silverkey(w->lv, w->g)
        update_player_area(w->lv, g)
        connect_areas(w->lv, g->area_number)

    // Test mode: process scripted commands, no SDL needed. Skip the
    // title/menu entry flow — tests start directly in gp_playing so
    // existing regression scripts behave the same as before the UI
    // overhaul. Flags like --no-dogs may appear before or after --test; in
    // the command loop, we skip anything matching a known flag so it isn't
    // reported as "Unknown test command".
    let mut test_idx = -1
    for i in 1..(int32) args.len
        if test_idx < 0 && args[(int64) i] == "--test" then test_idx = i
    if test_mode then
        g->phase = game_phase.gp_playing
        g->has_active_game = true
        let test_dt = 1.0 / 35.0
        for ti in (test_idx + 1)..(int32) args.len
            if args[(int64) ti] == "--no-dogs" then continue
            run_test_cmd(w, args[(int64) ti], pal, test_dt)
        return 0

    // Initialize SDL2 (interactive mode only)
    sdl2.set_hint(c"SDL_WINDOWS_DPI_AWARENESS", c"system")
    sdl2.init(sdl2.init_video | sdl2.init_audio)

    // Window: resizable, maximized on start. F11 toggles fullscreen.
    let flags = sdl2.window_shown | sdl2.window_resizable | sdl2.window_allow_highdpi
    let win = sdl2.create_window(c"Wolf-FC",
        sdl2.pos_centered, sdl2.pos_centered, screen_w, actual_h, flags)
    sdl2.maximize_window(win)
    let mut fullscreen = false

    // Renderer with vsync.
    let ren = sdl2.create_renderer(win, -1, sdl2.renderer_vsync)
    sdl2.set_logical_size(ren, screen_w, actual_h)
    sdl2.show_cursor(0)

    // Nearest-neighbor scaling — must be set BEFORE creating the texture.
    sdl2.set_hint(c"SDL_RENDER_SCALE_QUALITY", c"nearest")

    // Streaming texture at 640x400.
    let tex = sdl2.create_texture(ren, sdl2.pixel_argb8888,
        sdl2.tex_streaming, screen_w, screen_h)

    // Set up audio device and start music. Output is stereo (2 channels
    // interleaved L,R,…) so enemy SFX can pan spatially via digi.
    let mut spec = sdl2.audio_spec {
        freq = sample_rate, format = sdl2.audio_s16sys,
        channels = 2u8, silence = 0u8, samples = 1024u16,
        padding = 0u16, size = 0u32, callback = (any*) 0, userdata = (any*) 0
    }
    let mut obtained = default(sdl2.audio_spec)
    let audio_dev = sdl2.open_audio((any*) 0, 0, &spec, &obtained, 0)
    // First-frame music = whatever fits the initial phase (gp_title →
    // WONDERIN). Phase-driven swap below keeps this in sync afterward.
    let mut current_music_chunk = music_chunk_for_phase(g->phase, g->level_num)
    let mut ms = if audio_dev > 0u32 && current_music_chunk < ad->num_chunks then
        sdl2.pause_audio(audio_dev, 0)
        some(music_load(ad, current_music_chunk))
    else default(imf.player*?)
    // 1024 stereo frames per audio batch. `mix_buf` is int32 so the three
    // source fills (music, AdLib SFX, digi PCM) can sum without the per-
    // stage clipping that would otherwise starve later stages of headroom.
    // `out_buf` receives the soft-clipped int16 samples that actually get
    // queued to SDL (2048 int16 = 4096 bytes).
    let mix_buf = alloc(int32[2048] {})!
    let out_buf = alloc(int16[2048] {})!
    let mut music_on = ms.is_some

    // Fresh screenshot directory each session — user copies any they want to keep.
    clear_screenshots()

    // Game loop
    let mut running = true
    let mut last_ticks = sdl2.get_ticks()
    let mut event = default(sdl2.sdl_event)

    loop
        if !running then break
        if g->want_quit then break

        // Delta time
        let now = sdl2.get_ticks()
        let mut dt = (float64) (now - last_ticks) / 1000.0
        last_ticks = now
        if dt > 0.1 then dt = 0.1    // clamp large spikes

        // Poll events
        loop
            if sdl2.poll_event(&event) == 0 then break
            let t = (int32) event.type
            if t == sdl2.quit_event then running = false
            if t == sdl2.keydown_event then
                let k = event.key.keysym.sym
                // OS key-autorepeat fires SDL_KEYDOWN every ~30 ms while a key
                // is held; `repeat != 0` flags the duplicates. We want repeats
                // for menu nav (hold ↓ to scroll save slots) but NOT for
                // gameplay keys — a ctrl held through the episode-end screen
                // would otherwise re-raise key_fire after advance_next_episode
                // clears it, so the gatling fires on the first frame of the
                // next level. Checked per-branch below.
                let is_key_repeat = event.key.repeat != 0u8
                // Fullscreen toggle — always works (even from menu / pause).
                // F11 is our own shortcut; Alt+Enter matches the original
                // SDL port. Either Alt modifier counts (KMOD_ALT = LALT |
                // RALT = 0x0300). Alt+Enter `continue`s past the phase
                // match so the menu doesn't also confirm on the same press.
                let is_alt_enter = k == sdl2.key_return
                    && (event.key.keysym.mod & 0x0300u16) != 0u16
                if (k == sdl2.key_f11 || is_alt_enter) && !is_key_repeat then
                    fullscreen = !fullscreen
                    if fullscreen then
                        let mut db = sdl2.rect { x = 0, y = 0, w = 0, h = 0 }
                        sdl2.get_display_bounds(0, &db)
                        sdl2.set_bordered(win, 0)
                        sdl2.set_window_position(win, db.x, db.y)
                        sdl2.set_window_size(win, db.w, db.h)
                    else
                        sdl2.set_bordered(win, 1)
                        sdl2.restore_window(win)
                        sdl2.maximize_window(win)
                    sdl2.set_logical_size(ren, screen_w, actual_h)
                    if is_alt_enter then continue
                // Per-phase dispatch for everything else.
                match g->phase with
                | gp_title ->
                    // Any key advances to the main menu. Default selection
                    // = NEW GAME (RESUME is locked from the title screen).
                    g->phase = game_phase.gp_main_menu
                    g->menu_level = menu_main
                    g->menu_sel = 1
                    g->phase_timer = 0.0
                | gp_main_menu ->
                    // Classic menu-cursor feedback: MOVEGUN1SND on up/down
                    // nav (mirrors the gun-cursor click in the original),
                    // SHOOTSND on confirm, ESCPRESSEDSND on cancel. Plays on
                    // every menu level — the dispatch below just mutates
                    // menu_sel / menu_level, so a single site up here covers
                    // all sub-menus without sprinkling calls per branch.
                    if k == sdl2.key_up || k == sdl2.key_down then
                        trigger_sound(snd_move_gun1, w->ac)
                    else if k == sdl2.key_return || k == sdl2.key_space then
                        trigger_sound(snd_shoot, w->ac)
                    else if k == sdl2.key_escape then
                        trigger_sound(snd_esc_pressed, w->ac)
                    if g->menu_level == menu_main then
                        // Up/down navigation skips locked rows so RESUME and
                        // SAVE without an active game don't get in the way.
                        if k == sdl2.key_up then
                            let mut s = g->menu_sel
                            for _ in 0..main_menu_len
                                s = (s + main_menu_len - 1) % main_menu_len
                                if !main_menu_is_locked(s, g->has_active_game) then break
                            g->menu_sel = s
                        else if k == sdl2.key_down then
                            let mut s = g->menu_sel
                            for _ in 0..main_menu_len
                                s = (s + 1) % main_menu_len
                                if !main_menu_is_locked(s, g->has_active_game) then break
                            g->menu_sel = s
                        else if k == sdl2.key_return || k == sdl2.key_space then
                            match g->menu_sel with
                            | 0 ->
                                // RESUME GAME — only reachable when active.
                                if g->has_active_game then
                                    g->phase = game_phase.gp_playing
                            | 1 ->
                                // NEW GAME → episode picker
                                g->menu_level = menu_episode
                                g->menu_sel = 0
                            | 2 ->
                                // LOAD GAME → load slot menu (reads slot cache)
                                refresh_save_slots(w->sm)
                                g->menu_level = menu_loadlist
                                g->menu_sel = 0
                            | 3 ->
                                // SAVE GAME (locked without an active game)
                                if g->has_active_game then
                                    refresh_save_slots(w->sm)
                                    g->menu_level = menu_savelist
                                    g->menu_sel = 0
                            | 4 ->
                                g->music_on = !g->music_on
                                music_on = g->music_on
                                if !music_on && audio_dev > 0u32 then
                                    sdl2.clear_audio(audio_dev)
                            | 5 ->
                                g->want_quit = true
                            | _ -> void()
                        else if k == sdl2.key_escape then
                            // Esc on the main menu = RESUME if a game is
                            // active; otherwise no-op (no game to return to).
                            if g->has_active_game then
                                g->phase = game_phase.gp_playing
                    else if g->menu_level == menu_episode then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + num_episodes - 1) % num_episodes
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % num_episodes
                        else if k == sdl2.key_return || k == sdl2.key_space then
                            // Remember chosen episode in level_num (as its
                            // starting map). Map picker will refine this.
                            g->level_num = g->menu_sel * levels_per_episode
                            g->menu_level = menu_map
                            g->menu_sel = 0    // default to MAP 1
                        else if k == sdl2.key_escape then
                            g->menu_level = menu_main
                            g->menu_sel = 1     // back to NEW GAME
                    else if g->menu_level == menu_map then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + map_menu_len - 1) % map_menu_len
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % map_menu_len
                        else if k == sdl2.key_return || k == sdl2.key_space then
                            // menu_sel 0..9 = map index within episode.
                            // menu_sel 10 = BOSS FIGHT shortcut: map 9 +
                            // near-boss teleport, consumed in start_new_
                            // game_here after the level loads.
                            let ep = g->level_num / levels_per_episode
                            let picked_map = if g->menu_sel == 10 then 8 else g->menu_sel
                            g->level_num = ep * levels_per_episode + picked_map
                            g->want_near_boss = g->menu_sel == 10
                            g->menu_level = menu_difficulty
                            g->menu_sel = g->difficulty
                        else if k == sdl2.key_escape then
                            g->menu_level = menu_episode
                            g->menu_sel = g->level_num / levels_per_episode
                    else if g->menu_level == menu_difficulty then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + 3) % 4
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % 4
                        else if k == sdl2.key_return || k == sdl2.key_space then
                            g->difficulty = g->menu_sel
                            // g->level_num already holds the full ep*10+map
                            // index from the map picker. g->want_near_boss
                            // is consumed inside start_new_game_here.
                            start_new_game_here(w, vs)
                            g->has_active_game = true
                        else if k == sdl2.key_escape then
                            // Preserve map / boss-fight picker selection:
                            // if the user had BOSS FIGHT selected (which
                            // sets want_near_boss and level_num = ep*10+8),
                            // land them back on row 10 so Escape-loops
                            // don't drop that choice.
                            g->menu_level = menu_map
                            g->menu_sel = if g->want_near_boss then 10
                                else g->level_num % levels_per_episode
                            g->want_near_boss = false
                    else if g->menu_level == menu_savelist then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + num_save_slots - 1) % num_save_slots
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % num_save_slots
                        else if k == sdl2.key_return || k == sdl2.key_space then
                            save_game_to_slot(w, g->menu_sel)
                            refresh_save_slots(w->sm)
                            // Return to main menu after save (back to the
                            // SAVE GAME row).
                            g->menu_level = menu_main
                            g->menu_sel = 3
                        else if k == sdl2.key_escape then
                            g->menu_level = menu_main
                            g->menu_sel = 3
                    else if g->menu_level == menu_loadlist then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + num_save_slots - 1) % num_save_slots
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % num_save_slots
                        else if k == sdl2.key_return || k == sdl2.key_space then
                            if !w->sm->slots[g->menu_sel].empty then
                                if load_game_from_slot(w, vs, g->menu_sel) then
                                    g->has_active_game = true
                        else if k == sdl2.key_escape then
                            g->menu_level = menu_main
                            g->menu_sel = 2     // back to LOAD GAME
                | _ ->
                    // gp_playing, gp_dying, gp_intermission, gp_game_over,
                    // gp_episode_end, gp_victory. Escape from gp_playing
                    // jumps to the main menu (which doubles as the pause UI
                    // — RESUME GAME is the default selection so any-key-Esc-
                    // any-key resumes immediately). Other phases consume keys
                    // for their own advance flow (handled separately below).
                    if k == sdl2.key_escape && g->phase == game_phase.gp_playing then
                        g->phase = game_phase.gp_main_menu
                        g->menu_level = menu_main
                        g->menu_sel = 0     // RESUME GAME row
                        // Clear held inputs so the player isn't sprinting
                        // when they un-pause. (Mirrors enter_intermission's
                        // input-clear convention.)
                        g->key_up = false
                        g->key_down = false
                        g->key_left = false
                        g->key_right = false
                        g->key_fire = false
                    else if !is_key_repeat then
                        if k == sdl2.key_up then g->key_up = true
                        if k == sdl2.key_down then g->key_down = true
                        if k == sdl2.key_left then g->key_left = true
                        if k == sdl2.key_right then g->key_right = true
                        if k == sdl2.key_lshift then g->key_shift = true
                        if k == sdl2.key_lalt then g->key_alt = true
                        if k == sdl2.key_space then g->key_space = true
                        if k == sdl2.key_lctrl then g->key_fire = true
                        if k == sdl2.key_1 then g->weapon = 0
                        if k == sdl2.key_2 then g->weapon = 1
                        if k == sdl2.key_3 then g->weapon = 2
                        if k == sdl2.key_4 then g->weapon = 3
                        // Cheat-chord held-flags. M/L/I/B/A/T have no other
                        // in-game action (M used to toggle music but that
                        // clashed with the MLI chord; use the main menu's
                        // SOUND entry to toggle music now).
                        if k == sdl2.key_m then g->key_m_held = true
                        if k == sdl2.key_l then g->key_l_held = true
                        if k == sdl2.key_i then g->key_i_held = true
                        if k == sdl2.key_b then g->key_b_held = true
                        if k == sdl2.key_a then g->key_a_held = true
                        if k == sdl2.key_t then g->key_t_held = true
                        // IDDQD sequence — only progresses while in-game,
                        // matching how the chord cheats are gated. Held
                        // keys can't auto-advance because we're already
                        // inside the !is_key_repeat branch.
                        if g->phase == game_phase.gp_playing then
                            advance_iddqd(g, k)
                        if k == sdl2.key_s then take_screenshot(w, vs, pal)
                        if k == sdl2.key_d then debug_dump_state(w)
                        // IN_Ack: any keydown during an acknowledge screen
                        // (intermission / episode-end / final victory) counts
                        // as "acknowledge and advance". The advance itself
                        // runs below (after tick) and is gated by
                        // key_ack_handled so a held key only fires once.
                        if g->phase == game_phase.gp_intermission
                           || g->phase == game_phase.gp_episode_end
                           || g->phase == game_phase.gp_victory
                           || g->phase == game_phase.gp_game_over then
                            g->key_ack = true
            if t == sdl2.keyup_event then
                let k = event.key.keysym.sym
                // Keyup only clears flags; not phase-sensitive.
                if k == sdl2.key_up then g->key_up = false
                if k == sdl2.key_down then g->key_down = false
                if k == sdl2.key_left then g->key_left = false
                if k == sdl2.key_right then g->key_right = false
                if k == sdl2.key_lshift then g->key_shift = false
                if k == sdl2.key_lalt then g->key_alt = false
                if k == sdl2.key_lctrl then g->key_fire = false
                // Cheat-chord held-flags (see keydown side).
                if k == sdl2.key_m then g->key_m_held = false
                if k == sdl2.key_l then g->key_l_held = false
                if k == sdl2.key_i then g->key_i_held = false
                if k == sdl2.key_b then g->key_b_held = false
                if k == sdl2.key_a then g->key_a_held = false
                if k == sdl2.key_t then g->key_t_held = false
                if k == sdl2.key_space then
                    g->key_space = false
                    g->key_space_handled = false
                // Any keyup rearms the IN_Ack latch so the next press can fire.
                g->key_ack = false
                g->key_ack_handled = false

        // Cheat chords (M+L+I, B+A+T). Only fires while actually playing,
        // so holding the letters on menus / intermission / death screens
        // is a no-op. Runs before tick so the refilled health/ammo/weapon
        // is visible the same frame.
        if g->phase == game_phase.gp_playing then
            check_cheat_chords(g)

        // Update
        tick(w, dt)

        // Phase transitions (elevator→intermission, death→restart/gameover).
        // Music chunk swap is handled below from a single source of truth
        // (music_chunk_for_phase); no per-call music_switch flag needed.
        update_phase_transitions(w, vs)
        // Intermission → either episode-end (if we just finished level 8)
        // or next map. The episode-end screen owns its own space-advance.
        // First press of space while the count-up is running skips animation
        // to the final "everything shown" state; next press advances.
        if g->phase == game_phase.gp_intermission && g->phase_timer > 0.0
           && g->key_ack && !g->key_ack_handled then
            g->key_ack_handled = true
            if g->inter_stage < 4 then
                finish_intermission_anim(g)
            else if g->level_num % levels_per_episode == 8 then
                enter_episode_end(g)
            else
                advance_next_level(w, vs)
        // Episode-end → next episode's first map (or final victory).
        if g->phase == game_phase.gp_episode_end && g->phase_timer > 0.0
           && g->key_ack && !g->key_ack_handled then
            g->key_ack_handled = true
            advance_next_episode(w, vs)
        // Final victory → return to main menu.
        if g->phase == game_phase.gp_victory && g->phase_timer > 0.0
           && g->key_ack && !g->key_ack_handled then
            g->key_ack_handled = true
            g->phase = game_phase.gp_main_menu
            g->menu_level = menu_main
            g->menu_sel = 1     // NEW GAME — game ended, RESUME is locked
            g->has_active_game = false
        // Game-over: any key restarts from level 0 with a fresh game.
        if g->phase == game_phase.gp_game_over
           && g->key_ack && !g->key_ack_handled then
            g->key_ack_handled = true
            restart_full_game(w, vs)
        // Sync the active music to whatever phase we're now in. Only swap
        // when the chunk actually changed, so we don't restart the IMF
        // player every frame. Don't call `sdl2.clear_audio` here — the
        // already-queued ~46 ms of old music drains naturally while the
        // new chunk's samples take over, which sounds cleaner than the
        // audible underrun a hard flush causes.
        let want_chunk = music_chunk_for_phase(g->phase, g->level_num)
        if want_chunk != current_music_chunk then
            if audio_dev > 0u32 && want_chunk < ad->num_chunks then
                if ms.is_some then imf.destroy(ms!)
                ms = some(music_load(ad, want_chunk))
                current_music_chunk = want_chunk

        // Render
        render_frame(w, vs, pal)

        // Generate and queue audio: music -> AdLib SFX -> digi SFX -> SDL.
        // Buffer is 1024 STEREO frames (2048 int16 values = 4096 bytes);
        // drivers write L/R interleaved additively. Back-pressure threshold
        // is also in bytes.
        // Keep ~90 ms of queued stereo audio. Bigger than strictly needed
        // but cheap insurance against single-frame render hitches: if the
        // queue empties between fills, PulseAudio/PipeWire backends can
        // disconnect the SDL_QueueAudio stream entirely (silent music + SFX
        // until restart), which is exactly the failure mode we kept hitting.
        let queue_hi_water = 16384u32   // bytes; ~92ms of stereo audio
        let skip_audio = audio_dev == 0u32 ||
            sdl2.queued_audio_size(audio_dev) >= queue_hi_water
        if !skip_audio then
            mixer.fill_frame(mix_buf, out_buf, ms, music_on,
                w->ac->sfx, w->ac->digi, 1024, sample_rate)
            sdl2.queue_audio(audio_dev, (any*) out_buf.ptr, 4096u32)
            void()

        // Upload framebuffer to texture and display.
        // Upscale 320x200 → 640x400, upload, and present.
        upscale_2x(w->rc)
        sdl2.update_texture(tex, (any*) 0, (any*) w->rc->dbuf.ptr, screen_w * 4)
        sdl2.clear(ren)
        sdl2.render_copy(ren, tex, (any*) 0, (any*) 0)
        sdl2.present(ren)

    // Cleanup
    if audio_dev > 0u32 then sdl2.close_audio(audio_dev)
    sdl2.destroy_texture(tex)
    sdl2.destroy_renderer(ren)
    sdl2.destroy_window(win)
    sdl2.quit()
    0
