// Wolf-FC — a Wolfenstein 3D clone written in FC using SDL2.
// Classic 320x200 raycasting engine with textured walls, scaled to window.

// Project modules are top-level (no namespace), so they're reachable by
// qualified name without imports: sdl2.*, opl2.*, imf.*, adlib.*, png.*,
// plus the data-loading modules (bytes, palette, vswap, maps, audio) from
// data.fc. Only stdlib imports are needed here.
import io from std::
import sys from std::
import math from std::
import text from std::
import random from std::

// ============================================================
// Constants
// ============================================================

let game_w = 320       // internal game resolution (current; will become
                       // rc->fb_w in Hor+ widescreen pass)
let game_h = 200
let screen_w = 640     // display resolution (2x scale)
let screen_h = 400
let actual_h = 480     // 4:3 corrected height (6 * screen_h / 5)
let view_h = 160       // 3D viewport height in game coords (HUD takes bottom 40)
// Internal vertical resolution for the 3D viewport (raycaster + billboards
// + weapon + view-only overlays). Set to 2× view_h so each output dbuf row
// in the viewport region maps 1:1 to a raycaster row. Higher view_render_h
// halves `step_v = 64 / line_h` per integer line_h step → halves texture-row
// aliasing while walking forward into walls.
let view_render_h = 320
let map_size = 64

// `tan(36°)` — the OG horizontal half-FOV at the right edge of the 320-wide
// framebuffer (derived from FOCALLENGTH=0x5700 + MINDIST=0x5800 and
// VIEWGLOBAL=0x10000: edge tang = 160·0x10000 / 320 / 0xAF00 ≈ 0.7314, full
// FOV ≈ 72°). `game.plane_factor` is set at startup from this scaled by
// `fb_w / 320` so a wider framebuffer gets a proportionally wider FOV (Hor+
// widescreen: same vertical FOV, more horizontal).
let fov_factor = 0.7269

// Episode structure (6 episodes × 10 levels each). Within an episode,
// levels 0..7 are the normal maps, level 8 is the boss / finale, level 9
// is the secret level (reachable via a dedicated alt-elevator switch).
//
//   level 0..7 : elevator → next map in same episode
//   level 8    : elevator → episode victory screen; next episode at ep*10
//   level 9    : elevator → back to episode.back_to[ep] within episode
module episode =
    let levels_per = 10
    let count      = 6
    let back_to    = int32[6] { 1, 1, 7, 3, 5, 3 }

    // Human-readable episode titles (used by the episode-picker menu
    // and the per-episode victory screen).
    let title = (ep: int32) ->
        match ep with
        | 0 -> "ESCAPE FROM WOLFENSTEIN"
        | 1 -> "OPERATION EISENFAUST"
        | 2 -> "DIE, FUHRER, DIE!"
        | 3 -> "A DARK SECRET"
        | 4 -> "TRAIL OF THE MADMAN"
        | 5 -> "CONFRONTATION"
        | _ -> ""

    // Where should the next elevator trip land, given current level
    // and the `went_secret` latch?
    //   - If we just came from the secret level (level 9 of episode),
    //     return to back_to[ep] within the same episode.
    //   - If the player used the alt-elevator switch, jump to the
    //     secret level (level 9 of current episode).
    //   - Otherwise, level+1 within the same episode (0..7). Level 8
    //     is handled by the episode-end caller, not here.
    let next_level_num = (level_num: int32, went_secret: bool) ->
        let ep = level_num / levels_per
        let lvl = level_num % levels_per
        if went_secret then ep * levels_per + 9
        else if lvl == 9 then ep * levels_per + back_to[ep]
        else ep * levels_per + lvl + 1

// Quit-confirmation prompt pool. Mirrors the original game's "are you
// sure?" modal that picked a tongue-in-cheek prompt at random. We invent
// our own pool (no copyleft hygiene risk from the OG strings).
//
// Tone: playful taunt. The implicit deal is "quitting trades real action
// for mundane life" — so each cliffhanger ("FOR X AND Y...") names a
// paired-mundane thing the player would be trading down to, and the
// spelled-out ones describe a small domestic alternative. A handful of
// WW2-flavoured pairings (paperwork, drills, furlough) lean into the
// game's setting; the rest are general retiree-coded coziness.
//
// The pool can be overridden by writing one prompt per line to
// `~/.wolf-fc/quit-prompts`. Blank lines are ignored. A missing file or
// a file with no non-blank lines falls back to the built-in pool.
module quit_prompts =
    import io from std::
    import text from std::

    let builtin_count = 27

    let builtin_at = (i: int32) ->
        match i with
        // "For X and Y..." cliffhangers — the mundane life waiting on
        // the other side of the QUIT key.
        | 0  -> "For paperwork and protocol..."
        | 1  -> "For desk duty and decaf..."
        | 2  -> "For drill and drudgery..."
        | 3  -> "For filing and furlough..."
        | 4  -> "For memos and mothballs..."
        | 5  -> "For laundry and leftovers..."
        | 6  -> "For dishes and daytime TV..."
        | 7  -> "For hot cocoa and housework..."
        | 8  -> "For hearth and homework..."
        | 9  -> "For tea and tranquility..."
        | 10 -> "For fresh air and ferns..."
        | 11 -> "For the love of daylight..."
        | 12 -> "For pizza and peace of mind..."
        | 13 -> "For friends and fresh bread..."
        | 14 -> "For cats and contentment..."
        | 15 -> "For porch swings and patience..."
        | 16 -> "For dominoes and daydreams..."
        | 17 -> "For slippers and sudoku..."
        | 18 -> "For cardigans and crosswords..."
        | 19 -> "For yarn and yawning..."
        | 20 -> "For naps and needlepoint..."
        // Spelled-out — small domestic observations, no imperatives.
        | 21 -> "Dinner won't cook itself."
        | 22 -> "Bed is calling."
        | 23 -> "There is a sunset waiting."
        | 24 -> "Birds are chirping outside."
        | 25 -> "The coffee is getting cold."
        | _  -> "The laundry has been waiting."

    // Heap-copy a str slice into an owned uint8 buffer. Returned slice
    // is freeable on its own (no shared backing), so the override array
    // can be torn down line-by-line in `free_override`.
    private let dup_str = (s: const str) ->
        let n = s.len
        let buf = alloc(uint8[n] {})!
        for i in 0..n
            buf[i] = s[i]
        (str) buf

    // Read newline-delimited override pool. Lines are trimmed; blanks
    // dropped. Returns an empty slice if the file is missing, unreadable,
    // or contains zero non-blank lines — caller falls back to built-ins.
    let load_override = () ->
        match paths.wolf_data_dir() with
        | none -> alloc(str[0] {})!
        | some(dir) ->
            defer free(dir)
            let path = alloc("%s{dir}/quit-prompts")!
            defer free(path)
            match io.read_all(path) with
            | none -> alloc(str[0] {})!
            | some(contents) ->
                defer free(contents)
                let lines = text.split(contents, "\n")
                defer free(lines)
                // First pass: count non-blank trimmed lines.
                let mut n = 0i64
                for i in 0..lines.len
                    if text.trim(lines[i]).len > 0i64 then
                        n = n + 1i64
                if n == 0i64 then alloc(str[0] {})!
                else
                    let out = alloc(str[n] {})!
                    let mut k = 0i64
                    for i in 0..lines.len
                        let t = text.trim(lines[i])
                        if t.len > 0i64 then
                            out[k] = dup_str(t)
                            k = k + 1i64
                    out

    // Free the heap-allocated override pool (line buffers + outer slice).
    let free_override = (pool: str[]) ->
        for i in 0..pool.len
            free(pool[i])
        free(pool)

    // Pick the i-th prompt out of either the override pool (when non-
    // empty) or the built-in pool. Caller is responsible for choosing
    // a valid index.
    let at = (override_pool: const str[], i: int32) ->
        if override_pool.len > 0i64 then
            (const str) override_pool[(int64) i % override_pool.len]
        else builtin_at(i)

    let count = (override_pool: const str[]) ->
        if override_pool.len > 0i64 then (int32) override_pool.len
        else builtin_count

// ============================================================
// Game state
// ============================================================

// High-level game phase. Drives tick() (most systems freeze outside playing)
// and the main loop's input handling (intermission / high_scores consume space
// to advance; playing dispatches keys into the normal game code).
//
//   playing       — normal gameplay
//   dying         — collapse animation + red screen tint after HP=0
//   intermission  — stats screen between levels (press space to continue)
union game_phase =
    | pg13          // PG-13 parental-advisory splash shown once at startup;
                    // any key (or a short auto-timer) advances to title.
                    // Original Wolf3D had a SIGNON banner (a separate
                    // SIGNON.BIN linked into the EXE) before this; we
                    // skip it since the asset isn't in WL6 data files.
    | title         // title screen shown before first game; any key → menu
    | main_menu     // nav a list with arrows. Doubles as the pause UI:
                    // Esc from `playing` lands here with RESUME selected.
    | playing
    | dying
    | intermission
    | bj_victory    // BJ runs forward + jumps + yells after the player
                    // steps on a boss-map EXITTILE (ports the original's
                    // VictoryTile → SpawnBJVictory → ex_victorious path).
    | death_cam     // boss-death cutscene for the four auto-victory bosses
                    // (Schabbs / Gift / Fat / real Hitler). Pause on final
                    // death frame, fizzle to black, taunt card, teleport
                    // camera to frame the corpse, fade in, replay death
                    // animation, hand off to intermission. Ports the
                    // original's A_StartDeathCam.
    | episode_end   // per-episode victory screen (after boss level 8)
    | endart        // per-episode story-text page(s) shown after the
                    // episode-end stats screen — VGAGRAPH chunks 143..148
                    // hold article-markup data (^P pages, ^Cnn colors,
                    // ^Gx,y,p inline graphics, word-wrapped text). Forward
                    // keys page through; Esc or forward-past-last → main
                    // menu (matches the OG, where Victory()'s embedded
                    // ShowArticle ends GameLoop and pops to the control
                    // panel — no auto-advance to the next episode).
    | high_scores   // top-7 score table; shown after death (replaces the
                    // OG's CheckHighScore call from `ex_died`), after
                    // the per-episode endart article (`ex_victorious`),
                    // and from the View Scores main-menu entry. If the
                    // ending game qualified, the new row enters an
                    // inline name-edit mode (mirrors US_LineInput);
                    // otherwise any ack key dismisses → title screen.

// Menu navigation state. `menu_level` picks which list to show:
//   main        (NEW GAME / SOUND / LOAD GAME / SAVE GAME / RESUME / QUIT)
//   difficulty  (under NEW GAME, after episode select)
//   episode     (under NEW GAME, before difficulty)
//   savelist    (Save Game — 10 slots)
//   loadlist    (Load Game — 10 slots)
//   sound       (Music ON/OFF + Sound Effects ON/OFF)

struct game =
    // Camera / player
    pos_x: float64
    pos_y: float64
    dir_x: float64
    dir_y: float64
    plane_x: float64
    plane_y: float64

    // Input
    key_up: bool
    key_down: bool
    key_left: bool
    key_right: bool
    key_shift: bool
    key_alt: bool
    key_ctrl: bool
    key_space: bool
    // Latched so a held-space only triggers the use-action once per press.
    // Set true the first time player.update sees key_space=true; reset on
    // keyup. Without this the SDL key-repeat stream retriggers the door/
    // push-wall handlers on every frame, producing stray sounds.
    key_space_handled: bool
    // "Any key" ack for IN_Ack-style screens (intermission, episode-end,
    // victory, game-over). Set on any non-repeat KEYDOWN while in one of
    // those phases; cleared when all ack keys are released. Same latch/
    // handled pattern as key_space so a held key only advances once.
    key_ack: bool
    key_ack_handled: bool
    key_fire: bool
    // Held-state flags for the cheat-chord keys. Unlike the main gameplay
    // keys above (which are consumed per-frame by movement/fire), these
    // stay true while the physical key is pressed so player.cheats.check_chords can
    // detect M+L+I or B+A+T held simultaneously, regardless of press order.
    // Only wired in the interactive loop; --test mode fires the effect via
    // the mli / bat commands directly.
    key_m_held: bool
    key_l_held: bool
    key_i_held: bool
    key_b_held: bool
    key_a_held: bool
    key_t_held: bool
    // Edge latches so a held chord fires the cheat once. Cleared when any
    // of the three chord keys is released, re-arming the next press.
    cheat_mli_latched: bool
    cheat_bat_latched: bool
    // Doom-style IDDQD god-mode cheat. `iddqd_progress` is the index of
    // the next expected key in the I-D-D-Q-D sequence (0..4); reaching 5
    // toggles `god_mode` and resets. Detected on letter-key keydown
    // events (no key-repeat) so a held key can't auto-advance the
    // state machine. While `god_mode` is true, enemies.ai.damage_player early-
    // returns so the player can't lose health (or die).
    iddqd_progress: int32
    god_mode: bool
    // Doom-style IDKFA cheat. Same sequence-matching idea as IDDQD, but on
    // the I-D-K-F-A letter sequence. Toggling it on grants all keys, the
    // chain gun + 99 ammo, and latches `idkfa_mode` — which suppresses
    // ammo decrement in player.update_weapon and blocks score gains through
    // player.add_score (treasure pickups, enemy kills, intermission bonus).
    // reset_for_life re-grants the gifts on every death so the latch
    // survives dying.
    idkfa_progress: int32
    idkfa_mode: bool
    // Original-game TAB+<key> cheats. `key_tab_held` tracks whether TAB is
    // currently pressed; any subsequent keydown while it's true dispatches
    // through player.cheats.apply_tab_* (G/I/N/E/H). `noclip` is the latched
    // state of TAB+N — when true, try_move skips wall / door / enemy / static
    // collision so the player can walk through anything. Doesn't affect
    // raycasting or enemy LOS, so visuals / AI behave normally.
    key_tab_held: bool
    noclip: bool
    // Wall-scrape sound cooldown (seconds). Prevents HITWALLSND from firing
    // every frame while the player grinds along a wall. Counts down in
    // player.update; a new bump is only announced when it hits 0.
    wall_hit_cooldown: float64

    // Game
    health: int32
    ammo: int32
    score: int32
    // Score at the start of the current level. Captured at level
    // transition (in `advance_next_level`, after the just-completed
    // level's intermission bonus has been added) and consumed by
    // `restart_current_level` to rewind on death-with-lives-left.
    // Mirrors the original game's `gamestate.oldscore` — every
    // failed run of a level forfeits the points earned within that
    // run. The high-scores screen still uses the un-rewound `score`
    // at time of final death (we never reach restart_current_level
    // on the lethal life), matching the original's CheckHighScore
    // call from the `ex_died` lives==-1 branch.
    oldscore: int32
    lives: int32
    level_num: int32
    has_gold_key: bool
    has_silver_key: bool
    next_level: bool
    // Counts down in playing while `next_level` is latched; when it reaches
    // 0 the intermission phase is entered. Gives LEVELDONESND ("elevator
    // ding") time to play in the world before the tally screen pops.
    next_level_delay: float64
    weapon: int32          // 0=knife, 1=pistol, 2=machine gun, 3=chain gun
    best_weapon: int32     // highest-tier firearm owned (pistol..chain). When
                           // ammo runs out we drop to knife; picking ammo up
                           // again restores this weapon (wolf4sdl's chosenweapon).
    // Latched when the player uses the alt-elevator switch (plane-0 raw tile
    // 107 underfoot at the moment of activation). advance_next_level reads it
    // to route to the secret level (ep*10+9) instead of the normal next map.
    // Cleared after the routing decision is applied.
    went_secret: bool
    fire_timer: float64    // cooldown timer (>0 means firing animation)
    weapon_frame: int32    // animation frame (0=idle, 1-3=firing)
    // BJ-face HUD animation (wolf4sdl UpdateFace). face_frame picks the
    // A/B/C variant (0..2) of the current health-driven expression row;
    // face_count accumulates ~2 units per 35Hz tick (matching wolf4sdl
    // `facecount += tics` at 70Hz), and when it exceeds a random 0..255
    // threshold a new variant is rolled (0=25%, 1=50%, 2=25%, like the
    // `US_RndT()>>6` clamp). Reset to 0 on damage so the new expression
    // appears immediately.
    face_frame: int32
    face_count: float64
    // Wolf4sdl player->areanumber: index into level->tile_areas for the tile
    // the player is currently standing on. Used to anchor areas.connect's
    // flood. Refreshed each tick by areas.update_player_area.
    area_number: int32
    // Wolf4sdl `madenoise`: latched true when the player fires a non-knife
    // weapon or damages an enemy; consumed by enemies.ai.update_enemies to wake stand /
    // path enemies in the player-connected area set without needing LOS.
    // Reset at the top of each tick so it only fires for one frame.
    made_noise: bool
    // Wolf4sdl `thrustspeed >= RUNSPEED`: set in player.update to mark a
    // frame in which the player was actively moving (run modifier held +
    // any movement key). Enemy T_Shoot reads this to pick the lower
    // base-160 hitchance — player-can-dodge branch.
    player_running: bool
    // Latched by the BOSS FIGHT menu entry (and the --near-boss CLI flag,
    // on entry). Consumed by `start_new_game_here` to call
    // `spawn.near_boss` after the map loads, then cleared.
    want_near_boss: bool

    // BJ victory cutscene actor state — active only during bj_victory.
    // Spawned at the player's position; follows path-arrow tiles
    // (lv->path_arrows) tile-by-tile for 6 tiles, then jumps 4 frames with
    // YEAHSND on frame 2. See bj_victory.enter / bj_victory.tick.
    bj_x: float64
    bj_y: float64
    bj_tile_x: int32       // current tile (for path-arrow lookup)
    bj_tile_y: int32
    bj_dir: int32          // current heading (dir.east..dir.southeast, or dir.nodir)
    bj_distance: float64   // tiles remaining until BJ reaches next tile center
    bj_run_tiles_left: int32  // tiles to run before starting the jump (counts down from 6)
    bj_anim_frame: int32
    bj_anim_timer: float64
    bj_phase: int32      // 0 = running, 1 = jumping, 2 = holding final frame
    bj_yelled: bool      // YEAHSND latch (fires on entering jump frame 1)

    // Per-episode running totals for the Victory() screen at
    // episode_end. Each completed level adds its kill / secret /
    // treasure percent + level time to these. ep_levels_played is
    // the divisor for averages. ep_recorded_current is a dedup latch
    // — set when the just-finished level was already recorded, so
    // bj_victory + intermission paths don't double-count the boss
    // level. Reset on new game / next episode.
    ep_kr_total: int32
    ep_sr_total: int32
    ep_tr_total: int32
    ep_time_total: int32
    ep_levels_played: int32
    ep_recorded_current: bool

    // Per-episode ending text — active only during gp_endart.
    // `endart_data` is the decompressed VGAGRAPH chunk for the current
    // episode (chunks 143..148 hold article-markup). Page offsets are
    // computed once on entry so the renderer can jump to any page in O(1).
    endart_data: uint8[]
    endart_page_offsets: int32[]
    endart_total_pages: int32
    endart_page: int32         // 0-indexed; final page index = total_pages - 1

    // High-scores entry source. Latched in `high_scores_screen.enter`
    // so the dismissal handler knows whether to route back to the
    // title (post-death / post-victory) or the main menu (View Scores
    // entry). Values are `high_scores_screen.from_*` constants.
    hs_source: int32

    // Death-cam cutscene state — active only during death_cam.
    // Sub-phases: 0 = hold on final death frame, 1 = dissolve to black,
    // 2 = taunt "Let's see you in hell!" text screen, 3 = camera teleport +
    // dissolve back in, 4 = replay death animation, 5 = hand off to
    // intermission (transient; update_phase_transitions enters next state).
    dc_sub: int32
    dc_timer: float64               // seconds elapsed in current sub-phase
    dc_boss_idx: int32              // index of the corpse in lv->enemies
    dc_kill_x: float64              // player position when the boss died
    dc_kill_y: float64              // (matches wolf4sdl gamestate.killx/y)
    dc_fade: float64                // 0 = viewport fully visible, 1 = fully
                                    // black; feeds overlay.dissolve_stipple during
                                    // fade-out / taunt / fade-in sub-phases

    // Phase state (death / intermission / game-over). Most of tick() skips
    // when phase != playing; rendering paints the appropriate overlay.
    phase: game_phase
    phase_timer: float64       // seconds spent in current phase (for transitions)
    damage_flash_timer: float64  // red tint on damage; decays each tick
    // Latch set whenever the player's most recent damage came from a
    // Schabbs needle projectile. Cleared by any other damage source
    // and on respawn / new game. Read by hud.render to pick
    // MUTANTBJPIC over FACE8APIC on the dying-face slot (original's
    // DrawFace `LastAttacker->obclass == needleobj` branch).
    last_hit_needle: bool
    // Death-cam swing target: the killer's world position at the moment
    // the lethal hit landed. Mirrors the original's `killerobj` latch in
    // TakeDamage — the `Died` routine swings the player to face this
    // point at a fixed angular rate during the dying phase.
    // `killer_active` is true between the lethal hit and the moment the
    // swing finishes; cleared on respawn / new game and on the synthetic
    // `kill` test command (no enemy to face).
    killer_x: float64
    killer_y: float64
    killer_active: bool
    // Red stipple that uncovers back to the new scene after a death-restart.
    // Set to `player.respawn_fade_time` by restart_current_level; decays each tick.
    respawn_fade_timer: float64
    // "GET PSYCHED!" overlay shown briefly on level entry. Ticks down each
    // frame; while > 0 the world is frozen (tick skips all subsystems) and
    // render_frame paints GETPSYCHEDPIC over a grey background with a
    // progress bar, covering the disk-load pause the original game had.
    get_psyched_timer: float64

    // Chain-gun pickup face-slot swap. While > 0, hud.render paints
    // GOTGATLINGPIC in the BJ-face cell instead of the normal face frame
    // (matches wolf4sdl DrawFace's "SD_SoundPlaying() == GETGATLINGSND"
    // check). Does NOT freeze gameplay.
    got_gatling_timer: float64

    // Per-level counters. Totals come from build_level; current values
    // increment during play. All three are displayed on the intermission
    // screen as percentages (wolf4sdl bonus calculations).
    kills: int32
    total_kills: int32
    secrets: int32
    total_secrets: int32
    treasures: int32
    total_treasures: int32

    // Seconds elapsed in the current level (accumulates in tick during
    // playing). Compared against par_times on intermission.
    level_time: float64

    // Intermission screen animation state. Only meaningful during
    // intermission. Mirrors wolf4sdl LevelCompleted's count-up sequence:
    // time bonus ticks up first, then kill / secret / treasure ratios.
    //   stage: 0=time, 1=kill, 2=secret, 3=treasure, 4=done (awaiting space)
    //   counter: current value rendered in the active stage
    //   progress: fractional accumulator that drives counter at a fixed rate
    //   bonus_shown: running "BONUS" line displayed at the top-right
    //   target_timeleft / target_kr / target_sr / target_tr: cached goals
    inter_stage: int32
    inter_counter: int32
    inter_progress: float64
    inter_bonus_shown: int32
    inter_target_timeleft: int32
    inter_target_kr: int32
    inter_target_sr: int32
    inter_target_tr: int32
    inter_breathe_timer: float64   // drives L_GUYPIC/L_GUY2PIC alternation
    inter_pause_timer: float64     // post-stage pause: holds the just-finished
                                   // counter's final value on-screen with its
                                   // end-of-stage sound audible before the
                                   // next counter starts zipping up. Mirrors
                                   // wolf4sdl's VBLWAIT(30) + SD_SoundPlaying
                                   // gap between the three ratio rounds.
    inter_end_sound_delay: float64 // time left until the queued end-of-stage
                                   // sound actually fires. Gives the final
                                   // ENDBONUS1SND tick a moment to clear so
                                   // it doesn't collide with the ring sound.
                                   // wolf4sdl's `while (SD_SoundPlaying)` wait
                                   // served the same purpose.

    // Difficulty: 0=Daddy, 1=Don't Hurt Me, 2=Bring 'em On, 3=Death Incarnate.
    // Controls which tile blocks spawn enemies (base/+36/+72 per
    // ScanInfoPlane). Initialised to `difficulty.medium` to match the
    // OG difficulty-picker default (`NewItems.curpos = 2` in wl_menu.cpp).
    // The picker remembers the last pick within a session via
    // `menu_sel = g->difficulty`; `setdifficulty` dials it externally.
    difficulty: int32

    // Camera plane length. Combined with `dir_x/dir_y` it sets the
    // raycaster's horizontal FOV: the column at the right edge of the
    // viewport casts toward `dir + plane`, so wider plane = wider
    // FOV. Set at startup from the display aspect ratio for Hor+
    // widescreen — the OG's value is `tan(33°) ≈ 0.66` at 320 wide;
    // at 384 wide it's 0.66 * 384/320 ≈ 0.792, etc. Read by spawn
    // (which seeds plane_x/plane_y based on facing direction) and by
    // movement / hitscan code.
    plane_factor: float64

    // View-mode preference (Change View menu). 0=auto-detect from
    // display, 1=Original 4:3, 2=Widescreen 16:10, 3=Widescreen 16:9.
    // The render geometry (fb_w / plane_factor) is captured at
    // startup from this value. Changing the value mid-session
    // updates the config file but only takes effect on next launch.
    view_mode: int32

    // No-dogs mod toggle. Set from the Options menu (persisted in
    // ~/.wolf-fc/config) or from the --no-dogs CLI flag at launch.
    // Read by spawn.spawn_enemies; takes effect on the next level
    // build (changing it mid-level doesn't despawn live dogs).
    no_dogs: bool
    // Shadow Depth (0..100). Controls how dark walls / sprites get
    // at long distance — 0 disables distance fading entirely (the
    // OG-faithful default; the original has no distance shading,
    // only a side tint on perpendicular walls), 100 lets things go
    // to full black at the far end. Read every frame by the
    // raycaster + billboards via `raycaster.shadow_floor_from_depth`.
    shadow_depth: int32
    // Movement-speed multipliers as percentages (20..200, default 100).
    // bj_speed_pct scales every player speed (forward / back / strafe
    // / turn); enemy_speed_pct scales every patrol + chase speed in
    // combat.fc (and the dog lunge-range gate that uses speed × dt).
    // Default 100 keeps OG-faithful behaviour. Persisted in
    // ~/.wolf-fc/config alongside shadow_depth / view_mode.
    bj_speed_pct: int32
    enemy_speed_pct: int32
    // --test CLI flag: suppresses UX-only flourishes that would otherwise
    // freeze gameplay by a fixed duration (GET PSYCHED overlay, pickup
    // overlay). Tests advance the world `dt = 1/35` per tick, so a 0.7s
    // overlay would eat ~24 ticks and break determinism for every test
    // that crosses a level boundary.
    test_mode: bool

    // Resolved WL6 data directory (heap str). Resolved once in `main`
    // by `data_path.resolve()` — search order is $WOLF_FC_DATA_DIR,
    // then ./data, then the compile-time install location. Used by
    // every WL6 file load (initial + level transitions).
    data_dir: str

    // Menu selection state.
    menu_sel: int32
    menu_level: int32

    // Save-slot inline name entry. While true, the savelist menu is
    // showing a typing caret on the selected slot; main-loop keydowns
    // mutate `save_menu_ctx.edit_buf` instead of moving the cursor.
    // Enter commits + writes the slot, Esc cancels back to the slot
    // list. Mirrors the original's `US_LineInput` flow.
    save_edit_active: bool

    // Music on/off — togglable from the main menu "SOUND" entry.
    // Interactive loop inspects this when filling audio.
    music_on: bool

    // User requested quit (main menu's QUIT entry). Main loop reads this
    // and breaks out of the game loop.
    want_quit: bool

    // Quit-confirm modal state. `quit_prompt_idx` is rolled when the
    // QUIT row is selected and stays stable while the modal is up so a
    // user toggling between Y/N (well, just looking) sees the same
    // prompt. `quit_prompts_override` is loaded once at startup from
    // ~/.wolf-fc/quit-prompts; an empty slice means "use built-ins".
    quit_prompt_idx: int32
    quit_prompts_override: str[]

    // True once the player has started a game at least once. Controls the
    // main-menu behaviour: when true, Esc from the main menu resumes play;
    // otherwise there's nothing to return to.
    has_active_game: bool

    // Fading message banner at the top of the 3D viewport. Set via
    // hud.show_message; render_frame paints during playing only. msg_buf
    // is a fixed 64-byte buffer alloc'd once at game construction; we
    // never realloc — just copy into the first msg_len bytes.
    msg_buf: uint8[]
    msg_len: int32
    msg_timer: float64    // seconds remaining; decays during playing

    // PRNG state. Two pcg32 streams from the same seed but different channels:
    // enemy AI rolls (sight, hit chance, damage) and BJ face idle animation.
    // Keeping face on its own channel means rendering the HUD doesn't perturb
    // the enemy sequence that scripted tests depend on. Seed is 0 in --test
    // for reproducibility, sys.time() otherwise — set in main.
    rng_enemy: random.pcg_random
    rng_face: random.pcg_random

// CLI flag `--no-dogs`: when true, spawn.spawn_enemies skips every enemies.enemy_kind.dog. Pre-dead
// dog corpses don't exist in the data (the "dead guard" marker is tile 124,
// a guard), so no carve-out is needed for those.

// Per-level state: tile grid, dynamic entities, in-progress animations.
// Built once per level via build_level and destroyed via free_level on
// transition. Everything that a save-state would need to preserve lives here.
struct level =
    // Column-major 64x64 tile grid: tilemap[x*64 + y].
    // 0 = empty, 1-63 = wall texture, 128+ = door (index = value - 128).
    tilemap: uint8[]
    // Bitmap: which wall tiles are pushable (marker 98 in plane 1).
    pushwall_tiles: bool[]
    // Bitmap: which tiles are EXITTILE markers (plane-1 tile 99). Stepping
    // onto one triggers the BJ-victory cutscene (wolf4sdl VictoryTile).
    // Boss-level maps place these behind the gold-key door so the player
    // must kill the boss + pick up the dropped key first.
    exit_tiles: bool[]
    // Per-tile path-arrow override for patrolling enemies (plane-1 tiles
    // 90..97 = ICONARROWS + dir). 0..7 redirects a passing patroller to that
    // dir; dir.nodir (8) means "no arrow at this tile".
    path_arrows: uint8[]
    // Static sprite objects spawned from plane-1 tiles 23..72.
    sprites: tilemap.sprite_obj[]
    num_sprites: int32
    // Door objects allocated when their tiles are encountered during build.
    doors: doors.door_obj[]
    door_pos: float64[]         // 0.0 = closed, 1.0 = open
    num_doors: int32
    // Currently-animating push-wall (at most one at a time).
    pushwall: pushwall.pushwall_state
    // Active + dead enemies spawned from plane-1 tiles 108+.
    enemies: enemies.enemy[]
    num_enemies: int32
    // Active enemy-fired projectiles (Schabbs syringes, Giftmacher / Fat
    // rockets + their boom sprites, fake-Hitler flames). Slot-allocated in a
    // fixed-size array; `alive = false` means free. No separate count — the
    // array is scanned on every update / billboards.build pass.
    projectiles: projectiles.projectile[]
    // Wolf4sdl area system: per-tile area index (areas.no_area for walls / other
    // non-area tiles); a areas.num_areas² counter of how many open doors connect
    // each pair (>0 means connected); a per-area "reachable from player by
    // open doors" flag refreshed by areas.connect on each door transition.
    tile_areas: uint8[]
    area_connect: uint8[]
    area_by_player: bool[]
    // Per-level totals used by the kill / secret / treasure counters.
    // Computed once at build time; `game.total_*` mirrors them. Kept on
    // level so they survive player death (restart reuses these).
    total_enemies: int32         // live enemies spawned (excludes corpses)
    total_pushwalls: int32       // plane-1 tile 98 count
    total_treasures: int32       // treasure pickups (cross/chalice/bible/crown)

// One drawable billboard emitted each frame — a merged queue of static sprites
// and enemies, sorted back-to-front so farther items draw first and nearer
// ones paint over them. Kept in a process-wide scratch buffer on render_ctx
// rather than freshly allocated per frame.
struct billboard =
    x: float64
    y: float64
    shape_page: int32
    dist_sq: float64

// Renderer scratch buffers. Process-wide and rewritten every frame; not
// part of save-state. Held in its own struct so no one reaches for globals.
struct render_ctx =
    // Hor+ widescreen geometry. `fb_w` is the framebuffer width — set
    // at startup from the display aspect (320 for 4:3, 384 for 16:10,
    // 428 for 16:9, etc.); the OG vertical FOV is preserved (game_h
    // stays 200) and the horizontal FOV grows so the player sees more
    // peripheral world. UI elements live in a 320-wide region centred
    // at `ui_offset_x = (fb_w - 320) / 2`; the 3D viewport (raycaster
    // + billboards) and full-screen fills span 0..fb_w.
    fb_w: int32
    fb_h: int32
    screen_w: int32    // display texture width = 2 * fb_w
    ui_offset_x: int32
    fb: uint32[]       // fb_w x fb_h ARGB — primary software-rendered frame
    dbuf: uint32[]     // (2*fb_w) x (2*fb_h) ARGB — 2x nearest-neighbor upscale of fb
    zbuf: float64[]    // per-column wall perp-distance, for sprite clipping
    billboards: billboard[]    // back-to-front draw list (statics + enemies)
    num_billboards: int32
    // Cache of the title screen, pre-decoded and palette-applied at startup.
    // Used as the backdrop for both title and main_menu — without this
    // cache, every menu frame re-Huffman-decompresses TITLEPIC (~64KB of
    // per-bit tree-walk) and re-palettizes 64,000 pixels, which dropped the
    // frame rate enough to underrun the audio queue and kill the music.
    title_bg: uint32[]
    // Pre-rendered god-mode BJ face: FACE1A palette-applied with the
    // blue iris pixels recolored gold. Built once at startup; the HUD
    // blits it as a plain memcpy while god mode is on, so the recolor
    // doesn't run per frame. 24×32 ARGB.
    god_face: uint32[]
    // Lazy cache of VGAGRAPH pic chunks as pre-palettized ARGB buffers.
    // Indexed by chunk id; `.len == 0` means not yet cached. Populated on
    // first draw via `pics.draw` — turns every subsequent draw of the
    // same chunk (HUD background, digits, face, weapon, intermission
    // L-font, etc.) into a plain memcpy. Palette is fixed for the process
    // lifetime, so caching is safe.
    pic_cache: uint32[][]
    // Rotating screenshot slot counter (wraps at overlay.screenshot_max_slots).
    screenshot_slot: int32

// Sound system handle: loaded-asset refs + SFX playback state.
struct audio_ctx =
    vs: const vswap.vswap_file*      // VSWAP — digi sound data + wall/sprite pages
    ad: audio.audio_data*      // AUDIOT — AdLib SFX chunks + music
    sfx: adlib.sfx_state*      // AdLib SFX playback (owns its own OPL2 chip)
    digi: digi.player*         // 8-bit PCM playback (up to 4 slots)
    // Sound submenu's "Sound Effects: ON/OFF" toggle. Read by sfx.trigger_*
    // — when false, every sfx call no-ops. Music has its own gate
    // (`music_on` on `game`, consulted in the main-loop mixer).
    sfx_on: bool

// Save/load menu scratch. One instance per process — only one menu is open
// at a time, so sharing is fine. `slots` is refreshed by save.refresh_slots
// on menu entry; the two scratch buffers are reused across renders / writes.
struct save_menu_ctx =
    slots: save.slot_info[]    // length = save.num_slots
    label_scratch: uint8[]     // 32-byte reusable buffer for slot-label substrings
    hex_scratch: uint8[]       // 1-byte buffer for per-nibble save-file writes
    // In-progress slot name during inline save edit. NUL-terminated;
    // `edit_len` holds the byte length without the terminator. Capacity
    // is 32 (matches the original's MaxString in US_LineInput).
    edit_buf: uint8[]
    edit_len: int32

// High-scores screen state — process-wide, persists across games.
// `scores` is the 7-row table loaded once at startup (or seeded with
// id Software's defaults on first launch) and rewritten whenever a
// new score qualifies. Edit fields drive the inline name-entry that
// activates on a qualifying finish. `edit_index` is -1 outside the
// editing flow; while editing it points at the row in `scores` that
// was just inserted (and `edit_buf` / `edit_len` mirror the typed
// name until the player presses Enter to commit).
struct highscore_ctx =
    scores: highscore.entry[]
    edit_index: int32
    edit_active: bool
    edit_buf: uint8[]
    edit_len: int32
    // True the frame the player exits the high-scores screen after a
    // qualifying-and-named entry, so the post-screen routing (back to
    // title) can persist the table once. Cleared on next entry.
    pending_save: bool

// Everything the running game needs in one handle. Functions that only need
// one sub-context (e.g. `raycaster.render_walls` only touches level + render_ctx) keep
// their narrow signatures so their dependencies are visible in their types;
// only orchestrators (`tick`, `render_frame`, `run_test_cmd`) take `world*`.
// Wrapping this way unlocks save-state and multi-world scenarios without
// having to thread four pointers through every caller.
struct world =
    g: game*            // player, input, session state
    lv: level*          // tile grid + dynamic per-level entities
    lv_data: maps.level*  // decoded source for current level (kept so death /
                          // level-transition helpers can re-read player_start
                          // without another disk load)
    rc: render_ctx*     // renderer scratch buffers
    ac: audio_ctx*      // sound pipeline
    sm: save_menu_ctx*  // save/load menu cache + scratch
    hs: highscore_ctx*  // top-7 high-score table + name-entry scratch
    vg: const vgagraph.vgagraph_file*  // VGAGRAPH: fonts, status bar, BJ face,
                                 // title screen, menu graphics.
    font: font.info*             // small menu/UI font (chunk 1)

// ============================================================
// Cross-subsystem helpers
//
// Small game-state mutations shared across multiple subsystems. Kept at
// file scope in main.fc (the entry-point file, exempt from module-
// dependency cycle detection) so any module — pickups, enemies.ai,
// intermission, player.cheats — can reference them unqualified without
// forcing new cross-module edges.
// ============================================================

// Extra-life milestone. Matches wolf4sdl's EXTRAPOINTS: the player
// gets one extra life each time the score crosses 40000, 80000, etc.
let extra_life_score = 40000

// Grant one extra life with BONUS1UPSND. Matches wolf4sdl
// GiveExtraMan: the `lives` counter caps at 9. Called from add_score
// on each score-milestone crossing and from the 1UP pickup branch in
// pickups.check.
let grant_extra_life = (g: game*, ac: audio_ctx*) ->
    if g->lives < 9 then g->lives = g->lives + 1
    sfx.trigger(sfx.id.bonus1up, ac)

// Add `amount` to the score, honoring the IDKFA score lock. Single
// chokepoint so the lock covers pickups, enemy kills, and intermission
// bonuses uniformly. Also grants the 40k-score extra-life milestone,
// looping for huge single adds (an intermission bonus can easily cross
// multiple milestones at once — matches wolf4sdl's while-loop on
// nextextra). Score caps at 999 999 (the 6-digit HUD cell width); the
// original would happily wrap / overflow past that. The extra-life
// milestone count uses the capped score so once you're maxed, no more
// free lives come from further scoring.
let score_max = 999999
let add_score = (g: game*, amount: int32, ac: audio_ctx*) ->
    if g->idkfa_mode then return
    let before_milestones = g->score / extra_life_score
    g->score = g->score + amount
    if g->score > score_max || g->score < 0 then g->score = score_max
    let after_milestones = g->score / extra_life_score
    let mut n = before_milestones
    loop
        if n >= after_milestones then break
        grant_extra_life(g, ac)
        n = n + 1

// Grant the full cheat kit: 100 health, 99 ammo, chain gun (+ best-
// weapon latch), both keys. Shared by the M+L+I chord, IDKFA
// activation, the --cheat launch flag, and reset_for_life's IDKFA
// restock on respawn.
let give_full_kit = (g: game*) ->
    g->health = 100
    g->ammo = 99
    g->weapon = 3
    g->best_weapon = 3
    g->has_gold_key = true
    g->has_silver_key = true

// Map an SDL keysym + modifier mask to the ASCII byte the user
// intended to type, or 0 if the key has no printable mapping.
// Used by every inline name editor (high-scores, save-game) so they
// accept the same character set the original game's `US_LineInput`
// did (`isprint(c)` — letters, digits, punctuation). SDL keysym
// values for printable-ASCII keys are the ASCII byte itself
// (e.g. SDLK_PERIOD == 46 == '.'), so we compare the keysym
// directly against ASCII codepoints rather than chaining named-
// constant `if`s. The shift mapping assumes a US QWERTY layout —
// other layouts will hand back the wrong shifted character for
// punctuation, but plain letters stay correct.
let keysym_to_ascii = (k: int32, mods: uint16) ->
    let shift = (mods & 0x0003u16) != 0u16
    if k < 32 || k > 126 then 0u8
    else if shift then
        // Letters → uppercase.
        if k >= 97 && k <= 122 then (uint8) (k - 32)
        // Digits + punctuation → US QWERTY shift map.
        else if k == 49 then 33u8     // 1 -> !
        else if k == 50 then 64u8     // 2 -> @
        else if k == 51 then 35u8     // 3 -> #
        else if k == 52 then 36u8     // 4 -> $
        else if k == 53 then 37u8     // 5 -> %
        else if k == 54 then 94u8     // 6 -> ^
        else if k == 55 then 38u8     // 7 -> &
        else if k == 56 then 42u8     // 8 -> *
        else if k == 57 then 40u8     // 9 -> (
        else if k == 48 then 41u8     // 0 -> )
        else if k == 45 then 95u8     // - -> _
        else if k == 61 then 43u8     // = -> +
        else if k == 91 then 123u8    // [ -> {
        else if k == 93 then 125u8    // ] -> }
        else if k == 92 then 124u8    // \ -> |
        else if k == 59 then 58u8     // ; -> :
        else if k == 39 then 34u8     // ' -> "
        else if k == 44 then 60u8     // , -> <
        else if k == 46 then 62u8     // . -> >
        else if k == 47 then 63u8     // / -> ?
        else if k == 96 then 126u8    // ` -> ~
        else (uint8) k
    else (uint8) k


// ============================================================
// Factories
// ============================================================

// Allocate renderer scratch buffers. One instance per process. `fb_w`
// is the framebuffer width — typically the OG 320, or wider for
// Hor+ widescreen (384 / 428 / etc., set from the display aspect).
// `fb_h` stays 200 (vertical FOV preserved). The dbuf upscale buffer
// is 2x both dimensions. Decodes the title-screen backdrop once so
// pics.blit_title_bg is a cheap memcpy on every menu frame, and sizes
// pic_cache to hold one ARGB buffer per VGAGRAPH chunk (lazily
// populated on first draw).
let build_render_ctx = (vg: const vgagraph.vgagraph_file*, pal: const uint32[],
                        fb_w: int32, fb_h: int32) ->
    let rc = alloc(render_ctx {
        fb_w = fb_w,
        fb_h = fb_h,
        screen_w = fb_w * 2,
        ui_offset_x = (fb_w - 320) / 2,
        fb = alloc(uint32[fb_w * fb_h] {})!,
        dbuf = alloc(uint32[(fb_w * 2) * (fb_h * 2)] {})!,
        zbuf = alloc(float64[fb_w] {})!,
        billboards = alloc(billboard[tilemap.max_sprites + enemies.max_enemies + projectiles.max_projectiles] {})!,
        num_billboards = 0,
        title_bg = pics.build_title_bg_cache(vg, pal, fb_w, fb_h),
        god_face = pics.build_god_face_cache(vg, pal),
        pic_cache = alloc(uint32[][vg->num_chunks] {})!,
        screenshot_slot = 0
    })!
    rc

// Resolve a view-mode preference into a concrete framebuffer width.
// Auto (0) queries the display; Original / 16:10 / 16:9 use fixed
// values from `config.view_mode_to_fb_w`. Always clamps to [320, 640]
// and rounds up to even (so the 2× upscale buffer stays a multiple
// of 2). Test-mode callers should bypass this and just use 320 — SDL
// isn't initialised in that path.
let compute_fb_w_for_view_mode = (view_mode: int32) ->
    let forced = config.view_mode_to_fb_w(view_mode)
    if forced > 0 then forced
    else
        let mut db = sdl2.rect { x = 0, y = 0, w = 0, h = 0 }
        sdl2.get_display_bounds(0, &db)
        if db.w <= 0 || db.h <= 0 then 320
        else
            let display_aspect = (float64) db.w / (float64) db.h
            let scale = display_aspect / (4.0 / 3.0)
            let mut x = (int32) (320.0 * scale)
            if x < 320 then x = 320
            if x > 640 then x = 640
            if x % 2 != 0 then x = x + 1
            x

// Apply a view-mode change on the fly. Resizes the framebuffer /
// upscale / z-buffer / title-bg cache, rescales the player's camera-
// plane vector to the new FOV magnitude, and updates `g->view_mode`.
// Returns true if the framebuffer width actually changed (caller is
// expected to re-create the SDL texture and re-set the renderer's
// logical size). The pic_cache is left intact — pic-pixel buffers
// are independent of fb_w (pics blit at native size).
let apply_view_mode = (w: world*, vg: const vgagraph.vgagraph_file*,
                       pal: const uint32[], view_mode: int32) ->
    let new_fb_w = compute_fb_w_for_view_mode(view_mode)
    let new_plane_factor = fov_factor * (float64) new_fb_w / 320.0
    let g = w->g
    let rc = w->rc
    let changed = new_fb_w != rc->fb_w
    if changed then
        // Free the old size-dependent buffers + cache, then alloc
        // fresh ones at the new dimensions.
        free(rc->fb)
        free(rc->dbuf)
        free(rc->zbuf)
        free(rc->title_bg)
        rc->fb_w = new_fb_w
        rc->screen_w = new_fb_w * 2
        rc->ui_offset_x = (new_fb_w - 320) / 2
        rc->fb = alloc(uint32[new_fb_w * rc->fb_h] {})!
        rc->dbuf = alloc(uint32[(new_fb_w * 2) * (rc->fb_h * 2)] {})!
        rc->zbuf = alloc(float64[new_fb_w] {})!
        rc->title_bg = pics.build_title_bg_cache(vg, pal, new_fb_w, rc->fb_h)
        // Rescale the player's camera plane to the new FOV magnitude
        // while preserving direction. Plane is always perpendicular
        // to dir with magnitude == plane_factor; multiplying by the
        // ratio keeps that invariant after the change.
        let scale = new_plane_factor / g->plane_factor
        g->plane_x = g->plane_x * scale
        g->plane_y = g->plane_y * scale
        g->plane_factor = new_plane_factor
    g->view_mode = view_mode
    changed

// Allocate the save/load menu cache + scratch buffers. One instance per
// process (only one save/load menu can be open at a time).
let build_save_menu_ctx = () ->
    let sm = alloc(save_menu_ctx {
        slots = alloc(save.slot_info[save.num_slots] {})!,
        label_scratch = alloc(uint8[32] {})!,
        hex_scratch = alloc(uint8[1] {})!,
        edit_buf = alloc(uint8[32] {})!,
        edit_len = 0
    })!
    sm

// Allocate the high-score context: the 7-row table seeded with id
// Software's defaults (then overlaid from `~/.wolf-fc/highscores` if
// present) plus the inline name-entry buffer. Single instance per
// process — the screen / death flow / menu all reach for it via
// `world.hs`.
let build_highscore_ctx = () ->
    let scores = alloc(highscore.entry[highscore.max_scores] {})!
    highscore.reset_to_defaults(scores)
    highscore.load(scores)
    alloc(highscore_ctx {
        scores       = scores,
        edit_index   = -1,
        edit_active  = false,
        edit_buf     = alloc(uint8[highscore.max_name_len + 1] {})!,
        edit_len     = 0,
        pending_save = false
    })!

// Allocate a level from the decoded wolf3d map data. Builds tilemap,
// spawns static sprites, and marks push-wall tiles. Caller must call
// free_level when the level is no longer needed.
let build_level = (lv_data: maps.level*, sprite_start: int32, difficulty: int32, no_dogs: bool) ->
    let lv = alloc(level {
        tilemap = alloc(uint8[map_size * map_size] {})!,
        pushwall_tiles = alloc(bool[map_size * map_size] {})!,
        exit_tiles = alloc(bool[map_size * map_size] {})!,
        path_arrows = alloc(uint8[map_size * map_size] {})!,
        sprites = alloc(tilemap.sprite_obj[tilemap.max_sprites] {})!,
        num_sprites = 0,
        doors = alloc(doors.door_obj[doors.max_doors] {})!,
        door_pos = alloc(float64[doors.max_doors] {})!,
        num_doors = 0,
        pushwall = default(pushwall.pushwall_state),
        enemies = alloc(enemies.enemy[enemies.max_enemies] {})!,
        num_enemies = 0,
        projectiles = alloc(projectiles.projectile[projectiles.max_projectiles] {})!,
        tile_areas = alloc(uint8[map_size * map_size] {})!,
        area_connect = alloc(uint8[areas.num_areas * areas.num_areas] {})!,
        area_by_player = alloc(bool[areas.num_areas] {})!,
        total_enemies = 0,
        total_pushwalls = 0,
        total_treasures = 0
    })!
    tilemap.build(lv, lv_data, sprite_start)
    spawn.sprites(lv, lv_data, sprite_start)
    spawn.mark_pushwalls(lv, lv_data)
    spawn.mark_exit_tiles(lv, lv_data)
    spawn.mark_path_arrows(lv, lv_data)
    areas.build(lv, lv_data)
    spawn.spawn_enemies(lv, lv_data, difficulty, no_dogs)
    // Tally totals for the intermission screen (enemies that are not
    // pre-dead corpses; push-wall marker tiles; treasure pickups).
    let mut enemies_live = 0
    for i in 0..lv->num_enemies
        match lv->enemies[i].state with
        | dead -> void()
        | _ -> enemies_live = enemies_live + 1
    lv->total_enemies = enemies_live
    let mut pw = 0
    for i in 0..(map_size * map_size)
        if lv->pushwall_tiles[i] then pw = pw + 1
    lv->total_pushwalls = pw
    let mut treas = 0
    for i in 0..lv->num_sprites
        match lv->sprites[i].item_type with
        | cross | chalice | bible | crown -> treas = treas + 1
        | _ -> void()
    lv->total_treasures = treas
    lv

let free_level = (lv: level*) ->
    free(lv->tilemap)
    free(lv->pushwall_tiles)
    free(lv->exit_tiles)
    free(lv->path_arrows)
    free(lv->sprites)
    free(lv->doors)
    free(lv->door_pos)
    free(lv->enemies)
    free(lv->projectiles)
    free(lv->tile_areas)
    free(lv->area_connect)
    free(lv->area_by_player)
    free(lv)

// ============================================================
// Phase / counter helpers
// ============================================================

// Mirror level totals into g and zero the current-progress counters. Called
// on every level entry (initial load, elevator transition, death restart).
let reset_level_counters = (g: game*, lv: level*) ->
    g->kills = 0
    g->secrets = 0
    g->treasures = 0
    g->total_kills = lv->total_enemies
    g->total_secrets = lv->total_pushwalls
    g->total_treasures = lv->total_treasures
    g->level_time = 0.0

// Free the current level + lv_data and load + build the level at level_num.
// Shared by every transition path (next-level / restart / new-game). After
// this runs, the player still needs position + per-level state set — caller
// does that for its specific semantics.
let reload_level_data = (w: world*, vs: const vswap.vswap_file*) ->
    free_level(w->lv)
    free(w->lv_data->walls)
    free(w->lv_data->objects)
    free(w->lv_data)
    let p_maphead = data_path.wl6(w->g->data_dir, "MAPHEAD.WL6")
    defer free(p_maphead)
    let p_gamemaps = data_path.wl6(w->g->data_dir, "GAMEMAPS.WL6")
    defer free(p_gamemaps)
    w->lv_data = maps.load(p_maphead, p_gamemaps, w->g->level_num)
    w->lv = build_level(w->lv_data, vs->sprite_start, w->g->difficulty, w->g->no_dogs)

// Clear held gameplay-input flags. Called on ack-screen exits (intermission /
// episode-end advance) so the "any key" press that dismissed the screen
// doesn't carry into playing as a held movement / fire — e.g. a ctrl-press
// to advance the episode-end screen would otherwise leave the gatling firing
// as soon as the next episode's map 0 loads.
// Advance to the next map per episode routing. Called after the intermission
// space-press on levels 0..7 and level 9; level 8 → episode-end is handled
// by `episode_end.enter` at the caller. Preserves score, lives, weapon; clears
// keys. The `went_secret` latch is consumed and reset here.
// Add the current level's kill / secret / treasure percent + time to
// the per-episode running totals. Idempotent for a given level via
// the `ep_recorded_current` latch — both intermission.enter and
// bj_victory.enter call this, but only the first one for a given
// level actually adds.
let record_level_for_episode = (g: game*) ->
    if g->ep_recorded_current then return
    let kr = if g->total_kills > 0 then 100 * g->kills / g->total_kills else 100
    let sr = if g->total_secrets > 0 then 100 * g->secrets / g->total_secrets else 100
    let tr = if g->total_treasures > 0 then 100 * g->treasures / g->total_treasures else 100
    g->ep_kr_total = g->ep_kr_total + kr
    g->ep_sr_total = g->ep_sr_total + sr
    g->ep_tr_total = g->ep_tr_total + tr
    g->ep_time_total = g->ep_time_total + (int32) g->level_time
    g->ep_levels_played = g->ep_levels_played + 1
    g->ep_recorded_current = true

// Wipe the running totals at the start of a new episode / game.
let reset_episode_totals = (g: game*) ->
    g->ep_kr_total = 0
    g->ep_sr_total = 0
    g->ep_tr_total = 0
    g->ep_time_total = 0
    g->ep_levels_played = 0
    g->ep_recorded_current = false

let advance_next_level = (w: world*, vs: const vswap.vswap_file*) ->
    let g = w->g
    // Capture the score-at-start-of-the-next-level for the OG-style
    // death-rewind. By the time we get here the just-completed
    // level's intermission bonus has already landed in `score`
    // (intermission.enter / bj_victory.enter / death_cam advance
    // all call `add_score(g, compute_level_bonus(g), ...)`), so
    // `oldscore = score` snapshots "score at the moment you walked
    // into the next level". A subsequent death on the new level
    // will rewind here in `restart_current_level`. Mirrors the
    // original game's `gamestate.oldscore = gamestate.score` set
    // in the ex_completed branch.
    g->oldscore = g->score
    g->level_num = episode.next_level_num(g->level_num, g->went_secret)
    g->went_secret = false
    // Wolf3D clears keys between levels.
    g->has_gold_key = false
    g->has_silver_key = false
    // Re-arm per-episode recording for the upcoming level.
    g->ep_recorded_current = false
    reload_level_data(w, vs)
    spawn.find_player_start(w->lv_data, g)
    reset_level_counters(g, w->lv)
    areas.update_player_area(w->lv, g)
    areas.connect(w->lv, g->area_number)
    g->phase = game_phase.playing
    g->phase_timer = 0.0
    g->made_noise = false
    player.clear_input_keys(g)
    pics.trigger_get_psyched(g)

// End-of-episode → main menu. The OG GameLoop returns from
// ex_victorious back to the control panel; players replay individual
// episodes from the menu, with no auto-advance to the next one.
// Used by the endart phase exit + by the test-mode `advance` command
// when leaving episode_end / endart.
let return_to_menu_post_episode = (g: game*) ->
    g->phase = game_phase.main_menu
    g->menu_level = menu.nav.main
    g->menu_sel = 0     // NEW GAME row — game ended, BACK TO GAME locked
    g->has_active_game = false
    g->has_gold_key = false
    g->has_silver_key = false

// Restart the current level (death with lives remaining). Resets player
// health / ammo / weapon, rewinds score to the start-of-this-level value
// (`oldscore`); decrements lives at the caller to keep the pre/post-death
// accounting legible. Score rewind matches the original game: every
// failed run forfeits the points earned within that run. The lethal
// life is handled by the caller routing to `high_scores_screen.enter`
// instead of here, so the high-scores entry sees the un-rewound score.
let restart_current_level = (w: world*, vs: const vswap.vswap_file*) ->
    let g = w->g
    g->score = g->oldscore
    // Re-arm episode recording so re-finishing the level still
    // contributes to the running totals.
    g->ep_recorded_current = false
    reload_level_data(w, vs)
    spawn.find_player_start(w->lv_data, g)
    reset_level_counters(g, w->lv)
    player.reset_for_life(g)
    areas.update_player_area(w->lv, g)
    areas.connect(w->lv, g->area_number)
    g->phase = game_phase.playing
    g->phase_timer = 0.0
    // Seed the respawn uncover: the new scene renders under a full red
    // stipple that thins out rapidly, rather than a hard cut to gameplay.
    g->respawn_fade_timer = player.respawn_fade_time
    pics.trigger_get_psyched(g)

// Start a new game at the current level_num (set by the episode picker).
// Resets player state (3 lives, score 0, full HP, pistol 8 ammo) +
// rebuilds the level + clears per-episode running totals.
let start_new_game_here = (w: world*, vs: const vswap.vswap_file*) ->
    let g = w->g
    reset_episode_totals(g)
    reload_level_data(w, vs)
    spawn.find_player_start(w->lv_data, g)
    reset_level_counters(g, w->lv)
    player.reset_for_new_game(g)
    // reset_for_new_game zeros `score`; mirror that into `oldscore`
    // so the death-rewind has a sane baseline (rewinds to 0, not
    // whatever score the previous game ended on).
    g->oldscore = 0
    // Consume the BOSS FIGHT latch: teleport to the boss if the map has one.
    // Done after spawn.find_player_start + reset_level_counters so the teleport
    // overrides the map's default spawn while the level state is otherwise
    // fresh. areas.update_player_area / areas.connect below anchor the flood to
    // the post-teleport tile.
    if g->want_near_boss then
        spawn.near_boss(w->lv, g)
        g->want_near_boss = false
    areas.update_player_area(w->lv, g)
    areas.connect(w->lv, g->area_number)
    g->phase = game_phase.playing
    g->phase_timer = 0.0
    g->went_secret = false
    pics.trigger_get_psyched(g)

// Game-state phase transitions triggered by timers / flags. Called every
// frame from both the interactive loop and (between test commands) the
// test-mode scripted play. Returns true if a level reload happened — the
// caller uses that to refresh level-bound audio (new music).
//
// Order matters:
//   1. Elevator flag    -> enter intermission (freezes gameplay)
//   2. Death timer up   -> restart level (lives left) or high-scores
//                          screen (lives exhausted)
// Intermission / high-scores ack keys are handled by the caller (they
// need input access), not by this function.
let update_phase_transitions = (w: world*, vs: const vswap.vswap_file*) ->
    let g = w->g
    let mut level_changed = false
    if g->next_level && g->phase == game_phase.playing
       && g->next_level_delay <= 0.0 then
        g->next_level = false
        // Boss-map exits route through BJ victory; everything else goes
        // through the regular intermission → advance flow. In normal
        // play boss maps fire BJ via the EXITTILE check in player.update
        // (which doesn't set next_level), so this branch is reached only
        // by the synthetic `endepisode` test command on a boss map.
        if g->level_num % episode.levels_per == 8 then
            bj_victory.enter(g, w->ac)
        else
            intermission.enter(g, w->ac)
    if g->phase == game_phase.dying && g->phase_timer >= player.death_anim_time then
        if g->lives > 0 then
            g->lives = g->lives - 1
            restart_current_level(w, vs)
            level_changed = true
        else
            // Out of lives: route through the high-scores screen,
            // matching the OG's `case ex_died: ... CheckHighScore;
            // return;` flow. The screen handles the score insertion +
            // optional name entry; on dismiss it routes back to the
            // title (see the high_scores keydown handler in the main
            // loop). The level is intentionally NOT reloaded — the
            // next NEW GAME / LOAD GAME will rebuild as needed.
            high_scores_screen.enter(g, w->hs, high_scores_screen.from_death,
                g->score, g->level_num + 1, g->level_num / episode.levels_per)
            g->has_active_game = false
    // Death-cam cutscene has finished its replay hold; hand off
    // straight to the episode-end Victory screen — the OG GameLoop's
    // `ex_victorious` case skips `LevelCompleted()` (the per-level
    // tally), so the boss kill jumps directly from cutscene to
    // Victory(). Mirror the bj_victory finalisation: award the
    // level-completion bonus and record the boss level into the
    // per-episode totals so it shows up in the averages.
    if g->phase == game_phase.death_cam && g->dc_sub == death_cam.sub.done then
        add_score(g, intermission.compute_level_bonus(g), w->ac)
        record_level_for_episode(g)
        episode_end.enter(g)
    // PG-13 splash auto-advances to the title after a short hold so a
    // walked-away player doesn't come back to a stuck splash. Any keypress
    // also advances (handled in the main loop, not here).
    if g->phase == game_phase.pg13 && g->phase_timer >= pg13_screen.auto_advance_time then
        g->phase = game_phase.title
        g->phase_timer = 0.0
    level_changed
// One simulation tick — runs all per-frame game-state updates in order.
// Used by both the interactive game loop and the headless test mode so
// they stay in sync. Add new per-frame systems here, not at each caller.
let tick = (w: world*, dt: float64) ->
    let g = w->g
    // Damage flash and respawn fade decay every frame regardless of phase.
    if g->damage_flash_timer > 0.0 then
        g->damage_flash_timer = g->damage_flash_timer - dt
        if g->damage_flash_timer < 0.0 then g->damage_flash_timer = 0.0
    if g->respawn_fade_timer > 0.0 then
        g->respawn_fade_timer = g->respawn_fade_timer - dt
        if g->respawn_fade_timer < 0.0 then g->respawn_fade_timer = 0.0
    // Same for the message-banner timer.
    if g->msg_timer > 0.0 then
        g->msg_timer = g->msg_timer - dt
        if g->msg_timer < 0.0 then g->msg_timer = 0.0
    // "Got Gatling!" face swap decays regardless of phase — the face cell
    // keeps refreshing even during frozen phases, and the original's
    // SD_SoundPlaying check is timer-based here.
    if g->got_gatling_timer > 0.0 then
        g->got_gatling_timer = g->got_gatling_timer - dt
        if g->got_gatling_timer < 0.0 then g->got_gatling_timer = 0.0
    // Outside playing only phase_timer advances + the phase-transition
    // handler runs (so death collapse → restart, etc. can fire). Enemies,
    // doors, pickups, weapon, player: all frozen.
    match g->phase with
    | playing ->
        // "GET PSYCHED!" load overlay: freeze everything while visible so
        // the player can't walk into a wall on the first frame after a
        // level transition. Processed before `next_level` so a player who
        // hits the elevator during the overlay (impossible, but defensive)
        // still sees the level-done flow resume cleanly once it finishes.
        if g->get_psyched_timer > 0.0 then
            g->get_psyched_timer = g->get_psyched_timer - dt
            if g->get_psyched_timer < 0.0 then g->get_psyched_timer = 0.0
        // Elevator-switch pre-intermission wait: freeze all gameplay for
        // `next_level_delay` seconds so LEVELDONESND plays out in the world
        // before the tally screen takes over. update_phase_transitions
        // won't enter the intermission phase until the delay has elapsed.
        // We keep gameplay frozen for the whole `next_level` window (even
        // on the tick where delay reaches 0) so the phase transition fires
        // cleanly at end of tick without one stray gameplay frame sneaking
        // in.
        else if g->next_level then
            if g->next_level_delay > 0.0 then
                g->next_level_delay = g->next_level_delay - dt
                if g->next_level_delay < 0.0 then g->next_level_delay = 0.0
            // Even with the rest of gameplay frozen, dying actors keep
            // animating so anything mid-die when the elevator switch fired
            // finishes its death cascade before the tally screen.
            enemies.ai.update_dying_enemies(w->lv, w->g, dt)
        else
            // The original's PlayLoop resets madenoise at the top of each
            // frame; we follow suit so noise from one tick only wakes
            // enemies on the same tick. update_weapon raises it again when
            // the player fires a gun, and enemies.ai.damage_enemy raises
            // it on a knife hit.
            g->made_noise = false
            g->level_time = g->level_time + dt
            player.update(w->lv, g, dt, w->ac)
            doors.update(w->lv, g, dt, w->ac, player.radius)
            pushwall.update(w->lv, dt)
            player.update_weapon(w, dt)
            enemies.ai.update_enemies(w, dt)
            projectiles.update_all(w->lv, g, w->ac, dt)
            pickups.check(w->lv, g, w->ac)
            hud.update_face(g, dt)
    | _ ->
        g->phase_timer = g->phase_timer + dt
        if g->phase == game_phase.title
                && g->phase_timer >= title_screen.cycle_total then
            g->phase_timer = g->phase_timer - title_screen.cycle_total
        if g->phase == game_phase.dying then
            // Swing the heading toward whoever just killed us, like
            // the original's death rotation. No-op once aligned (or
            // when no killer was latched, e.g. the synthetic `kill`
            // test command).
            player.update_death_swing(g, dt)
        else if g->phase == game_phase.intermission then
            intermission.tick(g, w->ac, dt)
        else if g->phase == game_phase.bj_victory then
            bj_victory.tick(w->lv, g, w->ac, dt)
            // Boss corpse + any other dying actors keep animating during
            // the BJ run so the player sees the death animation finish
            // (not just the first die frame freeze-framed under BJ).
            enemies.ai.update_dying_enemies(w->lv, w->g, dt)
        else if g->phase == game_phase.death_cam then
            // Pump the dying boss's animation frames before the phase
            // logic inspects e->state — death_cam.sub.pre_fade and
            // death_cam.sub.replay_hold both advance on the die → dead
            // transition, so the tick order matters.
            enemies.ai.update_dying_enemies(w->lv, w->g, dt)
            death_cam.tick(w->lv, g, w->ac, dt)
    // Phase transitions (death collapse → restart / game-over). Main loop
    // layers music switching on top of this; test mode doesn't need music
    // so it can ignore the return value.
    let _changed = update_phase_transitions(w, w->ac->vs)

// Render the full game frame to fb (used before saving a screenshot).
let render_frame = (w: world*, vs: const vswap.vswap_file*, pal: const uint32[]) ->
    match w->g->phase with
    | pg13 ->
        pg13_screen.render(w->rc, w->vg, pal)
        overlay.upscale_2x(w->rc)
        return
    | title ->
        title_screen.render(w->rc, w->vg, pal, w->font, w->hs, w->g->phase_timer)
        overlay.upscale_2x(w->rc)
        return
    | main_menu ->
        menu.render_main(w->rc, w->sm, w->vg, pal, w->font, w->g, w->ac)
        overlay.upscale_2x(w->rc)
        return
    | intermission ->
        intermission.render(w->rc, w->vg, pal, w->g)
        overlay.upscale_2x(w->rc)
        return
    | episode_end ->
        episode_end.render(w->rc, w->vg, pal, w->font, w->g)
        overlay.upscale_2x(w->rc)
        return
    | endart ->
        endart_screen.render(w->rc, w->vg, pal, w->font, w->g)
        overlay.upscale_2x(w->rc)
        return
    | high_scores ->
        high_scores_screen.render(w->rc, w->vg, pal, w->font, w->hs, w->g->phase_timer)
        overlay.upscale_2x(w->rc)
        return
    | death_cam ->
        // Pre-clear fb's top region: low-res viewport overlays (banner
        // text, etc.) draw into fb at alpha=0xFF; the composite step
        // skips alpha=0 sentinel pixels so the high-res raycaster
        // content shows through everywhere else.
        overlay.clear_view_sentinel(w->rc)
        death_cam.render(w, vs, pal, w->vg)
        hud.render(w->rc, w->vg, pal, w->g)
        overlay.composite_view_overlay(w->rc)
        overlay.composite_hud(w->rc)
        return
    | _ -> void()
    // 3D phases (playing / dying / bj_victory): raycaster and viewport
    // effects render at high vertical resolution directly into dbuf;
    // HUD and low-res viewport overlays go to fb and are composited
    // afterward.
    overlay.clear_view_sentinel(w->rc)
    raycaster.render_walls(w->lv, w->rc, w->g, vs, pal)
    billboards.build(w->lv, w->rc, w->g, vs->sprite_start)
    billboards.render(w->rc, w->g, vs, pal)
    player.render_weapon(w->rc, vs, pal, w->g)
    // Damage / death red overlays — applied over the 3D view, under the HUD.
    // Phase-filtered renderers above return early, so this block only runs
    // during playing or dying. Damage flash is a brief uniform alpha
    // blend; the longer death + respawn transitions use a spatial-hash
    // stipple so the scene fills / clears as speckled grains of red.
    let red_tint = 0x00C00000u32
    let flash_a = if w->g->damage_flash_timer > 0.0 then
        w->g->damage_flash_timer / player.damage_flash_time * 0.45
    else 0.0
    if flash_a > 0.0 then overlay.viewport_tint(w->rc, red_tint, flash_a)
    let stipple_progress = match w->g->phase with
    | dying ->
        // Ramp 0 → 1 over player.death_fade_time, then hold at 1 until
        // player.death_anim_time elapses and the phase transition fires.
        let t = w->g->phase_timer / player.death_fade_time
        if t > 1.0 then 1.0 else t
    | _ ->
        // Quick uncover back to the new scene on respawn.
        if w->g->respawn_fade_timer > 0.0 then
            w->g->respawn_fade_timer / player.respawn_fade_time
        else 0.0
    overlay.dissolve_stipple(w->rc, red_tint, stipple_progress)
    hud.render(w->rc, w->vg, pal, w->g)
    hud.render_message(w->rc, w->font, w->g)
    // "GET PSYCHED!" level-entry overlay. The original fills the 3D
    // viewport with VIEWCOLOR (palette 0x7f), draws the pic centered, and
    // paints a progress bar across the bottom of the pic frame. We
    // replicate the same layout and animate the bar 0→100% over the hold
    // duration so the static "always-full" look of wolf4sdl's simplified
    // port still reads as genuine progress. Drawn AFTER hud.render so the
    // status bar stays visible underneath, matching the original.
    if w->g->get_psyched_timer > 0.0 then
        pics.render_get_psyched_overlay(w->rc, w->vg, pal,
            w->g->get_psyched_timer, pics.get_psyched_time)
    overlay.composite_view_overlay(w->rc)
    overlay.composite_hud(w->rc)
    // Pre-intermission fade-to-black: while `next_level` is latched and
    // gameplay is frozen, darken the entire frame linearly as next_level_delay
    // ticks down. Gives the player immediate visual feedback that the
    // elevator/boss activation registered, rather than a silent 1s hitch
    // followed by a sudden jump to the tally screen. Applied AFTER
    // composite so both viewport and HUD fade as one unit.
    if w->g->next_level && player.elevator_wait_time > 0.0 then
        let frac = 1.0 - w->g->next_level_delay / player.elevator_wait_time
        let alpha = if frac < 0.0 then 0.0 else if frac > 1.0 then 1.0 else frac
        overlay.dbuf_tint_full(w->rc, 0x000000u32, alpha)


// ============================================================
// Headless test mode — scripted commands for automated testing
// ============================================================

let run_test_cmd = (w: world*, arg: const str, pal: const uint32[], dt: float64) ->
    let g = w->g
    let bad = (expected: const str) ->
        io.write("bad arg '%s{arg}': expected %s{expected}\n", stderr)
        void()
    if text.starts_with(arg, "fwd:") then
        match text.parse_int32(arg[4..arg.len]) with
        | some(n) ->
            g->key_up = true
            for j in 0..n
                tick(w, dt)
            g->key_up = false
        | none -> bad("integer tick count")
    else if text.starts_with(arg, "back:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            g->key_down = true
            for j in 0..n
                tick(w, dt)
            g->key_down = false
        | none -> bad("integer tick count")
    else if text.starts_with(arg, "turnr:") then
        match text.parse_int32(arg[6..arg.len]) with
        | some(deg) -> player.rotate_camera(g, 0.0 - (float64) deg * 3.14159265 / 180.0)
        | none -> bad("integer degrees")
    else if text.starts_with(arg, "turnl:") then
        match text.parse_int32(arg[6..arg.len]) with
        | some(deg) -> player.rotate_camera(g, (float64) deg * 3.14159265 / 180.0)
        | none -> bad("integer degrees")
    else if arg == "run" then
        g->key_shift = !g->key_shift
    else if text.starts_with(arg, "goto:") then
        let coords = text.split(arg[5..arg.len], ",")
        if coords.len >= 2 then
            match text.parse_int32(coords[0]) with
            | some(tx) ->
                match text.parse_int32(coords[1]) with
                | some(ty) ->
                    g->pos_x = (float64) tx + 0.5
                    g->pos_y = (float64) ty + 0.5
                | none -> bad("integer Y coordinate")
            | none -> bad("integer X coordinate")
        else bad("X,Y coordinate pair")
        free(coords)
        pickups.check(w->lv, g, w->ac)
        // Teleporting bypasses door traversal, so the player's area + the
        // door-connectivity flood would otherwise stay anchored to the spawn
        // area. Recompute both, equivalent to "treat the jump as if the
        // player legally walked here through every open door."
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)
    else if text.starts_with(arg, "sethp:") then
        match text.parse_int32(arg[6..arg.len]) with
        | some(n) -> g->health = n
        | none -> bad("integer HP value")
    else if text.starts_with(arg, "setweapon:") then
        match text.parse_int32(arg[10..arg.len]) with
        | some(n) -> g->weapon = n
        | none -> bad("integer weapon index (0-3)")
    else if text.starts_with(arg, "setammo:") then
        match text.parse_int32(arg[8..arg.len]) with
        | some(n) -> g->ammo = n
        | none -> bad("integer ammo count")
    else if arg == "fire" then
        g->key_fire = true
        tick(w, dt)
        g->key_fire = false
    else if arg == "facetile" then
        let fx = (int32) (g->pos_x + g->dir_x)
        let fy = (int32) (g->pos_y + g->dir_y)
        let ft = if fx >= 0 && fx < map_size && fy >= 0 && fy < map_size then
            (int32) w->lv->tilemap[(int64) fx * 64 + (int64) fy]
        else -1
        let nl = if g->next_level then 1 else 0
        io.write("facing=(%d{fx},%d{fy}) tile=%d{ft} next_level=%d{nl}\n", stdout)
        void()
    else if arg == "givekeys" then
        g->has_gold_key = true
        g->has_silver_key = true
    else if arg == "mli" then
        // Direct-fire the M+L+I cheat effect. In interactive play this is
        // triggered by holding those three keys; test mode has no keyboard,
        // so scripted scenarios invoke the effect through this command.
        player.cheats.apply_mli(g)
    else if arg == "bat" then
        player.cheats.apply_bat(g)
    else if arg == "iddqd" then
        // Trigger the IDDQD god-mode toggle directly without having to
        // pipe the full I-D-D-Q-D sequence through the key event path.
        player.cheats.apply_iddqd(g)
    else if arg == "idkfa" then
        // Trigger the IDKFA toggle directly (see apply_iddqd comment).
        player.cheats.apply_idkfa(g)
    else if arg == "psyched" then
        // Force the GET PSYCHED overlay timer so a following ss: captures
        // the full-screen load graphic. Bypasses the normal test_mode gate
        // in pics.trigger_get_psyched.
        g->get_psyched_timer = pics.get_psyched_time
    else if arg == "gotgatling" then
        // Force the GOTGATLINGPIC face-cell swap so ss: can capture it.
        // Bypasses test_mode. The pic replaces the BJ face in hud.render
        // while the timer is active.
        g->got_gatling_timer = hud.got_gatling_time
    else if arg == "space" then
        g->key_space = true
        g->key_space_handled = false
        tick(w, dt)
        g->key_space = false
        g->key_space_handled = false
    else if text.starts_with(arg, "wait:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            for j in 0..n
                tick(w, dt)
        | none -> bad("integer tick count")
    else if text.starts_with(arg, "ss:") then
        render_frame(w, w->ac->vs, pal)
        overlay.save_png(w, arg[3..arg.len])
        io.write("Saved %s{arg[3..arg.len]}\n", stdout)
        void()
    else if arg == "state" then
        io.write("pos=(%8.4f{g->pos_x}, %8.4f{g->pos_y}) dir=(%8.4f{g->dir_x}, %8.4f{g->dir_y})\n", stdout)
        io.write("health=%d{g->health} ammo=%d{g->ammo} score=%d{g->score} lives=%d{g->lives} level=%d{g->level_num} weapon=%d{g->weapon} best=%d{g->best_weapon}\n", stdout)
        let gk = if g->has_gold_key then 1 else 0
        let sk = if g->has_silver_key then 1 else 0
        let gm = if g->god_mode then 1 else 0
        let ik = if g->idkfa_mode then 1 else 0
        io.write("keys: gold=%d{gk} silver=%d{sk} god=%d{gm} idkfa=%d{ik}\n", stdout)
        void()
    else if arg == "counters" then
        // Kill / secret / treasure counters + level time / par / phase.
        let phase_s = match g->phase with
        | pg13         -> "pg13"
        | title        -> "title"
        | main_menu    -> "menu"
        | playing      -> "playing"
        | dying        -> "dying"
        | intermission -> "intermission"
        | bj_victory   -> "bj_victory"
        | death_cam    -> "death_cam"
        | episode_end  -> "episode_end"
        | endart       -> "endart"
        | high_scores  -> "high_scores"
        let par = if g->level_num < 60 then intermission.par_times[g->level_num] else 0
        io.write("phase=%s{phase_s} difficulty=%d{g->difficulty}\n", stdout)
        io.write("kills=%d{g->kills}/%d{g->total_kills} secrets=%d{g->secrets}/%d{g->total_secrets} treasures=%d{g->treasures}/%d{g->total_treasures}\n", stdout)
        io.write("time=%6.2f{g->level_time} par=%d{par}\n", stdout)
        void()
    else if text.starts_with(arg, "vgrender:") then
        // Render one VGAGRAPH pic to the framebuffer and take a screenshot.
        // Syntax: vgrender:CHUNK,OUTFILE.png — top-left aligned, unscaled.
        let rest = arg[9..arg.len]
        let parts = text.split(rest, ",")
        if parts.len >= 2 then
            match text.parse_int32(parts[0]) with
            | some(n) ->
                // Clear the fb black first so metadata is obvious.
                for i in 0..(w->rc->fb_w * game_h)
                    w->rc->fb[i] = 0xFF000000u32
                pics.draw(w->rc, w->vg, pal, n, 0, 0)
                png.write(parts[1], w->rc->fb, w->rc->fb_w, game_h, "vg")
                io.write("Saved %s{parts[1]}\n", stdout)
                void()
            | none -> bad("integer chunk number")
        else bad("CHUNK,PATH.png")
        free(parts)
    else if text.starts_with(arg, "vgrenderfont:") then
        // Render the entire font ASCII range onto the fb and save. Useful
        // for verifying the font loader extracts correct glyphs.
        for i in 0..(w->rc->fb_w * game_h)
            w->rc->fb[i] = 0xFF000000u32
        let mut py = 8
        let mut px = 8
        for ch in 32..127
            let adv = font.draw_char(w->rc, w->font, px, py, ch, 0xFFFFFFFFu32)
            px = px + adv + 1
            if px > w->rc->fb_w - 16 then
                px = 8
                py = py + w->font->height + 2
        png.write(arg[13..arg.len], w->rc->fb, w->rc->fb_w, game_h, "font")
        io.write("Saved %s{arg[13..arg.len]}\n", stdout)
        void()
    else if text.starts_with(arg, "vginfo:") then
        // Dump the dimensions of one VGAGRAPH chunk (pic). Useful to verify
        // the decoder produces sane widths/heights after the Huffman expand.
        match text.parse_int32(arg[7..arg.len]) with
        | some(n) ->
            let pw = vgagraph.pic_width(w->vg, n)
            let ph = vgagraph.pic_height(w->vg, n)
            let off = if n < w->vg->num_chunks then w->vg->offsets[n] else -1i64
            io.write("vgchunk %d{n}: offset=%d{off} width=%d{pw} height=%d{ph}\n", stdout)
            void()
        | none -> bad("integer chunk number")
    else if arg == "vgtable" then
        // Dump the entire picture-dimensions table (STRUCTPIC / chunk 0).
        for i in 0..w->vg->num_pics
            let pw = w->vg->pic_dims[i].width
            let ph = w->vg->pic_dims[i].height
            if pw > 0 || ph > 0 then
                let ch = i + vgagraph.start_pics
                io.write("pic %d{ch}: %d{pw}x%d{ph}\n", stdout)
        void()
    else if arg == "level_stats" then
        // Dump total enemy/pushwall/treasure counts as counted by build_level.
        io.write("level_stats: enemies=%d{w->lv->total_enemies} pushwalls=%d{w->lv->total_pushwalls} treasures=%d{w->lv->total_treasures}\n", stdout)
        void()
    else if arg == "advance" then
        // Simulates the "press space" that dismisses an intermission /
        // game-over / episode-end / victory screen. Test-mode equivalent of
        // the interactive space-bar path, but collapses animation-skip +
        // advance into one step so scripted tests don't need two hops.
        if g->phase == game_phase.intermission then
            if g->inter_stage < 4 then intermission.finish_anim(g)
            if g->level_num % episode.levels_per == 8 then
                episode_end.enter(g)
            else
                advance_next_level(w, w->ac->vs)
        else if g->phase == game_phase.bj_victory then
            // BJ cutscene collapses straight to the episode-end screen.
            // Interactive mode auto-advances on its own after the final
            // hold, but tests skip to the end so scripted sequences don't
            // need to pad with wait:200.
            episode_end.enter(g)
        else if g->phase == game_phase.death_cam then
            // Death-cam collapses straight to the episode-end screen,
            // mirroring the natural death_cam.sub.done transition (which
            // skips intermission for boss kills, matching the OG
            // GameLoop's `ex_victorious` case).
            add_score(g, intermission.compute_level_bonus(g), w->ac)
            record_level_for_episode(g)
            episode_end.enter(g)
        else if g->phase == game_phase.episode_end then
            // Test-mode advance from episode_end → endart, matching the
            // interactive ack flow. Use `endartnext` / `endart_state` to
            // step pages within the article.
            let ep = g->level_num / episode.levels_per
            endart_screen.enter(g, w->vg, ep)
        else if g->phase == game_phase.endart then
            // Test-mode advance from endart → high-scores screen,
            // matching the interactive Esc / past-last-page flow
            // (which routes through CheckHighScore in the OG's
            // Victory() before returning to the menu).
            let ep = g->level_num / episode.levels_per
            high_scores_screen.enter(g, w->hs, high_scores_screen.from_endart,
                g->score, g->level_num + 1, ep)
        else if g->phase == game_phase.high_scores then
            // Test-mode advance from high-scores → its source's
            // dismissal target. Death / endart flows return to the
            // title screen (matching the OG's DemoLoop cycle); the
            // View Scores menu entry returns to the main menu.
            // Commits any pending name buffer first so a script that
            // types into hs_name + advance behaves the same as the
            // interactive Enter (which commits + dismisses in one).
            if w->hs->edit_active then
                high_scores_screen.commit_name(w->hs)
            high_scores_screen.dismiss(g, w->hs)
    else if text.starts_with(arg, "setdifficulty:") then
        // Set difficulty + fully rebuild the current level so spawn filtering
        // reflects it. Useful for testing tier gating (base/+36/+72 tiles).
        match text.parse_int32(arg[14..arg.len]) with
        | some(n) ->
            g->difficulty = if n < 0 then 0 else if n > 3 then 3 else n
            // Re-run spawn.spawn_enemies on the existing level. Since difficulty
            // only affects which plane-1 enemy tiles spawn, we can clear
            // lv->num_enemies and re-scan without rebuilding the tilemap.
            w->lv->num_enemies = 0
            spawn.spawn_enemies(w->lv, w->lv_data, g->difficulty, g->no_dogs)
            // Recount total_enemies so the counters tally correctly.
            let mut alive = 0
            for i in 0..w->lv->num_enemies
                match w->lv->enemies[i].state with
                | dead -> void()
                | _ -> alive = alive + 1
            w->lv->total_enemies = alive
            g->total_kills = alive
            g->kills = 0
        | none -> bad("integer difficulty 0-3")
    else if text.starts_with(arg, "setlevel:") then
        match text.parse_int32(arg[9..arg.len]) with
        | some(n) ->
            if n < 0 || n >= 60 then bad("level 0..59")
            else
                g->level_num = n
                g->oldscore = g->score   // pin start-of-level for death rewind
                reload_level_data(w, w->ac->vs)
                spawn.find_player_start(w->lv_data, g)
                reset_level_counters(g, w->lv)
                areas.update_player_area(w->lv, g)
                areas.connect(w->lv, g->area_number)
                g->phase = game_phase.playing
                g->phase_timer = 0.0
        | none -> bad("integer level")
    else if text.starts_with(arg, "setepisode:") then
        // Jump to the start of episode N (level = N*10), preserving
        // score/lives. Wrapper around setlevel.
        match text.parse_int32(arg[11..arg.len]) with
        | some(n) ->
            if n < 0 || n >= episode.count then bad("episode 0..5")
            else
                g->level_num = n * episode.levels_per
                g->oldscore = g->score   // pin start-of-level for death rewind
                reload_level_data(w, w->ac->vs)
                spawn.find_player_start(w->lv_data, g)
                reset_level_counters(g, w->lv)
                areas.update_player_area(w->lv, g)
                areas.connect(w->lv, g->area_number)
                g->phase = game_phase.playing
                g->phase_timer = 0.0
        | none -> bad("integer episode 0..5")
    else if text.starts_with(arg, "save:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            if n < 0 || n >= save.num_slots then bad("slot 0..%d{save.num_slots - 1}")
            else
                // Test-mode save uses the auto-generated label (empty
                // string triggers the "E<ep>M<lvl>" fallback).
                save.to_slot(w, n, "")
                io.write("saved slot %d{n}\n", stdout)
                void()
        | none -> bad("integer slot")
    else if text.starts_with(arg, "load:") then
        match text.parse_int32(arg[5..arg.len]) with
        | some(n) ->
            if n < 0 || n >= save.num_slots then bad("slot 0..%d{save.num_slots - 1}")
            else
                let ok = save.from_slot(w, w->ac->vs, n)
                io.write("load slot %d{n}: %s{if ok then "ok" else "failed"}\n", stdout)
                void()
        | none -> bad("integer slot")
    else if arg == "listsaves" then
        // Dump the on-disk save slots (label + level + score).
        save.refresh_slots(w->sm)
        for i in 0..save.num_slots
            let s = &w->sm->slots[i]
            if s->empty then
                io.write("slot %d{i}: EMPTY\n", stdout)
                void()
            else
                let ep = s->level_num / episode.levels_per + 1
                let lvl = s->level_num % episode.levels_per + 1
                let lbl_chars = if s->label.len > 0 then s->label else default(uint8[])
                io.write("slot %d{i}: E%d{ep}M%d{lvl} diff=%d{s->difficulty} score=%d{s->score} label=", stdout)
                if lbl_chars.len > 0 then io.write(lbl_chars, stdout)
                io.write("\n", stdout)
                void()
        void()
    else if arg == "endepisode" then
        // Force the episode-end path: sets next_level on level 8 of the
        // current episode so the intermission → episode-end flow runs.
        g->next_level = true
    else if arg == "kill" then
        // Instant-kill the player (skips the pain sound, goes straight to
        // dying). Mostly used by the regression suite to exercise the
        // death → restart → game-over flow without waiting for the enemy
        // AI to roll a lethal hit. Leaves killer_active false, so the
        // dying-phase camera swing is a no-op.
        g->health = 0
        g->phase = game_phase.dying
        g->phase_timer = 0.0
        g->killer_active = false
        sfx.trigger(sfx.id.death_1, w->ac)
    else if text.starts_with(arg, "killby:") then
        // Like `kill`, but latches a killer position so the dying-phase
        // camera swing has a target to rotate toward. Args are world
        // coordinates: "killby:32.5,57.5".
        let body = arg[7..arg.len]
        let mut comma = -1i64
        for i in 0..body.len
            if body[i] == 0x2C then    // ','
                comma = i
                break
        if comma <= 0 || comma >= body.len - 1 then bad("X,Y world coords")
        else
            match text.parse_float64(body[0..comma]) with
            | some(kx) ->
                match text.parse_float64(body[comma+1..body.len]) with
                | some(ky) ->
                    g->health = 0
                    g->phase = game_phase.dying
                    g->phase_timer = 0.0
                    g->killer_x = kx
                    g->killer_y = ky
                    g->killer_active = true
                    sfx.trigger(sfx.id.death_1, w->ac)
                | none -> bad("X,Y world coords")
            | none -> bad("X,Y world coords")
    else if text.starts_with(arg, "killenemy:") then
        // Instant-kill enemy by index (matches enemylist's [N] order).
        // Routes through enemies.ai.damage_enemy with an HP-clearing damage value so
        // score / kills / drops fire the same way a real bullet would.
        match text.parse_int32(arg[10..arg.len]) with
        | some(n) ->
            if n < 0 || n >= w->lv->num_enemies then bad("enemy index out of range")
            else
                let e = &w->lv->enemies[n]
                enemies.ai.damage_enemy(w->lv, g, w->ac, e, n, e->hp + 1, w->ac->vs->sprite_start)
        | none -> bad("integer enemy index")
    else if text.starts_with(arg, "setphase:") then
        // Force a phase transition for test-mode screenshot coverage.
        let p = arg[9..arg.len]
        if p == "pg13" then
            g->phase = game_phase.pg13
            g->phase_timer = 0.0
        else if p == "title" then g->phase = game_phase.title
        else if p == "menu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.main
        else if p == "diffmenu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.difficulty
        else if p == "epmenu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.episode
        else if p == "soundmenu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.sound
        else if p == "optionsmenu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.options
        else if p == "savemenu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.savelist
            save.refresh_slots(w->sm)
        else if p == "loadmenu" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.loadlist
            save.refresh_slots(w->sm)
        else if p == "quitprompt" then
            g->phase = game_phase.main_menu
            g->menu_level = menu.nav.quit
            g->quit_prompt_idx = 0     // deterministic for screenshots
        else if p == "playing" then g->phase = game_phase.playing
        else if p == "endart" then
            // Enter the per-episode ending article for whichever
            // episode the current level belongs to. The article is
            // already loaded by enter(); tests can drive it via
            // `endartnext` to step pages or `advance` to skip.
            let ep = g->level_num / episode.levels_per
            endart_screen.enter(g, w->vg, ep)
        else if p == "viewscores" then
            // High-scores screen reached via the View Scores main-
            // menu entry. Pure display — no insertion, no edit.
            high_scores_screen.enter(g, w->hs, high_scores_screen.from_menu,
                -1, 0, 0)
        else bad("pg13/title/menu/epmenu/diffmenu/soundmenu/optionsmenu/savemenu/loadmenu/playing/endart/viewscores")
    else if arg == "endartnext" then
        // Step one page in the endart article. Past the last page
        // this is a no-op — matches the interactive forward-past-last
        // behaviour (only Esc / `endartexit` actually leaves the
        // article).
        if g->phase == game_phase.endart then
            endart_screen.next_page(g)
    else if arg == "endartexit" then
        // Simulate Esc on the endart article: returns to the main
        // menu (the only way out of the article in the OG flow).
        if g->phase == game_phase.endart then
            return_to_menu_post_episode(g)
    else if arg == "endart_state" then
        // Dump current article state (page + total). Useful for tests
        // that want to verify the parser found N pages.
        io.write("endart page=%d{g->endart_page + 1} of %d{g->endart_total_pages}\n", stdout)
        void()
    else if text.starts_with(arg, "hs_qualify:") then
        // Drive the high-scores entry path with a synthetic
        // (score, completed-level, episode) triple. Sets up the
        // screen exactly the same way a real death would, so the
        // editor + insert behaviour can be exercised without faking
        // a 4-life death sequence.
        // Syntax: hs_qualify:SCORE,LEVEL1IDX,EPISODE
        let parts = text.split(arg[11..arg.len], ",")
        if parts.len >= 3 then
            let parse = (s: const str) ->
                match text.parse_int32(s) with
                | some(v) -> v
                | none -> 0
            let sc = parse(parts[0])
            let lv = parse(parts[1])
            let ep = parse(parts[2])
            high_scores_screen.enter(g, w->hs, high_scores_screen.from_death, sc, lv, ep)
        else bad("SCORE,LEVEL,EPISODE")
        free(parts)
    else if text.starts_with(arg, "hs_name:") then
        // Type a literal name into the high-scores edit buffer (replaces
        // any previously-typed bytes). Only meaningful while the screen
        // is in edit mode — does nothing otherwise. Followed by `advance`
        // to commit + dismiss.
        if w->hs->edit_active then
            let nm = arg[8..arg.len]
            for k in 0..(int32) w->hs->edit_buf.len
                w->hs->edit_buf[(int64) k] = 0u8
            let mut n = (int32) nm.len
            if n > highscore.max_name_len then n = highscore.max_name_len
            for k in 0..n
                w->hs->edit_buf[(int64) k] = nm[(int64) k]
            w->hs->edit_len = n
    else if arg == "hs_state" then
        // Dump every row of the high-scores table + the current edit
        // state. Useful for verifying default content + post-insert
        // shifts.
        let edit = if w->hs->edit_active then 1 else 0
        io.write("hs edit=%d{edit} index=%d{w->hs->edit_index}", stdout)
        if w->hs->edit_active then
            let typed = (const str) w->hs->edit_buf[0..(int64) w->hs->edit_len]
            io.write(" typed='", stdout)
            if typed.len > 0 then io.write(typed, stdout)
            io.write("'", stdout)
        io.write("\n", stdout)
        for i in 0..highscore.max_scores
            let e = &w->hs->scores[i]
            let nm = highscore.name_str(e)
            io.write("score[%d{i}] %d{e->score} L%d{e->completed} E%d{e->episode + 1} ", stdout)
            if nm.len > 0 then io.write(nm, stdout)
            io.write("\n", stdout)
        void()
    else if arg == "phase" then
        let phase_s = match g->phase with
        | pg13         -> "pg13"
        | title        -> "title"
        | main_menu    -> "menu"
        | playing      -> "playing"
        | dying        -> "dying"
        | intermission -> "intermission"
        | bj_victory   -> "bj_victory"
        | death_cam    -> "death_cam"
        | episode_end  -> "episode_end"
        | endart       -> "endart"
        | high_scores  -> "high_scores"
        io.write("phase=%s{phase_s} timer=%6.3f{g->phase_timer} lives=%d{g->lives}\n", stdout)
        void()
    else if arg == "music" then
        // Print the AUDIOT chunk that would be playing for the current phase.
        // Lets the regression suite verify menu / intermission / victory tracks
        // without needing an open audio device.
        let chunk = font.music_chunk_for_phase(g->phase, g->level_num)
        io.write("music chunk=%d{chunk} (audiot offset=%d{chunk - 261})\n", stdout)
        void()
    else if arg == "prefs" then
        // Dump the current persistent preferences (loaded from
        // `$WOLF_FC_HOME/config` at startup, defaults when missing).
        let m = if g->music_on then 1 else 0
        let s = if w->ac->sfx_on then 1 else 0
        let nd = if g->no_dogs then 1 else 0
        io.write("prefs music=%d{m} sfx=%d{s} no_dogs=%d{nd} shadow_depth=%d{g->shadow_depth} bj_speed_pct=%d{g->bj_speed_pct} enemy_speed_pct=%d{g->enemy_speed_pct}\n", stdout)
        void()
    else if arg == "digi_slots" then
        // Dump the digi-mixer slot table. Verifies wolf4sdl-style dedup:
        // retriggers of a sound already playing should reuse the same
        // slot rather than fan out across all four mixer voices.
        let mut active = 0
        for i in 0..4
            let s = &w->ac->digi->slots[i]
            if s->playing then active = active + 1
            io.write("slot %d{i}: playing=%d{if s->playing then 1 else 0} sound=%d{s->sound_num}\n", stdout)
        io.write("active=%d{active}\n", stdout)
        void()
    else if arg == "probe" then
        // Diagnostic: why can't the player move from their current position?
        // Prints the bbox tiles, any wall/door blocking each, and every live
        // enemy within 2 tiles of the player with their distance and tile.
        let px = g->pos_x
        let py = g->pos_y
        let xl = (int32) (px - player.radius)
        let xr = (int32) (px + player.radius)
        let yl = (int32) (py - player.radius)
        let yh = (int32) (py + player.radius)
        io.write("probe pos=(%7.3f{px}, %7.3f{py}) bbox_tiles: x[%d{xl}..%d{xr}] y[%d{yl}..%d{yh}]\n", stdout)
        for tx in xl..(xr + 1)
            for ty in yl..(yh + 1)
                let ti = (int32) w->lv->tilemap[(int64) tx * 64 + (int64) ty]
                let dstate = if ti < 128 then "open"
                    else match w->lv->doors[ti - 128].state with
                    | closed  -> "DOOR:closed"
                    | opening -> "DOOR:opening"
                    | open    -> "DOOR:open"
                    | closing -> "DOOR:closing"
                let solid = if ti >= 1 && ti <= 63 then "WALL" else dstate
                io.write("  tile (%d{tx},%d{ty}) = %d{ti} (%s{solid})\n", stdout)
        for i in 0..w->lv->num_enemies
            let e = w->lv->enemies[i]
            match e.state with
            | dead | die -> void()
            | _ ->
                let dx = e.x - px
                let dy = e.y - py
                let d = math.sqrt(dx * dx + dy * dy)
                if d < 2.5 then
                    let ks = match e.kind with
                    | guard   -> "guard"
                    | officer -> "officer"
                    | ss      -> "ss"
                    | dog     -> "dog"
                    | mutant  -> "mutant"
                    | hans    -> "hans"
                    | schabbs -> "schabbs"
                    | gretel  -> "gretel"
                    | giftmacher  -> "gift"
                    | fat     -> "fat"
                    | hitler_fake -> "hitler_fake"
                    | mecha_hitler -> "mecha_hitler"
                    | hitler  -> "hitler"
                    | blinky  -> "blinky"
                    | pinky   -> "pinky"
                    | clyde   -> "clyde"
                    | inky    -> "inky"
                    io.write("  enemy[%d{i}] %s{ks} tile(%d{e.tile_x},%d{e.tile_y}) pos(%6.3f{e.x},%6.3f{e.y}) d=%5.3f{d}\n", stdout)
        for i in 0..w->lv->num_sprites
            let s = w->lv->sprites[i]
            if !s.alive then continue
            let dx = s.x - px
            let dy = s.y - py
            let d = math.sqrt(dx * dx + dy * dy)
            if d < 2.5 then
                let bs = if s.blocks then "BLOCKS" else "walk"
                io.write("  sprite[%d{i}] tile(%d{(int32) s.x},%d{(int32) s.y}) page=%d{s.shape_page} %s{bs} d=%5.3f{d}\n", stdout)
        void()
    else if arg == "arrows" then
        // Dump every ICON_ARROWS path-marker tile baked into the level. Lets a
        // test author find a tile to walk a patrolling enemy through to verify
        // that enemies.ai.select_path_dir applies the override.
        for y in 0..map_size
            for x in 0..map_size
                let v = (int32) w->lv->path_arrows[(int64) x * 64 + (int64) y]
                if v != dir.nodir then
                    io.write("arrow (%d{x},%d{y}) dir=%d{v}\n", stdout)
        void()
    else if arg == "enemylist" then
        // Per-enemy dump: grid position, kind, state, dir. Handy to locate
        // a specific enemy for a scripted screenshot or attack test.
        for i in 0..w->lv->num_enemies
            let e = w->lv->enemies[i]
            let ks = match e.kind with
            | guard   -> "guard"
            | officer -> "officer"
            | ss      -> "ss"
            | dog     -> "dog"
            | mutant  -> "mutant"
            | hans    -> "hans"
            | schabbs -> "schabbs"
            | gretel  -> "gretel"
            | giftmacher  -> "gift"
            | fat     -> "fat"
            | hitler_fake -> "hitler_fake"
            | mecha_hitler -> "mecha_hitler"
            | hitler  -> "hitler"
            | blinky  -> "blinky"
            | pinky   -> "pinky"
            | clyde   -> "clyde"
            | inky    -> "inky"
            let ss = match e.state with
            | stand -> "stand"
            | path  -> "path"
            | chase -> "chase"
            | shoot -> "shoot"
            | pain  -> "pain"
            | die   -> "die"
            | dead  -> "dead"
            let area = (int32) w->lv->tile_areas[(int64) e.tile_x * 64 + (int64) e.tile_y]
            io.write("[%d{i}] (%d{e.tile_x},%d{e.tile_y}) kind=%s{ks} state=%s{ss} dir=%d{e.dir} hp=%d{e.hp} area=%d{area}\n", stdout)
        void()
    else if arg == "pickups" then
        // Per-level pickup inventory: dumps every live sprite whose
        // item_type is something the player could actually grab
        // (decorations are filtered out). Enemy-dropped items appear
        // after their corpse lands, so running `killenemy:i pickups`
        // is a way to verify drops. Format mirrors `enemylist`:
        //   [slot] (tx,ty) kind=<kind>
        // followed by a count line.
        let mut count = 0
        for i in 0..w->lv->num_sprites
            let s = w->lv->sprites[i]
            if !s.alive then continue
            let ks = match s.item_type with
            | decoration -> ""
            | dog_food    -> "dog_food"
            | food        -> "food"
            | first_aid   -> "first_aid"
            | extra_life  -> "extra_life"
            | clip        -> "clip"
            | clip_small  -> "clip_small"
            | machine_gun -> "machine_gun"
            | chain_gun   -> "chain_gun"
            | gold_key    -> "gold_key"
            | silver_key  -> "silver_key"
            | cross       -> "cross"
            | chalice     -> "chalice"
            | bible       -> "bible"
            | crown       -> "crown"
            | gibs        -> "gibs"
            if ks.len == 0 then continue
            let tx = (int32) s.x
            let ty = (int32) s.y
            io.write("[%d{i}] (%d{tx},%d{ty}) kind=%s{ks}\n", stdout)
            count = count + 1
        io.write("pickups: count=%d{count}\n", stdout)
        void()
    else if arg == "exittiles" then
        // List every EXITTILE marker (plane-1 tile 99) on the current map.
        // Boss-level maps place exactly one of these behind the gold-key
        // door; stepping onto it triggers the BJ-victory cutscene.
        let mut count = 0
        for y in 0..map_size
            for x in 0..map_size
                if w->lv->exit_tiles[(int64) x * 64 + (int64) y] then
                    io.write("exit: %d{x},%d{y}\n", stdout)
                    count = count + 1
        io.write("exittiles: count=%d{count}\n", stdout)
        void()
    else if arg == "enemies" then
        // Summary: counts by kind and by state, for regression checks.
        // Buckets: 0=guard, 1=officer, 2=ss, 3=dog, 4=mutant, 5=boss, 6=ghost.
        let mut by_kind = int32[7] { 0, 0, 0, 0, 0, 0, 0 }
        let mut by_state = int32[7] { 0, 0, 0, 0, 0, 0, 0 }
        for i in 0..w->lv->num_enemies
            let e = w->lv->enemies[i]
            let ki = match e.kind with
            | guard -> 0
            | officer -> 1
            | ss -> 2
            | dog -> 3
            | mutant -> 4
            | hans | schabbs | gretel | giftmacher | fat
            | hitler_fake | mecha_hitler | hitler -> 5
            | blinky | pinky | clyde | inky -> 6
            by_kind[ki] = by_kind[ki] + 1
            let si = match e.state with
            | stand -> 0
            | path -> 1
            | chase -> 2
            | shoot -> 3
            | pain -> 4
            | die -> 5
            | dead -> 6
            by_state[si] = by_state[si] + 1
        io.write("enemies: total=%d{w->lv->num_enemies}\n", stdout)
        io.write("  kind: guard=%d{by_kind[0]} officer=%d{by_kind[1]} ss=%d{by_kind[2]} dog=%d{by_kind[3]} mutant=%d{by_kind[4]} boss=%d{by_kind[5]} ghost=%d{by_kind[6]}\n", stdout)
        io.write("  state: stand=%d{by_state[0]} path=%d{by_state[1]} chase=%d{by_state[2]} shoot=%d{by_state[3]} pain=%d{by_state[4]} die=%d{by_state[5]} dead=%d{by_state[6]}\n", stdout)
        void()
    else if arg == "projectiles" then
        // Dump all active (alive) enemy projectiles: kind, position, travel
        // angle in radians, animation frame. Used by the boss regression
        // tests to verify Schabbs / Giftmacher / fake-Hitler actually
        // spawn visible projectiles instead of hitscanning.
        let mut alive = 0
        for i in 0..projectiles.max_projectiles
            let p = &w->lv->projectiles[i]
            if !p->alive then continue
            alive = alive + 1
            let ks = match p->kind with
            | needle -> "needle"
            | rocket -> "rocket"
            | fire   -> "fire"
            | boom   -> "boom"
            io.write("  proj[%d{i}] %s{ks} pos(%6.3f{p->x},%6.3f{p->y}) ang=%5.3f{p->angle} frame=%d{p->anim_frame}\n", stdout)
        io.write("projectiles: alive=%d{alive}\n", stdout)
        void()
    else
        io.write("Unknown test command: %s{arg}\n", stdout)
        void()

// ============================================================
// Entry point
// ============================================================

let main = (args: str[]) ->
    // CLI flags. Scan all args (so flags can appear before or after --test)
    // and set the relevant module-level switches before any level is built.
    //   --no-dogs             — skip spawning enemies.enemy_kind.dog actors
    //   --test                — enter scripted-command mode (no SDL)
    //   --level N             — skip the title screen and start at level N
    //                           (0..59). Handy for boss testing:
    //                           E1 Hans=8, E2 Schabbs=18, E3 Hitler=28,
    //                           E4 Giftmacher=38, E5 Gretel=48, E6 Fat=58.
    //   --difficulty N        — override difficulty (0 baby, 3 hard).
    //                           Combines with --level; also affects menu
    //                           default for NEW GAME if set alone.
    //   --near-boss           — after applying --level (or the default
    //                           level 0), teleport the player to an open
    //                           tile adjacent to the first boss enemy on
    //                           the map, facing the boss. No-op on maps
    //                           without a boss.
    //   --near-goldkey        — same idea, but teleport next to the first
    //                           gold-key pickup. Useful for HUD testing.
    //                           No-op on maps without one (E1L1).
    //   --near-silverkey      — teleport next to the first silver-key
    //                           pickup. First silver-key map is E2L3.
    //   --near-gibs           — teleport next to the first `bo_gibs`
    //                           pile. First gibs map is E1M2.
    //   --cheat               — pre-activate IDDQD + IDKFA: god mode,
    //                           both keys, chain gun, 99 ammo (non-
    //                           depleting), and a locked score. The
    //                           gifts re-apply on every death-respawn
    //                           while the IDKFA latch stays on.
    let mut test_mode = false
    let mut start_level = -1
    let mut start_difficulty = -1
    let mut start_near_boss = false
    let mut start_near_goldkey = false
    let mut start_near_silverkey = false
    let mut start_near_gibs = false
    let mut arg_no_dogs = false
    let mut arg_cheat = false
    for i in 1..(int32) args.len
        let a = args[(int64) i]
        if a == "--no-dogs" then arg_no_dogs = true
        if a == "--test" then test_mode = true
        if a == "--near-boss" then start_near_boss = true
        if a == "--near-goldkey" then start_near_goldkey = true
        if a == "--near-silverkey" then start_near_silverkey = true
        if a == "--near-gibs" then start_near_gibs = true
        if a == "--cheat" then arg_cheat = true
        if text.starts_with(a, "--level=") then
            match text.parse_int32(a[8..a.len]) with
            | some(n) -> if n >= 0 && n < 60 then start_level = n
            | none    -> void()
        if text.starts_with(a, "--difficulty=") then
            match text.parse_int32(a[13..a.len]) with
            | some(n) -> if n >= 0 && n < 4 then start_difficulty = n
            | none    -> void()

    // PRNG seed: deterministic 0 in --test mode so scripted scenarios
    // reproduce bit-identically; wall-clock milliseconds otherwise. A single
    // seed fans out to two pcg_random channels (enemy AI, face animation)
    // when the game struct is initialised below.
    let rng_seed = if test_mode then 0u64 else (uint64) sys.time()

    // Resolve the WL6 data directory before loading anything: env override,
    // then ./data, then the compile-time install location. The resulting
    // heap str is owned by the game struct (set below) and freed at exit.
    let data_dir = data_path.resolve()
    io.write("Data dir: %s{data_dir}\n", stdout)

    // Load game data (no SDL needed)
    io.write("Loading palette...\n", stdout)
    let pal = palette.init()

    io.write("Loading VSWAP.WL6...\n", stdout)
    let p_vswap = data_path.wl6(data_dir, "VSWAP.WL6")
    defer free(p_vswap)
    let vs = vswap.load(p_vswap)
    io.write("  chunks=%d{vs->num_chunks}, sprites@%d{vs->sprite_start}, sounds@%d{vs->sound_start}\n", stdout)

    io.write("Loading audio...\n", stdout)
    let p_audhed = data_path.wl6(data_dir, "AUDIOHED.WL6")
    defer free(p_audhed)
    let p_audt = data_path.wl6(data_dir, "AUDIOT.WL6")
    defer free(p_audt)
    let ad = audio.load(p_audhed, p_audt)
    io.write("  audio chunks=%d{ad->num_chunks}\n", stdout)

    io.write("Loading VGAGRAPH...\n", stdout)
    let p_vgadict = data_path.wl6(data_dir, "VGADICT.WL6")
    defer free(p_vgadict)
    let p_vgahead = data_path.wl6(data_dir, "VGAHEAD.WL6")
    defer free(p_vgahead)
    let p_vgagraph = data_path.wl6(data_dir, "VGAGRAPH.WL6")
    defer free(p_vgagraph)
    let vg = vgagraph.load(p_vgadict, p_vgahead, p_vgagraph)
    io.write("  vga chunks=%d{vg->num_chunks}, pics=%d{vg->num_pics}\n", stdout)

    io.write("Loading level 0...\n", stdout)
    let p_maphead0 = data_path.wl6(data_dir, "MAPHEAD.WL6")
    defer free(p_maphead0)
    let p_gamemaps0 = data_path.wl6(data_dir, "GAMEMAPS.WL6")
    defer free(p_gamemaps0)
    let mut lv_data = maps.load(p_maphead0, p_gamemaps0, 0)
    io.write("  map %d{lv_data->width}x%d{lv_data->height}\n", stdout)

    // Persistent user preferences (sound toggles for now; key bindings
    // and screen settings later). Read from `~/.wolf-fc/config`; missing
    // file falls back to defaults — see save.fc::config.
    let cfg = config.load()

    // Detect display aspect for Hor+ widescreen. We init SDL_VIDEO
    // here (interactive only) so the world / render_ctx allocs can
    // size their framebuffers based on the user's monitor. Test mode
    // skips SDL entirely and uses the OG 320 — keeps every screenshot-
    // diffing regression bit-identical. The user's view-mode choice
    // (config) wins over auto-detection: `Original` always picks 320,
    // `Widescreen 16:10` always picks 384, etc.
    let mut fb_w = 320
    let mut plane_factor = fov_factor
    if !test_mode then
        sdl2.init(sdl2.init_video)
        fb_w = compute_fb_w_for_view_mode(cfg.view_mode)
        plane_factor = fov_factor * (float64) fb_w / 320.0
        io.write("View mode %s{config.view_mode_label(cfg.view_mode)} → fb %d{fb_w}x200\n", stdout)

    // Assemble the `world` — the handle that groups game state, level data,
    // renderer, and audio. Orchestrators take `world*`; narrower functions
    // still take just the sub-contexts they need.
    let g = alloc(game {
        pos_x = 1.5, pos_y = 1.5,
        dir_x = 1.0, dir_y = 0.0,
        plane_x = 0.0, plane_y = plane_factor,
        plane_factor = plane_factor,
        view_mode = cfg.view_mode,
        key_up = false, key_down = false,
        key_left = false, key_right = false,
        key_shift = false, key_alt = false,
        key_ctrl = false, key_space = false, key_space_handled = false,
        key_ack = false, key_ack_handled = false, key_fire = false,
        key_m_held = false, key_l_held = false, key_i_held = false,
        key_b_held = false, key_a_held = false, key_t_held = false,
        cheat_mli_latched = false, cheat_bat_latched = false,
        iddqd_progress = 0, god_mode = false,
        idkfa_progress = 0, idkfa_mode = false,
        key_tab_held = false, noclip = false,
        wall_hit_cooldown = 0.0,
        health = 100, ammo = 8, score = 0, oldscore = 0, lives = 3,
        level_num = 0,
        has_gold_key = false, has_silver_key = false,
        next_level = false, next_level_delay = 0.0,
        weapon = 1, best_weapon = 1, went_secret = false,
        fire_timer = 0.0, weapon_frame = 0,
        face_frame = 0, face_count = 0.0,
        area_number = -1, made_noise = false, player_running = false, want_near_boss = false,
        bj_x = 0.0, bj_y = 0.0,
        bj_tile_x = 0, bj_tile_y = 0,
        bj_dir = dir.nodir, bj_distance = 0.0, bj_run_tiles_left = 0,
        bj_anim_frame = 0, bj_anim_timer = 0.0,
        bj_phase = 0, bj_yelled = false,
        dc_sub = 0, dc_timer = 0.0, dc_boss_idx = -1,
        dc_kill_x = 0.0, dc_kill_y = 0.0, dc_fade = 0.0,
        endart_data = alloc(uint8[0] {})!,
        endart_page_offsets = alloc(int32[0] {})!,
        endart_total_pages = 0, endart_page = 0,
        hs_source = 0,
        ep_kr_total = 0, ep_sr_total = 0, ep_tr_total = 0,
        ep_time_total = 0, ep_levels_played = 0,
        ep_recorded_current = false,
        phase = game_phase.pg13, phase_timer = 0.0,
        damage_flash_timer = 0.0,
        killer_x = 0.0, killer_y = 0.0, killer_active = false,
        respawn_fade_timer = 0.0,
        get_psyched_timer = 0.0, got_gatling_timer = 0.0,
        kills = 0, total_kills = 0,
        secrets = 0, total_secrets = 0,
        treasures = 0, total_treasures = 0,
        level_time = 0.0,
        inter_stage = 0, inter_counter = 0, inter_progress = 0.0,
        inter_bonus_shown = 0,
        inter_target_timeleft = 0, inter_target_kr = 0,
        inter_target_sr = 0, inter_target_tr = 0,
        inter_breathe_timer = 0.0,
        inter_pause_timer = 0.0,
        inter_end_sound_delay = 0.0,
        // Initial difficulty: gd_medium for interactive launches (matches
        // the OG difficulty-picker default — `NewItems.curpos = 2` /
        // "Bring 'Em On!" — so the first menu visit pre-selects the
        // right row); gd_hard for `--test` mode so the existing
        // regression suite keeps spawning the full enemy roster (medium
        // filters out +72-tier tiles, which would invalidate hundreds
        // of enemy-index assertions).
        difficulty = if test_mode then difficulty.hard else difficulty.medium,
        // CLI flag takes precedence over the persisted config — `--no-dogs`
        // is always "force on", absence falls back to whatever the user
        // last toggled in the Options menu.
        no_dogs = if arg_no_dogs then true else cfg.no_dogs,
        shadow_depth = cfg.shadow_depth,
        bj_speed_pct = cfg.bj_speed_pct,
        enemy_speed_pct = cfg.enemy_speed_pct,
        data_dir = data_dir,
        test_mode = test_mode,
        menu_sel = 0, menu_level = menu.nav.main, save_edit_active = false,
        music_on = cfg.music_on, want_quit = false,
        quit_prompt_idx = 0,
        quit_prompts_override = quit_prompts.load_override(),
        has_active_game = false,
        msg_buf = alloc(uint8[256] {})!,
        msg_len = 0, msg_timer = 0.0,
        rng_enemy = random.pcg_random.make_with_channel(rng_seed, enemies.rng_channel),
        rng_face = random.pcg_random.make_with_channel(rng_seed, hud.rng_channel)
    })!
    spawn.find_player_start(lv_data, g)
    io.write("  player at (%4.1f{g->pos_x}, %4.1f{g->pos_y})\n", stdout)

    // Sound system (valid in all modes; in --test and --screenshot nothing
    // actually reaches the speakers because SDL audio isn't opened, but
    // sfx.trigger / digi.fill work over this same ctx either way).
    let w = alloc(world {
        g = g,
        lv = build_level(lv_data, vs->sprite_start, g->difficulty, g->no_dogs),
        lv_data = lv_data,
        rc = build_render_ctx(vg, pal, fb_w, game_h),
        ac = alloc(audio_ctx {
            vs = vs,
            ad = ad,
            sfx = adlib.init((float64) sfx.sample_rate),
            digi = digi.init(vs),
            sfx_on = cfg.sfx_on
        })!,
        sm = build_save_menu_ctx(),
        hs = build_highscore_ctx(),
        vg = vg,
        font = font.load(vg, pics.id.font_small)
    })!
    // Initial per-level counters mirror what was tallied during build_level.
    g->total_kills = w->lv->total_enemies
    g->total_secrets = w->lv->total_pushwalls
    g->total_treasures = w->lv->total_treasures
    // Now that both player position and level areas exist, anchor the
    // player's area + the area_by_player set. wolf4sdl SpawnPlayer / InitAreas
    // do this on level load: only the player's starting area is initially
    // marked reachable, since all doors begin closed and area_connect is 0.
    areas.update_player_area(w->lv, g)
    areas.connect(w->lv, g->area_number)

    // --cheat: pre-activate IDDQD + IDKFA so they're live from the first
    // frame, regardless of whether the player enters a game via --level,
    // the NEW GAME menu, or --test. The IDKFA latch feeds reset_for_life,
    // so the player gets re-kitted after every death too.
    if arg_cheat then
        g->god_mode = true
        g->idkfa_mode = true
        give_full_kit(g)

    // --difficulty N / --level N: skip the title sequence and jump the
    // player straight into the specified map. Also respected in --test
    // mode so scripts can start on any level without a `setlevel:` prefix.
    if start_difficulty >= 0 then
        g->difficulty = start_difficulty
        // Rebuild enemies with the new difficulty tier. reload_level_data
        // reads g->difficulty, so it's enough to just re-run it.
        reload_level_data(w, vs)
        spawn.find_player_start(w->lv_data, g)
        reset_level_counters(g, w->lv)
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)
    if start_level >= 0 then
        g->level_num = start_level
        reload_level_data(w, vs)
        spawn.find_player_start(w->lv_data, g)
        reset_level_counters(g, w->lv)
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)
        g->phase = game_phase.playing
        g->has_active_game = true
        pics.trigger_get_psyched(g)
    if start_near_boss then
        spawn.near_boss(w->lv, w->g)
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)
    if start_near_goldkey then
        spawn.near_goldkey(w->lv, w->g)
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)
    if start_near_silverkey then
        spawn.near_silverkey(w->lv, w->g)
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)
    if start_near_gibs then
        spawn.near_gibs(w->lv, w->g)
        areas.update_player_area(w->lv, g)
        areas.connect(w->lv, g->area_number)

    // Test mode: process scripted commands, no SDL needed. Skip the
    // title/menu entry flow — tests start directly in playing so
    // existing regression scripts behave the same as before the UI
    // overhaul. Flags like --no-dogs may appear before or after --test; in
    // the command loop, we skip anything matching a known flag so it isn't
    // reported as "Unknown test command".
    let mut test_idx = -1
    for i in 1..(int32) args.len
        if test_idx < 0 && args[(int64) i] == "--test" then test_idx = i
    if test_mode then
        g->phase = game_phase.playing
        g->has_active_game = true
        let test_dt = 1.0 / 35.0
        for ti in (test_idx + 1)..(int32) args.len
            if args[(int64) ti] == "--no-dogs" then continue
            if args[(int64) ti] == "--cheat" then continue
            run_test_cmd(w, args[(int64) ti], pal, test_dt)
        return 0

    // Initialize SDL2 (interactive mode only)
    sdl2.set_hint(c"SDL_WINDOWS_DPI_AWARENESS", c"system")
    sdl2.init(sdl2.init_video | sdl2.init_audio)

    // Window: resizable, fullscreen (borderless display-sized) on start.
    // F11 / Alt+Enter toggles between fullscreen and maximized — both
    // paths share the body of the toggle below.
    // Display geometry. The framebuffer is fb_w × fb_h (set above
    // from the display aspect — see Hor+ widescreen detection); the
    // texture is 2× both dims; the logical-size scale-out target
    // applies the VGA 1.2 pixel aspect (game_h * 1.2 * 2 = 480) so a
    // 4:3 fb (320 wide) renders at 640×480 and a 16:10 fb (384 wide)
    // renders at 768×480.
    // Mutable so the Change View menu can resize on the fly.
    let mut runtime_screen_w = w->rc->screen_w
    let mut runtime_screen_h = w->rc->fb_h * 2
    let mut runtime_actual_h = (w->rc->fb_h * 12 / 10) * 2   // VGA pixel-aspect-corrected (1.2)
    let flags = sdl2.window_shown | sdl2.window_resizable | sdl2.window_allow_highdpi
    let win = sdl2.create_window(c"Wolf-FC",
        sdl2.pos_centered, sdl2.pos_centered, runtime_screen_w, runtime_actual_h, flags)
    let mut db = sdl2.rect { x = 0, y = 0, w = 0, h = 0 }
    sdl2.get_display_bounds(0, &db)
    sdl2.set_bordered(win, 0)
    sdl2.set_window_position(win, db.x, db.y)
    sdl2.set_window_size(win, db.w, db.h)
    let mut fullscreen = true

    // Renderer with vsync.
    let ren = sdl2.create_renderer(win, -1, sdl2.renderer_vsync)
    sdl2.set_logical_size(ren, runtime_screen_w, runtime_actual_h)
    sdl2.show_cursor(0)

    // Nearest-neighbor scaling — must be set BEFORE creating the texture.
    sdl2.set_hint(c"SDL_RENDER_SCALE_QUALITY", c"nearest")

    // Streaming texture at 2× framebuffer dims.
    let mut tex = sdl2.create_texture(ren, sdl2.pixel_argb8888,
        sdl2.tex_streaming, runtime_screen_w, runtime_screen_h)

    // Set up audio device and start music. Output is stereo (2 channels
    // interleaved L,R,…) so enemy SFX can pan spatially via digi.
    let mut spec = sdl2.audio_spec {
        freq = sfx.sample_rate, format = sdl2.audio_s16sys,
        channels = 2u8, silence = 0u8, samples = 1024u16,
        padding = 0u16, size = 0u32, callback = (any*) 0, userdata = (any*) 0
    }
    let mut obtained = default(sdl2.audio_spec)
    let audio_dev = sdl2.open_audio((any*) 0, 0, &spec, &obtained, 0)
    // First-frame music = whatever fits the initial phase (title →
    // WONDERIN). Phase-driven swap below keeps this in sync afterward.
    let mut current_music_chunk = font.music_chunk_for_phase(g->phase, g->level_num)
    let mut ms = if audio_dev > 0u32 && current_music_chunk < ad->num_chunks then
        sdl2.pause_audio(audio_dev, 0)
        some(font.music_load(ad, current_music_chunk))
    else default(imf.player*?)
    // 1024 stereo frames per audio batch. `mix_buf` is int32 so the three
    // source fills (music, AdLib SFX, digi PCM) can sum without the per-
    // stage clipping that would otherwise starve later stages of headroom.
    // `out_buf` receives the soft-clipped int16 samples that actually get
    // queued to SDL (2048 int16 = 4096 bytes).
    let mix_buf = alloc(int32[2048] {})!
    let out_buf = alloc(int16[2048] {})!
    // Honour the persisted music preference: even if the IMF player
    // loaded successfully, start the mixer with music silenced when
    // the user has toggled music off in a previous session.
    let mut music_on = ms.is_some && g->music_on

    // Fresh screenshot directory each session — user copies any they want to keep.
    overlay.clear_screenshots()

    // Game loop
    let mut running = true
    let mut last_ticks = sdl2.get_ticks()
    let mut event = default(sdl2.sdl_event)

    loop
        if !running then break
        if g->want_quit then break

        // Delta time
        let now = sdl2.get_ticks()
        let mut dt = (float64) (now - last_ticks) / 1000.0
        last_ticks = now
        if dt > 0.1 then dt = 0.1    // clamp large spikes

        // Poll events
        loop
            if sdl2.poll_event(&event) == 0 then break
            let t = (int32) event.type
            if t == sdl2.quit_event then running = false
            if t == sdl2.keydown_event then
                let k = event.key.keysym.sym
                // OS key-autorepeat fires SDL_KEYDOWN every ~30 ms while a key
                // is held; `repeat != 0` flags the duplicates. We want repeats
                // for menu nav (hold ↓ to scroll save slots) but NOT for
                // gameplay keys — a ctrl held through the episode-end screen
                // would otherwise re-raise key_fire after the level reset
                // clears it, so the gatling fires on the first frame of the
                // next level. Checked per-branch below.
                let is_key_repeat = event.key.repeat != 0u8
                // Fullscreen toggle — always works (even from menu / pause).
                // F11 is our own shortcut; Alt+Enter matches the original
                // SDL port. Either Alt modifier counts (KMOD_ALT = LALT |
                // RALT = 0x0300). Alt+Enter `continue`s past the phase
                // match so the menu doesn't also confirm on the same press.
                let is_alt_enter = k == sdl2.key_return
                    && (event.key.keysym.mod & 0x0300u16) != 0u16
                if (k == sdl2.key_f11 || is_alt_enter) && !is_key_repeat then
                    fullscreen = !fullscreen
                    if fullscreen then
                        let mut db = sdl2.rect { x = 0, y = 0, w = 0, h = 0 }
                        sdl2.get_display_bounds(0, &db)
                        sdl2.set_bordered(win, 0)
                        sdl2.set_window_position(win, db.x, db.y)
                        sdl2.set_window_size(win, db.w, db.h)
                    else
                        sdl2.set_bordered(win, 1)
                        sdl2.restore_window(win)
                        sdl2.maximize_window(win)
                    sdl2.set_logical_size(ren, runtime_screen_w, runtime_actual_h)
                    if is_alt_enter then continue
                // Per-phase dispatch for everything else.
                // Deliberate-feeling ack keys (Enter / Space / Ctrl / Esc)
                // — matches the IN_Ack restriction below so modifier-only
                // / function-key bumps don't skip past intro screens.
                // Esc is included so a player can mash "get me out of
                // here" on every screen consistently.
                let is_ack_key_intro = k == sdl2.key_return
                    || k == sdl2.key_space
                    || k == sdl2.key_lctrl
                    || k == sdl2.key_escape
                match g->phase with
                | pg13 ->
                    // Advance to the title screen on an ack key. update_
                    // phase_transitions also auto-advances after a few
                    // seconds.
                    if is_ack_key_intro then
                        g->phase = game_phase.title
                        g->phase_timer = 0.0
                | endart ->
                    // Per-page navigation, faithful to the original
                    // ShowArticle loop. The OG GameLoop's ex_victorious
                    // case calls `Victory()` (stats + EndText article)
                    // and then `return`s back to the control panel —
                    // there is no auto-advance to the next episode.
                    // Players replay each episode by re-picking it from
                    // the main menu.
                    //
                    //   Left / Up / PageUp           → previous page
                    //   Right / Down / PageDown      → next page
                    //   Enter / Space / Ctrl         → next page
                    //   Esc                          → exit the article →
                    //                                  main menu (the
                    //                                  only key that
                    //                                  actually leaves
                    //                                  the article;
                    //                                  matches the on-
                    //                                  screen "ESC EXITS"
                    //                                  hint and the OG
                    //                                  `do { ... } while
                    //                                  (LastScan != Esc
                    //                                  && !ci.button1)`)
                    //   Forward past the last page   → no-op (stays on
                    //                                  the final page;
                    //                                  player still has
                    //                                  to press Esc to
                    //                                  leave)
                    // Other keys (modifiers, letters, etc.) are no-ops
                    // so a stray bump doesn't skip a page.
                    if !is_key_repeat then
                        if k == sdl2.key_left || k == sdl2.key_up
                                || k == sdl2.key_pageup then
                            endart_screen.prev_page(g)
                        else if k == sdl2.key_escape then
                            // Esc routes through CheckHighScore — the
                            // OG's Victory() / GameLoop ex_victorious
                            // calls CheckHighScore before returning to
                            // the control panel.
                            let ep = g->level_num / episode.levels_per
                            high_scores_screen.enter(g, w->hs,
                                high_scores_screen.from_endart,
                                g->score, g->level_num + 1, ep)
                        else if k == sdl2.key_right || k == sdl2.key_down
                                || k == sdl2.key_pagedown
                                || k == sdl2.key_return
                                || k == sdl2.key_space
                                || k == sdl2.key_lctrl then
                            // next_page no-ops past the last page — the
                            // user has to press Esc to exit the article.
                            endart_screen.next_page(g)
                | title ->
                    // Advance to the main menu on an ack key. Default
                    // selection = NEW GAME (RESUME is locked from the
                    // title screen).
                    if is_ack_key_intro then
                        g->phase = game_phase.main_menu
                        g->menu_level = menu.nav.main
                        g->menu_sel = 0     // NEW GAME row in OG layout
                        g->phase_timer = 0.0
                | main_menu ->
                    // Classic menu-cursor feedback: MOVEGUN1SND on up/down
                    // nav, SHOOTSND on confirm into a submenu, MOVEGUN2SND
                    // on commit-a-setting (sound toggles), ESCPRESSEDSND on
                    // cancel. The submenu-confirm vs setting-commit split
                    // matches the original: SHOOTSND drilling-in,
                    // MOVEGUN2SND finalising a config change. Plays on
                    // every menu level — the dispatch below just mutates
                    // menu_sel / menu_level, so a single site up here
                    // covers all sub-menus without sprinkling calls per
                    // branch.
                    let is_confirm = k == sdl2.key_return || k == sdl2.key_space
                    let is_commit  = is_confirm && g->menu_level == menu.nav.sound
                    // The episode picker's hidden number shortcut (0..9)
                    // counts as a confirm too — same drilling-into-a-
                    // submenu effect, so it deserves the same SHOOTSND.
                    let is_episode_floor_key = g->menu_level == menu.nav.episode
                        && (k == sdl2.key_0 || (k >= sdl2.key_1 && k <= sdl2.key_9))
                    if k == sdl2.key_up || k == sdl2.key_down then
                        sfx.trigger(sfx.id.move_gun1, w->ac)
                    else if is_commit then
                        sfx.trigger(sfx.id.move_gun2, w->ac)
                    else if is_confirm || is_episode_floor_key then
                        sfx.trigger(sfx.id.shoot, w->ac)
                    else if k == sdl2.key_escape then
                        sfx.trigger(sfx.id.esc_pressed, w->ac)
                    if g->menu_level == menu.nav.main then
                        // Up/down navigation skips locked rows so SAVE
                        // and BACK TO GAME without an active game don't
                        // get in the way.
                        if k == sdl2.key_up then
                            let mut s = g->menu_sel
                            for _ in 0..menu.main_len
                                s = (s + menu.main_len - 1) % menu.main_len
                                if !menu.main_is_locked(s, g->has_active_game) then break
                            g->menu_sel = s
                        else if k == sdl2.key_down then
                            let mut s = g->menu_sel
                            for _ in 0..menu.main_len
                                s = (s + 1) % menu.main_len
                                if !menu.main_is_locked(s, g->has_active_game) then break
                            g->menu_sel = s
                        else if is_confirm then
                            // Layout: NEW / SOUND / OPTIONS / LOAD / SAVE / VIEW / SCORES / BACK / QUIT
                            match g->menu_sel with
                            | 0 ->
                                // NEW GAME → episode picker
                                g->menu_level = menu.nav.episode
                                g->menu_sel = 0
                            | 1 ->
                                // SOUND → sound submenu
                                g->menu_level = menu.nav.sound
                                g->menu_sel = 0
                            | 2 ->
                                // OPTIONS → wolf-fc mods submenu
                                g->menu_level = menu.nav.options
                                g->menu_sel = 0
                            | 3 ->
                                // LOAD GAME → load slot menu
                                save.refresh_slots(w->sm)
                                g->menu_level = menu.nav.loadlist
                                g->menu_sel = 0
                            | 4 ->
                                // SAVE GAME (locked without an active game)
                                if g->has_active_game then
                                    save.refresh_slots(w->sm)
                                    g->menu_level = menu.nav.savelist
                                    g->menu_sel = 0
                            | 5 ->
                                // CHANGE VIEW → view-mode picker
                                g->menu_level = menu.nav.changeview
                                g->menu_sel = g->view_mode
                            | 6 ->
                                // VIEW SCORES → high-scores screen.
                                // hs_source=from_menu so the dismiss
                                // routes back here instead of to the
                                // title.
                                high_scores_screen.enter(g, w->hs,
                                    high_scores_screen.from_menu, -1, 0, 0)
                            | 7 ->
                                // BACK TO GAME / DEMO — label + target
                                // track has_active_game. With a running
                                // game this resumes gameplay; without
                                // one it bounces to the title screen
                                // (the OG's BACK TO DEMO returns to
                                // DemoLoop, which lands on the title pic).
                                if g->has_active_game then
                                    g->phase = game_phase.playing
                                else
                                    g->phase = game_phase.title
                                    g->phase_timer = 0.0
                            | 8 ->
                                // QUIT → enter the Y/N confirm modal.
                                // Roll the prompt index now so the
                                // displayed tagline stays stable while
                                // the modal is up. RNG channel reuse:
                                // rng_face is non-gameplay and not part
                                // of the test-mode bit-stability contract
                                // (test mode never reaches the menu).
                                let n = quit_prompts.count(g->quit_prompts_override)
                                let r = random.pcg_random.next_bounded_uint32(&g->rng_face, (uint32) n)
                                g->quit_prompt_idx = (int32) r
                                g->menu_level = menu.nav.quit
                            | _ -> void()
                        else if k == sdl2.key_escape then
                            // Esc on the main menu = same as picking
                            // BACK TO GAME / DEMO: resume gameplay if a
                            // game is running, otherwise bounce to the
                            // title screen (matching the OG's back-to-
                            // demo behaviour).
                            if g->has_active_game then
                                g->phase = game_phase.playing
                            else
                                g->phase = game_phase.title
                                g->phase_timer = 0.0
                    else if g->menu_level == menu.nav.episode then
                        // Hidden floor-jump shortcut: pressing 1..9 on the
                        // episode picker drops the player straight onto
                        // floor 1..9 of the highlighted episode (skipping
                        // the floors before it); pressing 0 jumps to the
                        // secret bonus floor (floor 10 / level index 9).
                        // Same `level_num = ep*10 + offset` math the rest
                        // of the menu uses; no other state is mutated, so
                        // the difficulty picker still gates the actual
                        // game start.
                        let floor_offset = if k == sdl2.key_0 then 9
                            else if k >= sdl2.key_1 && k <= sdl2.key_9 then k - sdl2.key_1
                            else -1
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + episode.count - 1) % episode.count
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % episode.count
                        else if floor_offset >= 0 then
                            g->level_num = g->menu_sel * episode.levels_per + floor_offset
                            g->want_near_boss = false
                            g->menu_level = menu.nav.difficulty
                            g->menu_sel = g->difficulty
                        else if is_confirm then
                            // Episode pick → straight to difficulty.
                            // level_num resets to the episode's first map.
                            g->level_num = g->menu_sel * episode.levels_per
                            g->want_near_boss = false
                            g->menu_level = menu.nav.difficulty
                            g->menu_sel = g->difficulty
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.main
                            g->menu_sel = 0     // back to NEW GAME row
                    else if g->menu_level == menu.nav.difficulty then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + 3) % 4
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % 4
                        else if is_confirm then
                            g->difficulty = g->menu_sel
                            // g->level_num already holds the chosen episode's
                            // first map (set when leaving the episode picker).
                            start_new_game_here(w, vs)
                            g->has_active_game = true
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.episode
                            g->menu_sel = g->level_num / episode.levels_per
                    else if g->menu_level == menu.nav.sound then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + menu.sound_len - 1) % menu.sound_len
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % menu.sound_len
                        else if is_confirm then
                            // Toggle the row's setting in place, then
                            // persist both toggles to ~/.wolf-fc/config
                            // so the choice survives across launches.
                            //   row 0 = SOUND EFFECTS → ac->sfx_on
                            //   row 1 = MUSIC         → g->music_on
                            if g->menu_sel == 0 then
                                w->ac->sfx_on = !w->ac->sfx_on
                            else
                                g->music_on = !g->music_on
                                music_on = g->music_on
                                if !music_on && audio_dev > 0u32 then
                                    sdl2.clear_audio(audio_dev)
                            config.save(config.snapshot(w))
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.main
                            g->menu_sel = 1     // back to SOUND row
                    else if g->menu_level == menu.nav.changeview then
                        // View-mode picker: arrow up/down navigates the
                        // four modes; Enter commits + applies the choice
                        // on the fly. apply_view_mode resizes the
                        // framebuffer / upscale / z-buffer / title-bg
                        // cache and rescales the player's plane vector;
                        // we follow up by recreating the SDL texture +
                        // updating the renderer's logical size so the
                        // new fb dimensions actually reach the display.
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + menu.changeview_len - 1) % menu.changeview_len
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % menu.changeview_len
                        else if is_confirm then
                            let resized = apply_view_mode(w, w->vg, pal, g->menu_sel)
                            config.save(config.snapshot(w))
                            if resized then
                                sdl2.destroy_texture(tex)
                                runtime_screen_w = w->rc->screen_w
                                runtime_screen_h = w->rc->fb_h * 2
                                runtime_actual_h = (w->rc->fb_h * 12 / 10) * 2
                                tex = sdl2.create_texture(ren, sdl2.pixel_argb8888,
                                    sdl2.tex_streaming, runtime_screen_w, runtime_screen_h)
                                sdl2.set_logical_size(ren, runtime_screen_w, runtime_actual_h)
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.main
                            g->menu_sel = 5     // back to CHANGE VIEW row
                    else if g->menu_level == menu.nav.options then
                        // Wolf-fc mods. Up/down navigates rows; Enter
                        // toggles boolean rows or runs the action row;
                        // Left/Right adjusts slider rows by ±5%.
                        // Every commit persists the full prefs struct
                        // via config.snapshot — never partial — so
                        // other unrelated toggles round-trip cleanly.
                        let kind = menu.option_kind(g->menu_sel)
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + menu.options_len - 1) % menu.options_len
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % menu.options_len
                        else if is_confirm && kind == menu.option_kind_toggle then
                            // Toggle row 0 = No Dogs.
                            if g->menu_sel == 0 then
                                g->no_dogs = !g->no_dogs
                            config.save(config.snapshot(w))
                        else if is_confirm && kind == menu.option_kind_action then
                            // Action row = RESET. Wipe every Options
                            // field back to its default — sound
                            // toggles are deliberately untouched
                            // (different submenu, different scope).
                            let d = config.defaults()
                            g->no_dogs = d.no_dogs
                            g->shadow_depth = d.shadow_depth
                            g->bj_speed_pct = d.bj_speed_pct
                            g->enemy_speed_pct = d.enemy_speed_pct
                            config.save(config.snapshot(w))
                        else if (k == sdl2.key_left || k == sdl2.key_right)
                            && kind == menu.option_kind_slider then
                            // Slider rows. Shadow Depth uses ±5% in 0..100;
                            // the BJ / Enemy Speed sliders use ±5% in
                            // 20..200 (constants live in `config`).
                            if g->menu_sel == 1 then
                                let delta = if k == sdl2.key_left then -5 else 5
                                let mut v = g->shadow_depth + delta
                                if v < 0 then v = 0
                                if v > 100 then v = 100
                                g->shadow_depth = v
                            else if g->menu_sel == 2 then
                                let delta = if k == sdl2.key_left then 0 - config.speed_pct_step else config.speed_pct_step
                                let mut v = g->bj_speed_pct + delta
                                if v < config.speed_pct_min then v = config.speed_pct_min
                                if v > config.speed_pct_max then v = config.speed_pct_max
                                g->bj_speed_pct = v
                            else if g->menu_sel == 3 then
                                let delta = if k == sdl2.key_left then 0 - config.speed_pct_step else config.speed_pct_step
                                let mut v = g->enemy_speed_pct + delta
                                if v < config.speed_pct_min then v = config.speed_pct_min
                                if v > config.speed_pct_max then v = config.speed_pct_max
                                g->enemy_speed_pct = v
                            config.save(config.snapshot(w))
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.main
                            g->menu_sel = 2     // back to OPTIONS row
                    else if g->menu_level == menu.nav.savelist then
                        // Inline save-name entry: while editing, every
                        // keydown mutates `sm->edit_buf` instead of
                        // navigating slots. Mirrors the original's
                        // `US_LineInput` flow on each save row.
                        if g->save_edit_active then
                            if k == sdl2.key_return then
                                // Commit — write the slot using the
                                // typed name (defaulting to "EMPTY"
                                // if the user cleared the buffer
                                // entirely).
                                let n = w->sm->edit_len
                                let label = if n > 0 then
                                    (const str) w->sm->edit_buf[0..(int64) n]
                                else "EMPTY"
                                save.to_slot(w, g->menu_sel, label)
                                save.refresh_slots(w->sm)
                                g->save_edit_active = false
                                g->menu_level = menu.nav.main
                                g->menu_sel = 4     // back to SAVE GAME row
                            else if k == sdl2.key_escape then
                                // Cancel: clear edit buffer, stay on
                                // slot list.
                                g->save_edit_active = false
                                w->sm->edit_len = 0
                                w->sm->edit_buf[0i64] = 0u8
                            else if k == sdl2.key_backspace then
                                if w->sm->edit_len > 0 then
                                    w->sm->edit_len = w->sm->edit_len - 1
                                    w->sm->edit_buf[(int64) w->sm->edit_len] = 0u8
                            else
                                // Printable-ASCII char → append. Same
                                // shift-aware mapping as the high-
                                // scores name editor (the OG used
                                // US_LineInput's `isprint(c)` filter
                                // for both screens). Capacity is 32
                                // (MaxString); reserve 1 for NUL.
                                let cap = (int32) w->sm->edit_buf.len - 1
                                if w->sm->edit_len < cap then
                                    let ch = keysym_to_ascii(k, event.key.keysym.mod)
                                    if ch != 0u8 then
                                        w->sm->edit_buf[(int64) w->sm->edit_len] = ch
                                        w->sm->edit_len = w->sm->edit_len + 1
                                        w->sm->edit_buf[(int64) w->sm->edit_len] = 0u8
                        else if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + save.num_slots - 1) % save.num_slots
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % save.num_slots
                        else if is_confirm then
                            // Enter edit mode, prefilled with the
                            // existing slot label (so re-saving over
                            // a slot doesn't force the user to retype).
                            let s = &w->sm->slots[g->menu_sel]
                            let mut n = if s->empty then 0
                                else (int32) s->label.len
                            if n > 31 then n = 31
                            for i in 0..n
                                w->sm->edit_buf[(int64) i] = s->label[(int64) i]
                            w->sm->edit_buf[(int64) n] = 0u8
                            w->sm->edit_len = n
                            g->save_edit_active = true
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.main
                            g->menu_sel = 4     // back to SAVE GAME row
                    else if g->menu_level == menu.nav.loadlist then
                        if k == sdl2.key_up then
                            g->menu_sel = (g->menu_sel + save.num_slots - 1) % save.num_slots
                        else if k == sdl2.key_down then
                            g->menu_sel = (g->menu_sel + 1) % save.num_slots
                        else if is_confirm then
                            if !w->sm->slots[g->menu_sel].empty then
                                if save.from_slot(w, vs, g->menu_sel) then
                                    g->has_active_game = true
                        else if k == sdl2.key_escape then
                            g->menu_level = menu.nav.main
                            g->menu_sel = 3     // back to LOAD GAME
                    else if g->menu_level == menu.nav.quit then
                        // Quit-confirm modal. Y commits; N / Esc cancels
                        // back to the main menu. Enter / Space are
                        // intentionally not synonyms for Y — matches the
                        // original game's strict-Y behaviour.
                        if k == sdl2.key_y then
                            sfx.trigger(sfx.id.shoot, w->ac)
                            g->want_quit = true
                        else if k == sdl2.key_n || k == sdl2.key_escape then
                            // Esc already played esc_pressed via the
                            // shared dispatch above; trigger it
                            // explicitly for the N case so the cancel
                            // sound is consistent across both keys.
                            if k == sdl2.key_n then
                                sfx.trigger(sfx.id.esc_pressed, w->ac)
                            g->menu_level = menu.nav.main
                            g->menu_sel = 8     // back to QUIT row
                | high_scores ->
                    // Direct dispatch (not via the IN_Ack latch) so the
                    // typing keys during edit don't double as ack
                    // presses, and so Enter / Esc both commit-and-
                    // dismiss in one keystroke — matches the OG, where
                    // CheckHighScore returns to its caller the moment
                    // US_LineInput returns. Without this we'd need the
                    // player to press Enter twice (first to commit name,
                    // again to leave the screen).
                    if !is_key_repeat then
                        let mods = event.key.keysym.mod
                        if w->hs->edit_active then
                            if k == sdl2.key_return || k == sdl2.key_escape then
                                // Commit + dismiss. The OG copies the
                                // buffer regardless of whether Enter or
                                // Esc dismissed the line input.
                                high_scores_screen.commit_name(w->hs)
                                high_scores_screen.dismiss(g, w->hs)
                            else if k == sdl2.key_backspace then
                                high_scores_screen.edit_backspace(w->hs)
                            else
                                let ch = keysym_to_ascii(k, mods)
                                if ch != 0u8 then
                                    high_scores_screen.edit_append(w->hs, ch)
                        else
                            // Not editing — any deliberate ack key
                            // dismisses (the OG's `IN_UserInput(500)`
                            // takes any key in the no-qualify branch).
                            let is_ack = k == sdl2.key_return
                                || k == sdl2.key_space
                                || k == sdl2.key_lctrl
                                || k == sdl2.key_escape
                            if is_ack then
                                high_scores_screen.dismiss(g, w->hs)
                | _ ->
                    // playing, dying, intermission, episode_end,
                    // bj_victory, death_cam. Escape from playing
                    // jumps to the main menu (which doubles as the pause UI
                    // — BACK TO GAME is the default selection so any-key-Esc-
                    // any-key resumes immediately). Other phases consume keys
                    // for their own advance flow (handled separately below).
                    if k == sdl2.key_escape && g->phase == game_phase.playing then
                        g->phase = game_phase.main_menu
                        g->menu_level = menu.nav.main
                        g->menu_sel = 7     // BACK TO GAME row
                        // Clear held inputs so the player isn't sprinting
                        // when they un-pause. (Mirrors intermission.enter's
                        // input-clear convention.)
                        g->key_up = false
                        g->key_down = false
                        g->key_left = false
                        g->key_right = false
                        g->key_fire = false
                    else if !is_key_repeat then
                        // TAB+<key> cheats (from the original's debugmode
                        // menu). When TAB is held and the pressed key maps
                        // to a cheat, dispatch it and suppress the normal
                        // per-key handlers so e.g. TAB+I doesn't also
                        // latch the MLI 'I' chord or retrigger iddqd
                        // progress. Gated to the playing phase so the
                        // combo is inert on menus / intermission.
                        let tab_cheat = g->key_tab_held
                           && g->phase == game_phase.playing
                           && (k == sdl2.key_g || k == sdl2.key_i
                               || k == sdl2.key_n || k == sdl2.key_e
                               || k == sdl2.key_h)
                        if tab_cheat then
                            if k == sdl2.key_g then player.cheats.apply_tab_g(g)
                            if k == sdl2.key_i then player.cheats.apply_tab_i(g, w->ac)
                            if k == sdl2.key_n then player.cheats.apply_tab_n(g)
                            if k == sdl2.key_e then player.cheats.apply_tab_e(g)
                            if k == sdl2.key_h then
                                // Synthetic damage — no in-world attacker, so feed
                                // the player's own position. update_death_swing
                                // sees a zero-length vector and clears killer_active
                                // immediately (no rotation).
                                enemies.ai.damage_player(g, w->ac, 16, enemies.damage_source.bullet, g->pos_x, g->pos_y)
                        else
                            if k == sdl2.key_up then g->key_up = true
                            if k == sdl2.key_down then g->key_down = true
                            if k == sdl2.key_left then g->key_left = true
                            if k == sdl2.key_right then g->key_right = true
                            if k == sdl2.key_lshift then g->key_shift = true
                            if k == sdl2.key_lalt then g->key_alt = true
                            if k == sdl2.key_space then g->key_space = true
                            if k == sdl2.key_lctrl then g->key_fire = true
                            if k == sdl2.key_tab then g->key_tab_held = true
                            if k == sdl2.key_1 then g->weapon = 0
                            if k == sdl2.key_2 then g->weapon = 1
                            if k == sdl2.key_3 then g->weapon = 2
                            if k == sdl2.key_4 then g->weapon = 3
                            // Cheat-chord held-flags. M/L/I/B/A/T have no other
                            // in-game action (M used to toggle music but that
                            // clashed with the MLI chord; use the main menu's
                            // SOUND entry to toggle music now).
                            if k == sdl2.key_m then g->key_m_held = true
                            if k == sdl2.key_l then g->key_l_held = true
                            if k == sdl2.key_i then g->key_i_held = true
                            if k == sdl2.key_b then g->key_b_held = true
                            if k == sdl2.key_a then g->key_a_held = true
                            if k == sdl2.key_t then g->key_t_held = true
                            // IDDQD / IDKFA sequences — only progress while
                            // in-game, matching how the chord cheats are
                            // gated. Held keys can't auto-advance because
                            // we're already inside the !is_key_repeat branch.
                            if g->phase == game_phase.playing then
                                player.cheats.advance_iddqd(g, k)
                                player.cheats.advance_idkfa(g, k)
                            if k == sdl2.key_s then overlay.take_screenshot(w, vs, pal)
                            // Debug-state dump used to live on plain D — moved
                            // under the TAB chord so a stray D press during
                            // gameplay doesn't spam the console.
                            if k == sdl2.key_d && g->key_tab_held then
                                save.debug_dump_state(w)
                            // IN_Ack: a deliberate-feeling keypress (Enter,
                            // Space, Ctrl — the OG fire key, or Esc as a
                            // "get me out of here" key) during an
                            // acknowledge screen (intermission / episode-end
                            // / final victory / game-over) counts as
                            // "acknowledge and advance". The OG accepted
                            // any LastScan including modifier keys, but on
                            // modern keyboards a stray Shift / Win / Menu
                            // / function key shouldn't skip past the screen.
                            // The advance itself runs below (after tick)
                            // and is gated by key_ack_handled so a held
                            // key only fires once.
                            let is_ack_key = k == sdl2.key_return
                                || k == sdl2.key_space
                                || k == sdl2.key_lctrl
                                || k == sdl2.key_escape
                            if is_ack_key && (g->phase == game_phase.intermission
                               || g->phase == game_phase.episode_end) then
                                g->key_ack = true
            if t == sdl2.keyup_event then
                let k = event.key.keysym.sym
                // Keyup only clears flags; not phase-sensitive.
                if k == sdl2.key_up then g->key_up = false
                if k == sdl2.key_down then g->key_down = false
                if k == sdl2.key_left then g->key_left = false
                if k == sdl2.key_right then g->key_right = false
                if k == sdl2.key_lshift then g->key_shift = false
                if k == sdl2.key_lalt then g->key_alt = false
                if k == sdl2.key_lctrl then g->key_fire = false
                if k == sdl2.key_tab then g->key_tab_held = false
                // Cheat-chord held-flags (see keydown side).
                if k == sdl2.key_m then g->key_m_held = false
                if k == sdl2.key_l then g->key_l_held = false
                if k == sdl2.key_i then g->key_i_held = false
                if k == sdl2.key_b then g->key_b_held = false
                if k == sdl2.key_a then g->key_a_held = false
                if k == sdl2.key_t then g->key_t_held = false
                if k == sdl2.key_space then
                    g->key_space = false
                    g->key_space_handled = false
                // Any keyup rearms the IN_Ack latch so the next press can fire.
                g->key_ack = false
                g->key_ack_handled = false

        // Cheat chords (M+L+I, B+A+T). Only fires while actually playing,
        // so holding the letters on menus / intermission / death screens
        // is a no-op. Runs before tick so the refilled health/ammo/weapon
        // is visible the same frame.
        if g->phase == game_phase.playing then
            player.cheats.check_chords(g)

        // Update
        tick(w, dt)

        // Phase transitions (elevator→intermission, death→restart/high-scores).
        // Music chunk swap is handled below from a single source of truth
        // (font.music_chunk_for_phase); no per-call music_switch flag needed.
        update_phase_transitions(w, vs)
        // Intermission → either episode-end (if we just finished level 8)
        // or next map. The episode-end screen owns its own space-advance.
        // First press of space while the count-up is running skips animation
        // to the final "everything shown" state; next press advances.
        if g->phase == game_phase.intermission && g->phase_timer > 0.0
           && g->key_ack && !g->key_ack_handled then
            g->key_ack_handled = true
            if g->inter_stage < 4 then
                intermission.finish_anim(g)
            else if g->level_num % episode.levels_per == 8 then
                episode_end.enter(g)
            else
                advance_next_level(w, vs)
        // Episode-end → per-episode ending text article. The article's
        // last page (or Esc) returns to the main menu — the OG GameLoop
        // returns from ex_victorious back to the control panel; players
        // replay episodes individually from the menu.
        if g->phase == game_phase.episode_end && g->phase_timer > 0.0
           && g->key_ack && !g->key_ack_handled then
            g->key_ack_handled = true
            let ep = g->level_num / episode.levels_per
            endart_screen.enter(g, w->vg, ep)
        // Endart paging is handled directly in the keydown event below
        // (Left/Up/PageUp = back, Esc = exit-to-menu, forward keys =
        // next page) — not via the IN_Ack latch since the IN_Ack
        // pattern can't distinguish key direction. high_scores is
        // also dispatched directly (the editing flow needs typing keys
        // distinct from ack keys; see the high_scores arm above).
        // Sync the active music to whatever phase we're now in. Only swap
        // when the chunk actually changed, so we don't restart the IMF
        // player every frame. Don't call `sdl2.clear_audio` here — the
        // already-queued ~46 ms of old music drains naturally while the
        // new chunk's samples take over, which sounds cleaner than the
        // audible underrun a hard flush causes.
        let want_chunk = font.music_chunk_for_phase(g->phase, g->level_num)
        if want_chunk != current_music_chunk then
            if audio_dev > 0u32 && want_chunk < ad->num_chunks then
                if ms.is_some then imf.destroy(ms!)
                ms = some(font.music_load(ad, want_chunk))
                current_music_chunk = want_chunk

        // Render
        render_frame(w, vs, pal)

        // Generate and queue audio: music -> AdLib SFX -> digi SFX -> SDL.
        // Buffer is 1024 STEREO frames (2048 int16 values = 4096 bytes);
        // drivers write L/R interleaved additively. Back-pressure threshold
        // is also in bytes.
        // Keep ~90 ms of queued stereo audio. Bigger than strictly needed
        // but cheap insurance against single-frame render hitches: if the
        // queue empties between fills, PulseAudio/PipeWire backends can
        // disconnect the SDL_QueueAudio stream entirely (silent music + SFX
        // until restart), which is exactly the failure mode we kept hitting.
        let queue_hi_water = 16384u32   // bytes; ~92ms of stereo audio
        let skip_audio = audio_dev == 0u32 ||
            sdl2.queued_audio_size(audio_dev) >= queue_hi_water
        if !skip_audio then
            mixer.fill_frame(mix_buf, out_buf, ms, music_on,
                w->ac->sfx, w->ac->digi, 1024, sfx.sample_rate)
            sdl2.queue_audio(audio_dev, (any*) out_buf.ptr, 4096u32)
            void()

        // Upload framebuffer to texture and display. render_frame
        // produces a fully-composited 640x400 dbuf for every phase
        // (3D phases skip the fb intermediate for the viewport region;
        // non-3D phases call upscale_2x internally).
        sdl2.update_texture(tex, (any*) 0, (any*) w->rc->dbuf.ptr, runtime_screen_w * 4)
        sdl2.clear(ren)
        sdl2.render_copy(ren, tex, (any*) 0, (any*) 0)
        sdl2.present(ren)

    // Cleanup
    if audio_dev > 0u32 then sdl2.close_audio(audio_dev)
    sdl2.destroy_texture(tex)
    sdl2.destroy_renderer(ren)
    sdl2.destroy_window(win)
    sdl2.quit()
    quit_prompts.free_override(g->quit_prompts_override)
    0
